<%
  // pageMode controls how nav items render:
  //   'dashboard' — <button> elements that call showView() via JS
  //   'index'     — <a> links that navigate to /web-dashboard?view=...
  // Defaults to 'index' (safe for any non-dashboard page)
  // Use this header for any new pages you create, and set pageMode as needed when including it.
  
  var _mode = (typeof pageMode !== 'undefined') ? pageMode : 'index';
%>

<header class="top-header">

  <!-- Brand — always links to home -->
  <a href="/" class="header-brand">
    <img src="/images/scsu_logo.png" alt="SCSU" onerror="this.style.display='none'" />
    <div class="brand-text">
      <span class="brand-cs">CS_LIBRARY</span>
      <span class="brand-sep">|</span>
      <span class="brand-scsu">SCSU</span>
    </div>
  </a>

  <div class="hdr-pipe"></div>

  <!-- Desktop nav -->
  <nav class="header-nav">
    <% if (_mode === 'dashboard') { %>
      <button class="hdr-nav-btn active" id="nav-catalog" onclick="showView('catalog')">My Library</button>
      <button class="hdr-nav-btn"        id="nav-mybooks" onclick="showView('mybooks')">My Books</button>
      <button class="hdr-nav-btn"        id="nav-suggest" onclick="showView('suggest')">Suggest</button>
    <% } else { %>
      <a href="/web-dashboard?view=catalog" class="hdr-nav-btn">My Library</a>
      <a href="/web-dashboard?view=mybooks" class="hdr-nav-btn">My Books</a>
      <a href="/web-dashboard?view=suggest" class="hdr-nav-btn">Suggest</a>
    <% } %>
  </nav>

  <!-- Right side — user info or sign in/register -->
  <div class="header-right">
    <% if (user) { %>
      <span class="header-user-name"><%= user.name %></span>
      <a href="/auth/logout" class="logout-btn">Sign out</a>
    <% } else { %>
      <a href="/auth/login"    class="sign-in-link">Sign in</a>
    <% } %>
  </div>

  <!-- Hamburger — mobile only -->
  <button class="hamburger" id="hamburgerBtn" onclick="toggleMobileMenu()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>

  <!-- Mobile dropdown -->
  <div class="mobile-menu" id="mobileMenu">
    <% if (_mode === 'dashboard') { %>
      <button class="mobile-item active" id="mnav-catalog" onclick="showView('catalog');closeMobileMenu()">My Library</button>
      <button class="mobile-item"        id="mnav-mybooks" onclick="showView('mybooks');closeMobileMenu()">My Books</button>
      <button class="mobile-item"        id="mnav-suggest" onclick="showView('suggest');closeMobileMenu()">Suggest</button>
    <% } else { %>
      <a href="/web-dashboard?view=catalog" class="mobile-item">My Library</a>
      <a href="/web-dashboard?view=mybooks" class="mobile-item">My Books</a>
      <a href="/web-dashboard?view=suggest" class="mobile-item">Suggest</a>
    <% } %>
    <div class="mobile-divider"></div>
    <% if (user) { %>
      <span class="mobile-user"><%= user.name %></span>
      <a href="/auth/logout" class="mobile-item mobile-signout">Sign Out</a>
    <% } else { %>
      <a href="/auth/login"    class="mobile-item">Sign In</a>
      <a href="/auth/register" class="mobile-item" style="color:#60a5fa;font-weight:700;">Create Account</a>
    <% } %>
  </div>

</header>

<script>
  function toggleMobileMenu() {
    document.getElementById('hamburgerBtn').classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  }
  function closeMobileMenu() {
    document.getElementById('hamburgerBtn').classList.remove('open');
    document.getElementById('mobileMenu').classList.remove('open');
  }

  // Close the mobile menu automatically when the window is resized
  // wide enough that the hamburger button is no longer visible.
  window.addEventListener('resize', function() {
    const btn = document.getElementById('hamburgerBtn');
    if (btn && getComputedStyle(btn).display === 'none') {
      closeMobileMenu();
    }
  });
</script>
