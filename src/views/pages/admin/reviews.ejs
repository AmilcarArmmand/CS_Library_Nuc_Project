<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin-mobile.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Space Grotesk', sans-serif; background: #020617; color: white; min-height: 100vh; }
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%),
        radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%);
    }
    .admin-layout { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    /* Sidebar */
    .sidebar { width: 250px; background: rgba(10,15,28,0.95); border-right: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; padding: 1.5rem 0; flex-shrink: 0; backdrop-filter: blur(20px); position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; }
    .sidebar-brand { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 1rem; }
    .sidebar-brand h1 { font-size: 0.85rem; font-weight: 900; letter-spacing: 0.15em; }
    .sidebar-brand span { font-size: 0.65rem; color: #60a5fa; font-weight: 300; letter-spacing: 0.15em; }
    .nav-items { display: flex; flex-direction: column; gap: 0.15rem; padding: 0 0.75rem; flex: 1; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; border-radius: 0.5rem; text-decoration: none; color: #94a3b8; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; white-space: nowrap; }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
    .nav-item.active { background: rgba(59,130,246,0.15); color: #60a5fa; }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }
    .sidebar-footer .admin-name { font-size: 0.75rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.15rem; }
    .sidebar-footer .admin-email { font-size: 0.65rem; color: #64748b; margin-bottom: 0.6rem; }
    .signout-btn { display: inline-block; padding: 0.35rem 0.75rem; border-radius: 0.35rem; font-size: 0.68rem; font-weight: 700; color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); text-decoration: none; }
    .main { flex: 1; margin-left: 250px; padding: 2rem; }
    .page-title { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
    .page-sub   { font-size: 0.82rem; color: #64748b; margin-bottom: 1.5rem; }

    .panel { background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55); border-radius: 1rem; padding: 1.5rem; backdrop-filter: blur(12px); margin-bottom: 1.5rem; }
    .panel-title { font-size: 0.72rem; letter-spacing: 0.2em; font-weight: 900; text-transform: uppercase; color: #60a5fa; margin-bottom: 1rem; }

    /* Toolbar */
    .toolbar { display: flex; gap: 0.5rem; margin-bottom: 1.25rem; flex-wrap: wrap; align-items: center; }
    .filter-btn { padding: 0.35rem 0.85rem; border-radius: 9999px; font-family: inherit; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: #94a3b8; transition: all 0.2s; text-decoration: none; }
    .filter-btn:hover  { background: rgba(255,255,255,0.1); color: white; }
    .filter-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); }
    .filter-btn.deleted-active { background: rgba(239,68,68,0.15); color: #f87171; border-color: rgba(239,68,68,0.4); }
    .separator { width: 1px; height: 1.2rem; background: rgba(255,255,255,0.1); margin: 0 0.15rem; }
    .search-input { padding: 0.4rem 0.85rem; border-radius: 9999px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); color: white; font-family: inherit; font-size: 0.78rem; outline: none; margin-left: auto; width: 240px; }
    .search-input:focus { border-color: rgba(59,130,246,0.5); }

    /* Table */
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid rgba(71,85,105,0.4); }
    td { font-size: 0.78rem; padding: 0.75rem 0.75rem; border-bottom: 1px solid rgba(71,85,105,0.2); color: #cbd5e1; vertical-align: top; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    /* Stars */
    .stars { display: inline-flex; gap: 1px; }
    .star-f { color: #fbbf24; font-size: 0.82rem; }
    .star-e { color: #1e293b;  font-size: 0.82rem; }

    /* Badges */
    .badge { display: inline-block; padding: 0.2rem 0.55rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.08em; }
    .badge-book  { background: rgba(59,130,246,0.15);  color: #60a5fa; }
    .badge-equip { background: rgba(168,85,247,0.15);  color: #c084fc; }
    .badge-deleted { background: rgba(239,68,68,0.15); color: #f87171; }

    /* Action buttons */
    .btn { padding: 0.3rem 0.7rem; border-radius: 0.45rem; font-family: inherit; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.06em; cursor: pointer; border: 1px solid; transition: all 0.2s; }
    .btn-red     { background: rgba(239,68,68,0.1);   color: #f87171; border-color: rgba(239,68,68,0.25); }
    .btn-red:hover     { background: rgba(239,68,68,0.25); }
    .btn-green   { background: rgba(34,197,94,0.1);   color: #4ade80; border-color: rgba(34,197,94,0.25); }
    .btn-green:hover   { background: rgba(34,197,94,0.25); }

    /* Review body */
    .review-body-cell { max-width: 260px; }
    .review-body-text { font-size: 0.74rem; color: #94a3b8; line-height: 1.5; }
    .review-body-empty { font-size: 0.7rem; color: #334155; font-style: italic; }

    /* Toast */
    .toast-wrap { position: fixed; top: 1.25rem; right: 1.25rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }
    .toast { padding: 0.65rem 1rem; border-radius: 0.65rem; font-size: 0.78rem; font-weight: 600; border: 1px solid; animation: dropIn 0.25s ease; }
    .toast.positive { background: rgba(34,197,94,0.15);  color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .toast.negative { background: rgba(239,68,68,0.15);  color: #f87171; border-color: rgba(239,68,68,0.3); }
    @keyframes dropIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) { .main { margin-left: 0; } }
  </style>
</head>
<body>
<div class="admin-layout">

  <%- include('./partials/sidebar', { activePage: 'reviews', mobileTitle: 'Reviews', admin: admin }) %>
  <div class="toast-wrap" id="toastWrap"></div>

  <main class="main">
    <h1 class="page-title">Review Management</h1>
    <p class="page-sub">
      View and moderate user reviews for books and equipment.
      Soft-deleted reviews are hidden from users but can be restored.
      Total visible: <%= total %>
    </p>

    <!-- Filters -->
    <div class="toolbar">
      <!-- Type filter -->
      <a href="/admin/reviews?type=all&status=<%= filterStatus %>"
         class="filter-btn <%= filterType === 'all' ? 'active' : '' %>">ALL TYPES</a>
      <a href="/admin/reviews?type=book&status=<%= filterStatus %>"
         class="filter-btn <%= filterType === 'book' ? 'active' : '' %>">BOOKS</a>
      <a href="/admin/reviews?type=equipment&status=<%= filterStatus %>"
         class="filter-btn <%= filterType === 'equipment' ? 'active' : '' %>">EQUIPMENT</a>

      <div class="separator"></div>

      <!-- Status filter -->
      <a href="/admin/reviews?type=<%= filterType %>&status=live"
         class="filter-btn <%= filterStatus === 'live' ? 'active' : '' %>">LIVE</a>
      <a href="/admin/reviews?type=<%= filterType %>&status=deleted"
         class="filter-btn <%= filterStatus === 'deleted' ? 'deleted-active' : '' %>">DELETED</a>

      <input type="text" class="search-input" placeholder="Search by user, item, or review…"
             oninput="filterReviews(this.value)" />
    </div>

    <div class="panel">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Type</th>
              <th>Rating</th>
              <th>Review</th>
              <th>User</th>
              <th>Date</th>
              <% if (filterStatus === 'deleted') { %>
                <th>Deleted</th>
              <% } %>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="reviewTable">
            <% if (reviewList.length === 0) { %>
              <tr>
                <td colspan="<%= filterStatus === 'deleted' ? 8 : 7 %>"
                    style="text-align:center;color:#334155;padding:2rem;">
                  No reviews found.
                </td>
              </tr>
            <% } %>
            <% reviewList.forEach(function(rv) { %>
              <tr class="review-row"
                  data-search="<%= (rv.itemName || '').toLowerCase() %> <%= (rv.userName || '').toLowerCase() %> <%= (rv.body || '').toLowerCase() %>">
                <td style="font-weight:700;max-width:180px;">
                  <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= rv.itemName %></span>
                  <span style="font-size:0.62rem;color:#64748b;font-family:ui-monospace,monospace;"><%= rv.targetId %></span>
                </td>
                <td>
                  <span class="badge <%= rv.targetType === 'book' ? 'badge-book' : 'badge-equip' %>">
                    <%= rv.targetType === 'book' ? 'BOOK' : 'EQUIPMENT' %>
                  </span>
                </td>
                <td>
                  <div class="stars">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <span class="<%= i <= rv.rating ? 'star-f' : 'star-e' %>">★</span>
                    <% } %>
                  </div>
                  <div style="font-size:0.62rem;color:#64748b;margin-top:0.15rem;"><%= rv.rating %>/5</div>
                </td>
                <td class="review-body-cell">
                  <% if (rv.body && rv.body.trim()) { %>
                    <p class="review-body-text"><%= rv.body.length > 200 ? rv.body.slice(0, 200) + '…' : rv.body %></p>
                  <% } else { %>
                    <p class="review-body-empty">No written review</p>
                  <% } %>
                </td>
                <td>
                  <div style="font-weight:600;"><%= rv.userName %></div>
                  <div style="font-size:0.65rem;color:#64748b;"><%= rv.userEmail %></div>
                </td>
                <td style="font-size:0.72rem;white-space:nowrap;">
                  <%= new Date(rv.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </td>
                <% if (filterStatus === 'deleted') { %>
                  <td style="font-size:0.72rem;white-space:nowrap;color:#f87171;">
                    <%= rv.deletedAt ? new Date(rv.deletedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %>
                  </td>
                <% } %>
                <td>
                  <% if (filterStatus === 'deleted') { %>
                    <button class="btn btn-green"
                            onclick="restoreReview(<%= rv.id %>)">RESTORE</button>
                  <% } else { %>
                    <button class="btn btn-red"
                            onclick="deleteReview(<%= rv.id %>)">DELETE</button>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script src="/js/admin-mobile.js"></script>
<script>
  function toast(msg, type = 'positive') {
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.textContent = msg;
    document.getElementById('toastWrap').appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }

  function filterReviews(q) {
    q = q.toLowerCase().trim();
    document.querySelectorAll('#reviewTable tr.review-row').forEach(row => {
      row.style.display = (!q || row.dataset.search.includes(q)) ? '' : 'none';
    });
  }

  async function deleteReview(id) {
    if (!confirm('Soft-delete this review? It will be hidden from users but can be restored.')) return;
    try {
      const r = await fetch(`/admin/reviews/${id}/delete`, { method: 'POST' });
      const d = await r.json();
      if (!r.ok) { toast(d.error ?? 'Failed.', 'negative'); return; }
      toast('Review deleted.', 'positive');
      setTimeout(() => location.reload(), 600);
    } catch { toast('Server error.', 'negative'); }
  }

  async function restoreReview(id) {
    try {
      const r = await fetch(`/admin/reviews/${id}/restore`, { method: 'POST' });
      const d = await r.json();
      if (!r.ok) { toast(d.error ?? 'Failed.', 'negative'); return; }
      toast('Review restored.', 'positive');
      setTimeout(() => location.reload(), 600);
    } catch { toast('Server error.', 'negative'); }
  }
</script>
</body>
</html>
