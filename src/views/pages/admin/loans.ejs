<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin-mobile.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Space Grotesk', sans-serif; background: #020617; color: white; min-height: 100vh; }
    body::before { content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none; background: radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%), radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%); }
    .admin-layout { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    .sidebar { width: 250px; background: rgba(10,15,28,0.95); border-right: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; padding: 1.5rem 0; flex-shrink: 0; backdrop-filter: blur(20px); position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; }
    .sidebar-brand { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 1rem; }
    .sidebar-brand h1 { font-size: 0.85rem; font-weight: 900; letter-spacing: 0.15em; }
    .sidebar-brand span { font-size: 0.65rem; color: #60a5fa; font-weight: 300; letter-spacing: 0.15em; }
    .nav-items { display: flex; flex-direction: column; gap: 0.15rem; padding: 0 0.75rem; flex: 1; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; border-radius: 0.5rem; text-decoration: none; color: #94a3b8; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
    .nav-item.active { background: rgba(59,130,246,0.15); color: #60a5fa; }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }
    .signout-btn { display: inline-block; padding: 0.35rem 0.75rem; border-radius: 0.35rem; font-size: 0.68rem; font-weight: 700; color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); text-decoration: none; }

    .main { flex: 1; margin-left: 250px; padding: 2rem; }
    .page-title { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
    .page-sub { font-size: 0.82rem; color: #64748b; margin-bottom: 1.5rem; }

    .toolbar { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center; }
    .filter-btn { padding: 0.35rem 0.85rem; border-radius: 9999px; font-family: inherit; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: #94a3b8; transition: all 0.2s; }
    .filter-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .filter-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); }
    .btn { padding: 0.4rem 1rem; border-radius: 0.5rem; font-family: inherit; font-size: 0.72rem; font-weight: 700; cursor: pointer; border: 1px solid; transition: all 0.2s; text-decoration: none; }
    .btn-green { background: rgba(34,197,94,0.15); color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .btn-green:hover { background: rgba(34,197,94,0.3); }

    .panel { background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55); border-radius: 1rem; padding: 1.5rem; backdrop-filter: blur(12px); }

    table { width: 100%; border-collapse: collapse; }
    th { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid rgba(71,85,105,0.4); cursor: pointer; }
    th:hover { color: #e2e8f0; }
    td { font-size: 0.78rem; padding: 0.55rem 0.75rem; border-bottom: 1px solid rgba(71,85,105,0.2); color: #cbd5e1; }
    tr:hover td { background: rgba(255,255,255,0.02); }
    .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; }
    .badge-active { background: rgba(34,197,94,0.15); color: #4ade80; }
    .badge-returned { background: rgba(100,116,139,0.2); color: #94a3b8; }
    .badge-overdue { background: rgba(239,68,68,0.15); color: #f87171; }
    .overdue-days { font-size: 0.65rem; color: #f87171; font-weight: 700; }
    .search-input { padding: 0.4rem 0.85rem; border-radius: 9999px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); color: white; font-family: inherit; font-size: 0.78rem; outline: none; margin-left: auto; width: 220px; }
    .search-input:focus { border-color: rgba(59,130,246,0.5); }
    .request-grid { display: grid; gap: 0.85rem; }
    .request-card { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem; border-radius: 0.85rem; border: 1px solid rgba(71,85,105,0.35); background: rgba(255,255,255,0.02); }
    .request-title { font-size: 0.85rem; font-weight: 700; color: #f8fafc; }
    .request-meta { font-size: 0.72rem; color: #94a3b8; margin-top: 0.25rem; line-height: 1.5; }
    .request-actions { display: flex; flex-direction: column; gap: 0.45rem; align-items: flex-end; flex-shrink: 0; }
    .btn-blue { background: rgba(59,130,246,0.16); color: #93c5fd; border-color: rgba(59,130,246,0.35); }
    .btn-blue:hover { background: rgba(59,130,246,0.28); }
    .btn-red { background: rgba(239,68,68,0.1); color: #f87171; border-color: rgba(239,68,68,0.25); }
    .btn-red:hover { background: rgba(239,68,68,0.2); }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('./partials/sidebar', { activePage: 'loans', mobileTitle: 'Loans', admin: admin }) %>

  <main class="main">
    <h1 class="page-title">Loan Management</h1>
    <p class="page-sub">View and manage all checkout activity</p>

    <div class="toolbar">
      <button class="filter-btn active" id="tab-books" onclick="switchTab('books')">📚 BOOKS</button>
      <button class="filter-btn"        id="tab-equipment" onclick="switchTab('equipment')">🔧 EQUIPMENT</button>
      <span style="width:1px;height:1.2rem;background:rgba(255,255,255,0.1);margin:0 0.25rem;"></span>
      <button class="filter-btn active" id="filter-all"      onclick="filterLoans('all', event)">ALL</button>
      <button class="filter-btn"        id="filter-active"   onclick="filterLoans('active', event)">ACTIVE</button>
      <button class="filter-btn"        id="filter-overdue"  onclick="filterLoans('overdue', event)">OVERDUE</button>
      <button class="filter-btn"        id="filter-returned" onclick="filterLoans('returned', event)">RETURNED</button>
      <a href="/admin/loans/csv" class="btn btn-green" style="margin-left:auto;">EXPORT CSV</a>
      <input type="text" class="search-input" placeholder="Search by name or title…" oninput="searchLoans(this.value)" />
    </div>

    <div class="panel" style="margin-bottom:1rem;">
      <div class="panel-title">Pending Extension Requests (<%= renewalRequests.length %>)</div>
      <% if (!renewalRequests.length) { %>
        <p style="color:#64748b;font-size:0.8rem;">No extension requests are waiting for review.</p>
      <% } else { %>
        <div class="request-grid">
          <% renewalRequests.forEach(request => { %>
            <div class="request-card" id="request-<%= request.id %>">
              <div>
                <div class="request-title"><%= request.title %></div>
                <div class="request-meta">
                  <div><strong><%= request.userName %></strong> (<%= request.userEmail %>)</div>
                  <div>Current due date: <%= new Date(request.dueDate).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></div>
                  <div>Requested: <%= new Date(request.requestedAt).toLocaleString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit' }) %></div>
                </div>
              </div>
              <div class="request-actions">
                <button class="btn btn-blue" onclick="updateRenewalRequest(<%= request.id %>, 'approved', this)">APPROVE</button>
                <button class="btn btn-red" onclick="updateRenewalRequest(<%= request.id %>, 'rejected', this)">REJECT</button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div class="panel">
      <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th onclick="sortTable(0)">Book</th>
            <th onclick="sortTable(1)">Borrower</th>
            <th onclick="sortTable(2)">Checked Out</th>
            <th onclick="sortTable(3)">Due Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="loanTable">
          <% loans.forEach(l => { %>
          <% const now = new Date(); %>
          <% const due = new Date(l.dueDate); %>
          <% const overdue = !l.returned && due < now; %>
          <% const daysOverdue = overdue ? Math.floor((now.getTime() - due.getTime()) / 86400000) : 0; %>
          <tr class="loan-row" data-status="<%= l.returned ? 'returned' : (overdue ? 'overdue' : 'active') %>" data-search="<%= (l.title || '').toLowerCase() %> <%= (l.userName || '').toLowerCase() %>">
            <td style="font-weight:700;"><%= l.title %></td>
            <td>
              <div><%= l.userName %></div>
              <div style="font-size:0.65rem;color:#64748b;"><%= l.userEmail %></div>
            </td>
            <td><%= new Date(l.checkedOut).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
            <td><%= due.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
            <td>
              <% if (l.returned) { %>
                <span class="badge badge-returned">RETURNED</span>
              <% } else if (overdue) { %>
                <span class="badge badge-overdue">OVERDUE</span>
                <span class="overdue-days"><%= daysOverdue %> day<%= daysOverdue > 1 ? 's' : '' %></span>
              <% } else { %>
                <span class="badge badge-active">ACTIVE</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      </div>
    </div>

    <!-- Equipment Loans — hidden until equipment tab is clicked -->
    <div class="panel" id="equipment-loans-panel" style="display:none;">
      <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th onclick="sortEquipTable(0)">Item</th>
            <th onclick="sortEquipTable(1)">Borrower</th>
            <th onclick="sortEquipTable(2)">Barcode</th>
            <th onclick="sortEquipTable(3)">Checked Out</th>
            <th onclick="sortEquipTable(4)">Due Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="equipLoanTable">
          <% equipmentLoans.forEach(l => { %>
          <% const now = new Date(); %>
          <% const due = new Date(l.dueDate); %>
          <% const overdue = !l.returned && due < now; %>
          <% const daysOverdue = overdue ? Math.floor((now.getTime() - due.getTime()) / 86400000) : 0; %>
          <tr class="equip-loan-row"
              data-status="<%= l.returned ? 'returned' : (overdue ? 'overdue' : 'active') %>"
              data-search="<%= (l.name || '').toLowerCase() %> <%= (l.userName || '').toLowerCase() %>">
            <td style="font-weight:700;">
              <%= l.name %>
              <div style="font-size:0.65rem;color:#64748b;"><%= l.category || 'Equipment' %></div>
            </td>
            <td>
              <div><%= l.userName %></div>
              <div style="font-size:0.65rem;color:#64748b;"><%= l.userEmail %></div>
            </td>
            <td style="font-family:monospace;color:#93c5fd;"><%= l.barcode %></td>
            <td><%= new Date(l.checkedOut).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
            <td><%= due.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %></td>
            <td>
              <% if (l.returned) { %>
                <span class="badge badge-returned">RETURNED</span>
              <% } else if (overdue) { %>
                <span class="badge badge-overdue">OVERDUE</span>
                <span class="overdue-days"><%= daysOverdue %> day<%= daysOverdue > 1 ? 's' : '' %></span>
              <% } else { %>
                <span class="badge badge-active">ACTIVE</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
          <% if (!equipmentLoans.length) { %>
          <tr><td colspan="6" style="text-align:center;color:#64748b;padding:2rem;">No equipment loans yet</td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>

  </main>
</div>

<script src="/js/admin-mobile.js"></script>
<script>
  let activeTab = 'books';

  function switchTab(tab) {
    activeTab = tab;
    document.getElementById('tab-books').classList.toggle('active', tab === 'books');
    document.getElementById('tab-equipment').classList.toggle('active', tab === 'equipment');

    const bookPanel    = document.querySelector('#loanTable')?.closest('.panel');
    const equipPanel   = document.getElementById('equipment-loans-panel');
    const renewalPanel = document.querySelector('.request-grid, .request-card')?.closest('.panel');

    if (bookPanel)    bookPanel.style.display    = tab === 'books'     ? '' : 'none';
    if (equipPanel)   equipPanel.style.display   = tab === 'equipment' ? '' : 'none';
    if (renewalPanel) renewalPanel.style.display = tab === 'books'     ? '' : 'none';

    // Reset filter buttons to ALL
    document.querySelectorAll('[id^="filter-"]').forEach(b => b.classList.remove('active'));
    document.getElementById('filter-all').classList.add('active');
    const rowClass = tab === 'equipment' ? '.equip-loan-row' : '.loan-row';
    document.querySelectorAll(rowClass).forEach(r => r.style.display = '');
  }

  function filterLoans(status, e) {
    document.querySelectorAll('[id^="filter-"]').forEach(b => b.classList.remove('active'));
    if (e?.target) e.target.classList.add('active');
    const rowClass = activeTab === 'equipment' ? '.equip-loan-row' : '.loan-row';
    document.querySelectorAll(rowClass).forEach(row => {
      row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
    });
  }

  function searchLoans(q) {
    q = q.toLowerCase();
    const rowClass = activeTab === 'equipment' ? '.equip-loan-row' : '.loan-row';
    document.querySelectorAll(rowClass).forEach(row => {
      row.style.display = row.dataset.search.includes(q) ? '' : 'none';
    });
  }

  let sortDir = 1;
  function sortTable(col) {
    const tbody = document.getElementById('loanTable');
    const rows  = Array.from(tbody.querySelectorAll('.loan-row'));
    rows.sort((a, b) => sortDir * (a.children[col]?.textContent?.trim() || '').localeCompare(b.children[col]?.textContent?.trim() || ''));
    sortDir *= -1;
    rows.forEach(r => tbody.appendChild(r));
  }

  let equipSortDir = 1;
  function sortEquipTable(col) {
    const tbody = document.getElementById('equipLoanTable');
    const rows  = Array.from(tbody.querySelectorAll('.equip-loan-row'));
    rows.sort((a, b) => equipSortDir * (a.children[col]?.textContent?.trim() || '').localeCompare(b.children[col]?.textContent?.trim() || ''));
    equipSortDir *= -1;
    rows.forEach(r => tbody.appendChild(r));
  }

  async function updateRenewalRequest(id, status, btn) {
    try {
      btn.disabled = true;
      const r = await fetch('/admin/loans/renewals/update', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ id, status }),
      });
      const d = await r.json().catch(() => ({}));
      if (!r.ok) { alert(d.error || 'Failed to update extension request.'); btn.disabled = false; return; }
      location.reload();
    } catch { alert('Could not update extension request.'); btn.disabled = false; }
  }
</script>
</body>
</html>
