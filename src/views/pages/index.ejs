<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>

  <!-- Open Graph / Link preview tags -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://cs-library-testserver.com/" />
  <meta property="og:title"       content="CS Library — SCSU Department of Computer Science" />
  <meta property="og:description" content="Browse the CS department's book collection, check out books at the kiosk, and track your loans online." />
  <meta property="og:image"       content="https://cs-library-testserver.com/images/og-preview.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content="CS Library" />

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="CS Library — SCSU Department of Computer Science" />
  <meta name="twitter:description" content="Browse the CS department's book collection, check out books at the kiosk, and track your loans online." />
  <meta name="twitter:image"       content="https://cs-library-testserver.com/images/og-preview.png" />

  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
  <style>
  body.modal-open { overflow: hidden; }
  .book-title-link { cursor: pointer; }

  .idx-modal {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(2,6,23,0.85); backdrop-filter: blur(6px);
    align-items: center; justify-content: center; padding: 1rem;
  }
  .idx-modal.open { display: flex; }
  .idx-modal-card {
    position: relative; background: #0f172a;
    border: 1px solid rgba(255,255,255,0.1); border-radius: 1rem;
    max-width: 680px; width: 100%; max-height: 88vh;
    overflow-y: auto; padding: 1.5rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.7);
  }
  .idx-modal-close {
    position: absolute; top: 1rem; right: 1rem;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    color: #94a3b8; border-radius: 50%; width: 2rem; height: 2rem;
    font-size: 1.1rem; cursor: pointer; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .idx-modal-close:hover { background: rgba(255,255,255,0.12); color: white; }
  .idx-modal-layout { display: flex; gap: 1.25rem; align-items: flex-start; flex-wrap: wrap; }
  .idx-modal-cover {
    width: 100px; height: 148px; object-fit: cover;
    border-radius: 0.5rem; border: 1px solid rgba(71,85,105,0.5);
    flex-shrink: 0;
  }
  .idx-modal-body { flex: 1; min-width: 0; }
  .idx-modal-title { font-size: 1.1rem; font-weight: 800; color: white; margin-bottom: 0.25rem; line-height: 1.3; }
  .idx-modal-author { font-size: 0.85rem; color: #60a5fa; margin-bottom: 0.2rem; }
  .idx-modal-subline { font-size: 0.75rem; color: #64748b; margin-bottom: 0.75rem; }
  .idx-modal-meta {
    display: grid; gap: 0.6rem;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    margin-top: 0.85rem;
  }
  .idx-meta-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.65rem; padding: 0.65rem 0.75rem;
  }
  .idx-meta-label { display: block; font-size: 0.6rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin-bottom: 0.3rem; }
  .idx-meta-value { font-size: 0.78rem; color: #e2e8f0; word-break: break-word; }
  .idx-meta-value.empty { color: #334155; }
  .idx-modal-copy { margin-top: 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .idx-copy-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.65rem; padding: 0.75rem 0.85rem;
  }
  .idx-copy-card h3 { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin-bottom: 0.4rem; }
  .idx-copy-card p { font-size: 0.8rem; color: #cbd5e1; line-height: 1.6; }
  .idx-copy-card p.empty { color: #334155; }
  .idx-modal-cta {
    margin-top: 1rem; padding: 0.75rem 1rem;
    background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);
    border-radius: 0.65rem; font-size: 0.78rem; color: #93c5fd; text-align: center;
  }
  .idx-modal-cta a { color: #60a5fa; font-weight: 700; text-decoration: none; }
  .idx-modal-cta a:hover { text-decoration: underline; }
</style>
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <!-- ── Header ── -->
  <%- include('../partials/header', { pageMode: 'index' }) %>

  <div class="page">

    <!-- ── Logout notice ── -->
    <% if (message) { %>
      <div class="notice-bar">
        <span class="notice">You have been signed out.</span>
      </div>
    <% } %>

    <!-- ── Welcome banner — RYM style ── -->
    <div class="welcome-banner">
      <div class="welcome-text">
        <h1>Welcome to the <span>CS Library</span></h1>
        <p>
          The CS Library is a book collection maintained by the
          Department of Computer Science at Southern Connecticut State University.
          Browse the catalog, check out books at the kiosk, and track your loans online.
          
          We are located in Morril Hall 122.
        </p>
      </div>
    </div>

    <!-- ── Stats bar ── -->
    <div class="stats-bar">
      <div class="stat-item">
        <span class="stat-num"><%= totalBooks %></span>
        <span class="stat-label">Books</span>
      </div>
      <div class="stat-item">
        <span class="stat-num"><%= availableBooks %></span>
        <span class="stat-label">Available</span>
      </div>
      <div class="stat-item">
        <span class="stat-num"><%= checkedOutBooks %></span>
        <span class="stat-label">Checked Out</span>
      </div>
      <div class="stat-item">
        <span class="stat-num"><%= totalEquipmentTypes %></span>
        <span class="stat-label">Equipment Types</span>
      </div>
      <div class="stat-item">
        <span class="stat-num"><%= availableEquipmentUnits %></span>
        <span class="stat-label">Equipment Available</span>
      </div>
    </div>

    <!-- ── Book list ── -->
    <div class="main-layout">
      <div class="section-header">
        <h2>Recently Added</h2>
        <span>Showing latest <%= newestBooks.length %> additions</span>
      </div>

      <div class="book-list">
        <% if (newestBooks && newestBooks.length > 0) { %>
          <% newestBooks.forEach(function(book, i) { %>
            <div class="book-row">
              <span class="book-num"><%= i + 1 %></span>

              <div class="book-cover">
                <img src="<%= book.cover || '' %>"
                     loading="lazy"
                     onerror="this.src='/assets/book-placeholder.svg'"
                     alt="<%= book.title %>" />
              </div>

              <div class="book-info">
                <span class="book-title-link" onclick="openIndexModal('<%= book.isbn %>')"><%= book.title %></span>
                <span class="book-author-link"><%= book.author %></span>
                <div class="book-meta">
                  <% if (book.shelf) { %>
                    <span class="book-shelf"><%= book.shelf %></span>
                    <span>·</span>
                  <% } %>
                  <span class="book-isbn-meta">ISBN <%= book.isbn %></span>
                </div>
              </div>

              <span class="book-status <%= book.status === 'Available' ? 'status-available' : 'status-out' %>">
                <%= book.status %>
              </span>
            </div>
          <% }); %>
        <% } else { %>
          <div class="empty-state">No books in the catalog yet.</div>
        <% } %>
      </div>

      <!-- ── Equipment list ── -->
      <div class="section-header" style="margin-top:2.5rem;">
        <h2>Recently Added Equipment</h2>
        <span>Showing latest <%= newestEquipment.length %> additions</span>
      </div>

      <div class="book-list">
        <% if (newestEquipment && newestEquipment.length > 0) { %>
          <% newestEquipment.forEach(function(item, i) { %>
            <div class="book-row">
              <span class="book-num"><%= i + 1 %></span>
              <div class="book-cover">
                <img src="<%= item.image || '' %>"
                     loading="lazy"
                     onerror="this.src='/assets/book-placeholder.svg'"
                     alt="<%= item.name %>" />
              </div>
              <div class="book-info">
                <span class="book-title-link" onclick="openEquipModal(<%= item.id %>)"><%= item.name %></span>
                <span class="book-author-link"><%= item.category || 'Equipment' %></span>
                <div class="book-meta">
                  <span class="book-isbn-meta"><%= item.loanDurationDays %>-day loan</span>
                </div>
              </div>
              <span class="book-status <%= item.availableUnits > 0 ? 'status-available' : 'status-out' %>">
                <%= item.availableUnits > 0 ? item.availableUnits + ' Available' : 'Unavailable' %>
              </span>
            </div>
          <% }); %>
        <% } else { %>
          <div class="empty-state">No equipment in the catalog yet.</div>
        <% } %>
      </div>

      <!-- CTA for logged-out users -->
      <% if (!user) { %>
        <div class="cta-block">
          <p><strong>Want to borrow books and equipment?</strong> Create a free account to track your loans and request renewals from the kiosk.</p>
          <a href="/auth/register" class="cta-btn">Create Account →</a>
        </div>
      <% } %>

    </div><!-- end main-layout -->
  
  </div>

  <div class="idx-modal" id="idxModal" onclick="maybeCloseIndexModal(event)">
    <div class="idx-modal-card">
      <button class="idx-modal-close" type="button" aria-label="Close" onclick="closeIndexModal()">×</button>
      <div class="idx-modal-layout">
        <img class="idx-modal-cover" id="idxModalCover" src="/assets/book-placeholder.svg" alt="" />
        <div class="idx-modal-body">
          <h2 class="idx-modal-title" id="idxModalTitle"></h2>
          <p class="idx-modal-author" id="idxModalAuthor"></p>
          <p class="idx-modal-subline" id="idxModalSubline"></p>
          <span class="badge" id="idxModalStatus"></span>
        </div>
      </div>
      <div class="idx-modal-meta" id="idxModalMeta"></div>
      <div class="idx-modal-copy" id="idxModalCopy"></div>
      <div class="idx-modal-cta" id="idxModalCta"></div>
    </div>
  </div>

  <!-- Equipment modal -->
  <div class="idx-modal" id="equipModal" onclick="maybeCloseEquipModal(event)">
    <div class="idx-modal-card">
      <button class="idx-modal-close" type="button" aria-label="Close" onclick="closeEquipModal()">×</button>
      <div class="idx-modal-layout">
        <img class="idx-modal-cover" id="equipModalCover" src="/assets/book-placeholder.svg" alt="" />
        <div class="idx-modal-body">
          <h2 class="idx-modal-title"  id="equipModalName"></h2>
          <p class="idx-modal-author"  id="equipModalCategory"></p>
          <p class="idx-modal-subline" id="equipModalSubline"></p>
          <span class="badge"          id="equipModalStatus"></span>
        </div>
      </div>
      <div class="idx-modal-meta" id="equipModalMeta"></div>
      <div class="idx-modal-copy" id="equipModalCopy"></div>
      <div class="idx-modal-cta"  id="equipModalCta"></div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    // ── Index book modal ────────────────────────────────────────────────────────
    const indexBooks = <%- JSON.stringify(newestBooks) %>;

    function esc(s) {
      return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    function dash(v) { return (v && String(v).trim()) ? String(v).trim() : null; }

    function idxMetaCard(label, value) {
      const v = dash(value);
      return `<div class="idx-meta-card">
        <span class="idx-meta-label">${esc(label)}</span>
        <span class="idx-meta-value ${v ? '' : 'empty'}">${esc(v || '—')}</span>
      </div>`;
    }
    function idxCopyCard(label, value) {
      const v = dash(value);
      return `<div class="idx-copy-card">
        <h3>${esc(label)}</h3>
        <p class="${v ? '' : 'empty'}">${esc(v || '—')}</p>
      </div>`;
    }

    function openIndexModal(isbn) {
      const book = indexBooks.find(b => b.isbn === isbn);
      if (!book) return;

      document.getElementById('idxModalCover').src = book.cover || '/assets/book-placeholder.svg';
      document.getElementById('idxModalCover').alt = book.title || '';
      document.getElementById('idxModalTitle').textContent = book.title || 'Untitled';
      document.getElementById('idxModalAuthor').textContent = book.author || 'Unknown author';
      document.getElementById('idxModalSubline').textContent =
        [book.publisher, book.creationDate].filter(Boolean).join(' · ') || '';

      const badge = document.getElementById('idxModalStatus');
      const avail = book.status === 'Available';
      badge.className = `badge ${avail ? 'status-available' : 'status-out'}`;
      badge.textContent = (book.status || 'Unknown').toUpperCase();

      document.getElementById('idxModalMeta').innerHTML = [
        idxMetaCard('ISBN', book.isbn),
        idxMetaCard('Shelf', book.shelf),
        idxMetaCard('Edition', book.edition),
        idxMetaCard('Language', book.language),
        idxMetaCard('Type', book.bookType),
        idxMetaCard('Publisher', book.publisher),
      ].join('');

      document.getElementById('idxModalCopy').innerHTML = [
        book.description   ? idxCopyCard('Description', book.description) : '',
        book.subjects      ? idxCopyCard('Subjects', book.subjects) : '',
        book.series        ? idxCopyCard('Series', book.series) : '',
      ].join('');

      const ctaEl = document.getElementById('idxModalCta');
      <% if (!user) { %>
      ctaEl.innerHTML = 'Want to borrow this book? <a href="/auth/register">Create a free account</a> or <a href="/auth/login">sign in</a> to place a hold.';
      <% } else { %>
      ctaEl.innerHTML = 'Browse the full catalog and manage loans in your <a href="/web-dashboard">dashboard</a>.';
      <% } %>

      document.getElementById('idxModal').classList.add('open');
      document.body.classList.add('modal-open');
    }

    function closeIndexModal() {
      document.getElementById('idxModal').classList.remove('open');
      document.body.classList.remove('modal-open');
    }

    function maybeCloseIndexModal(e) {
      if (e.target.id === 'idxModal') closeIndexModal();
    }
    function toggleMenu() {
      const btn  = document.getElementById('hamburgerBtn');
      const menu = document.getElementById('mobileMenu');
      btn.classList.toggle('open');
      menu.classList.toggle('open');
    }

    // Close menu when a link is tapped
    document.querySelectorAll('.mobile-item').forEach(function(link) {
      link.addEventListener('click', function() {
        document.getElementById('hamburgerBtn').classList.remove('open');
        document.getElementById('mobileMenu').classList.remove('open');
      });
    });

    // ── Equipment modal ──────────────────────────────────────────────────────
    const indexEquipment = <%- JSON.stringify(newestEquipment) %>;

    function openEquipModal(id) {
      const item = indexEquipment.find(e => e.id === id);
      if (!item) return;

      document.getElementById('equipModalCover').src = item.image || '/assets/book-placeholder.svg';
      document.getElementById('equipModalName').textContent     = item.name || 'Unknown';
      document.getElementById('equipModalCategory').textContent = item.category || 'Equipment';
      document.getElementById('equipModalSubline').textContent  =
        item.availableUnits + ' of ' + item.totalUnits + ' unit' + (item.totalUnits !== 1 ? 's' : '') + ' available';

      const badge = document.getElementById('equipModalStatus');
      const avail = item.availableUnits > 0;
      badge.className   = `badge ${avail ? 'status-available' : 'status-out'}`;
      badge.textContent = avail ? 'AVAILABLE' : 'UNAVAILABLE';

      document.getElementById('equipModalMeta').innerHTML = [
        idxMetaCard('Category',    item.category),
        idxMetaCard('Loan Period', item.loanDurationDays ? item.loanDurationDays + ' days' : null),
        idxMetaCard('Total Units', item.totalUnits),
        idxMetaCard('Available',   item.availableUnits),
      ].join('');

      document.getElementById('equipModalCopy').innerHTML =
        item.description ? idxCopyCard('Description', item.description) : '';

      const ctaEl = document.getElementById('equipModalCta');
      <% if (!user) { %>
      ctaEl.innerHTML = 'Want to borrow this item? <a href="/auth/register">Create a free account</a> or <a href="/auth/login">sign in</a>.';
      <% } else { %>
      ctaEl.innerHTML = 'Visit the library kiosk to check out this item, or browse more in your <a href="/web-dashboard?view=equipment">dashboard</a>.';
      <% } %>

      document.getElementById('equipModal').classList.add('open');
      document.body.classList.add('modal-open');
    }

    function closeEquipModal() {
      document.getElementById('equipModal').classList.remove('open');
      document.body.classList.remove('modal-open');
    }

    function maybeCloseEquipModal(e) {
      if (e.target.id === 'equipModal') closeEquipModal();
    }

  </script>
</body>
</html>
