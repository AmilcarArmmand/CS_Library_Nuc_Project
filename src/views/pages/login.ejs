<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <div class="login-outer">

    <!-- Left panel -->
    <div class="left-panel">
      <div class="left-logo">
        <img src="/images/scsu_logo.png" alt="SCSU Logo"
             onerror="this.style.display='none'" />
        <div class="accent-bar"></div>
        <span class="dept-label">Department of Computer Science</span>
      </div>

      <div class="left-titles">
        <p class="title-main">CS Library</p>
        <p class="title-sub">Web Portal.</p>
        <p class="title-desc">Sign-in to access the catalog of CS Books, checkout, return, and more.</p>
      </div>

      <p class="left-footer">© 2026 SCSU Capstone</p>
    </div>

    <!-- Right panel -->
    <div class="right-panel">
      <div class="form-box">
        <a href="/" class="form-top-link">← Back to home</a>
        <h1>Welcome Back</h1>
        <div class="accent-bar-form"></div>
        <p class="subtitle">Sign in to access the CS Library</p>

        <% const microsoftEnabled = Boolean(authProviders?.microsoft); %>
        <% if (microsoftEnabled) { %>
          <div class="auth-tabs">
            <button class="tab-btn active" type="button" onclick="switchTab('email')">Email &amp; Password</button>
            <button class="tab-btn" type="button" onclick="switchTab('outlook')">Outlook</button>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>
        <% if (message) { %>
          <div class="status-msg"><%= message %></div>
        <% } %>

        <!-- Email/password panel -->
        <div class="auth-panel active" id="panel-email">
          <form method="POST" action="/auth/login">
            <div class="field-group">
              <div class="field-label">
                <span class="icon" style="display:flex;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </span>
                <span>Email Address</span>
              </div>
              <input type="email" name="email" placeholder="you@example.com" required autofocus />
            </div>

            <div class="field-group">
              <div class="field-label">
                <span class="icon" style="display:flex;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </span>
                <span>Password</span>
              </div>
              <input type="password" name="password" placeholder="Enter your password" required />
            </div>
            <div class="field-actions">
              <a href="/auth/forgot-password" class="inline-link">Forgot password?</a>
            </div>

            <button type="submit" class="btn-primary">Sign In</button>
          </form>

        <div class="links-row">
          <span>Don't have an account?</span>
          <a href="/auth/register" class="back-link">Create one</a>
        </div>
        </div>

        <!-- Outlook panel -->
        <% if (microsoftEnabled) { %>
          <div class="auth-panel" id="panel-outlook">
            <a href="/auth/outlook" class="btn-outlook">
              <svg viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
                <rect x="11" y="1" width="9" height="9" fill="#7fba00"/>
                <rect x="1" y="11" width="9" height="9" fill="#00a4ef"/>
                <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
              </svg>
              Continue with Outlook
            </a>
            <p style="color:rgba(148,163,184,0.6); font-size:0.72rem; text-align:center;">
              Sign in using your Outlook account. A CS Library account will be created automatically.
            </p>
          </div>
        <% } %>

        <!-- Clock -->
        <div class="clock-row">
          <span class="clock-icon" style="color: #94a3b8; display: flex;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="clock-text" id="clock">--</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Tab switching
    function switchTab(tab) {
      document.querySelectorAll('.tab-btn').forEach((b, i) => {
        b.classList.toggle('active', (i === 0 && tab === 'email') || (i === 1 && tab === 'outlook'));
      });
      document.getElementById('panel-email').classList.toggle('active', tab === 'email');
      const outlookPanel = document.getElementById('panel-outlook');
      if (outlookPanel) {
        outlookPanel.classList.toggle('active', tab === 'outlook');
      }
    }

    // Live clock
    function updateClock() {
      const now = new Date();
      const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      let h = now.getHours(), ampm = 'AM';
      if (h >= 12) { ampm = 'PM'; if (h > 12) h -= 12; }
      if (h === 0) h = 12;
      const m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clock').textContent =
        `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} | ${h}:${m} ${ampm}`;
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Ctrl+A → Admin login
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'a') {
        e.preventDefault();
        window.location.href = '/admin/login';
      }
    });
  </script>
</body>
</html>
