<%
  // ── Parameters ───────────────────────────────────────────────────────────
  // activePage : 'dashboard' | 'books' | 'equipment' | 'loans' | 'users'
  //              | 'reports' | 'donations' | 'suggestions'
  // mobileTitle: string shown in the mobile topbar
  // admin      : req.user — used for name/email in the footer (optional)
  var _page  = (typeof activePage  !== 'undefined') ? activePage  : '';
  var _admin = (typeof admin       !== 'undefined') ? admin       : null;
%>

<nav class="sidebar">
  <div class="sidebar-brand">
    <h1>CS_LIBRARY</h1>
    <span>ADMIN PANEL</span>
  </div>

  <div class="nav-items">

    <a href="/admin" class="nav-item <%= _page === 'dashboard' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7" rx="1"/>
        <rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="3" y="14" width="7" height="7" rx="1"/>
        <rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      Dashboard
    </a>

    <a href="/admin/books" class="nav-item <%= _page === 'books' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
      </svg>
      Books
    </a>

    <a href="/admin/equipment" class="nav-item <%= _page === 'equipment' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="14" rx="2"/>
        <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
        <line x1="12" y1="12" x2="12" y2="16"/>
        <line x1="10" y1="14" x2="14" y2="14"/>
      </svg>
      Equipment
    </a>

    <a href="/admin/loans" class="nav-item <%= _page === 'loans' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <path d="M14 2v6h6"/>
        <path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>
      </svg>
      Loans
    </a>

    <a href="/admin/users" class="nav-item <%= _page === 'users' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
        <path d="M16 3.13a4 4 0 010 7.75"/>
      </svg>
      Users
    </a>

    <a href="/admin/reports" class="nav-item <%= _page === 'reports' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
      </svg>
      Reports
    </a>

    <a href="/admin/donations" class="nav-item <%= _page === 'donations' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="8" width="18" height="4" rx="1"/>
        <path d="M12 8v13"/>
        <path d="M5 12h14v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/>
        <path d="M7.5 8a2.5 2.5 0 1 1 0-5c1.8 0 3.2 2.2 4.5 5"/>
        <path d="M16.5 8a2.5 2.5 0 1 0 0-5c-1.8 0-3.2 2.2-4.5 5"/>
      </svg>
      Donations
    </a>

    <a href="/admin/suggestions" class="nav-item <%= _page === 'suggestions' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
      Suggestions
    </a>

  </div>

  <div class="sidebar-footer">
    <% if (_admin) { %>
    <div class="admin-name"><%= _admin.name %></div>
    <div class="admin-email"><%= _admin.email %></div>
    <% } %>
    <a href="/admin/logout" class="signout-btn">Sign Out</a>
  </div>
</nav>

<!-- Mobile topbar (replaces admin-mobile-shell include) -->
<div class="admin-mobile-topbar">
  <button
    type="button"
    class="admin-mobile-menu-btn"
    aria-label="Open admin navigation"
    onclick="toggleAdminSidebar()"
  >
    <span></span><span></span><span></span>
  </button>
  <div class="admin-mobile-title"><%= mobileTitle %></div>
</div>
<div class="admin-sidebar-backdrop" onclick="closeAdminSidebar()"></div>
