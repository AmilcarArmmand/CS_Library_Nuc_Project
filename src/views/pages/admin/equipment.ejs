<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin-mobile.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Space Grotesk', sans-serif; background: #020617; color: white; min-height: 100vh; }
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%),
        radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%);
    }
    .admin-layout { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    /* Sidebar */
    .sidebar { width: 250px; background: rgba(10,15,28,0.95); border-right: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; padding: 1.5rem 0; flex-shrink: 0; backdrop-filter: blur(20px); position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; }
    .sidebar-brand { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 1rem; }
    .sidebar-brand h1 { font-size: 0.85rem; font-weight: 900; letter-spacing: 0.15em; }
    .sidebar-brand span { font-size: 0.65rem; color: #60a5fa; font-weight: 300; letter-spacing: 0.15em; }
    .nav-items { display: flex; flex-direction: column; gap: 0.15rem; padding: 0 0.75rem; flex: 1; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; border-radius: 0.5rem; text-decoration: none; color: #94a3b8; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; white-space: nowrap; }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
    .nav-item.active { background: rgba(59,130,246,0.15); color: #60a5fa; }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }
    .signout-btn { display: inline-block; padding: 0.35rem 0.75rem; border-radius: 0.35rem; font-size: 0.68rem; font-weight: 700; color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); text-decoration: none; }

    .main { flex: 1; margin-left: 250px; padding: 2rem; }
    .page-title { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
    .page-sub { font-size: 0.82rem; color: #64748b; margin-bottom: 1.5rem; }

    .panel { background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55); border-radius: 1rem; padding: 1.5rem; backdrop-filter: blur(12px); margin-bottom: 1.5rem; box-shadow: 0 22px 40px -28px rgba(2,6,23,0.9); }
    .panel-title { font-size: 0.72rem; letter-spacing: 0.2em; font-weight: 900; text-transform: uppercase; color: #60a5fa; margin-bottom: 1rem; }
    .panel-copy { color: #94a3b8; font-size: 0.8rem; line-height: 1.6; margin-bottom: 1rem; }

    .form-grid { display: grid; gap: 0.85rem; grid-template-columns: repeat(12, minmax(0, 1fr)); }
    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .span-12 { grid-column: span 12; } .span-8 { grid-column: span 8; } .span-6 { grid-column: span 6; }
    .span-4 { grid-column: span 4; } .span-3 { grid-column: span 3; } .span-2 { grid-column: span 2; }
    .form-group label { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
    .form-group input, .form-group select, .form-group textarea {
      padding: 0.65rem 0.85rem; border-radius: 0.65rem; border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05); color: white; font-family: inherit; font-size: 0.82rem; outline: none; transition: border-color 0.2s;
    }
    .form-group textarea { min-height: 5rem; resize: vertical; line-height: 1.5; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: rgba(59,130,246,0.5); }
    .form-group select option { background: #0f172a; }

    .btn-row { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-top: 1rem; }
    .btn { padding: 0.6rem 1.2rem; border-radius: 0.65rem; font-family: inherit; font-size: 0.75rem; font-weight: 800; letter-spacing: 0.06em; cursor: pointer; border: 1px solid; transition: all 0.2s; }
    .btn-blue  { background: rgba(59,130,246,0.2);  color: #60a5fa;  border-color: rgba(59,130,246,0.4); }
    .btn-blue:hover  { background: rgba(59,130,246,0.35); }
    .btn-green { background: rgba(34,197,94,0.15);  color: #4ade80;  border-color: rgba(34,197,94,0.3); }
    .btn-green:hover { background: rgba(34,197,94,0.3); }
    .btn-red   { background: rgba(239,68,68,0.1);   color: #f87171;  border-color: rgba(239,68,68,0.25); }
    .btn-red:hover   { background: rgba(239,68,68,0.25); }
    .btn-slate { background: rgba(148,163,184,0.1); color: #cbd5e1;  border-color: rgba(148,163,184,0.2); }
    .btn-slate:hover { background: rgba(148,163,184,0.2); }
    .btn-amber { background: rgba(245,158,11,0.15); color: #fbbf24;  border-color: rgba(245,158,11,0.3); }
    .btn-amber:hover { background: rgba(245,158,11,0.28); }
    .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.64rem; }

    .search-bar { margin-bottom: 1rem; }
    .search-bar input { width: 100%; max-width: 430px; padding: 0.65rem 1rem; border-radius: 9999px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); color: white; font-family: inherit; font-size: 0.82rem; outline: none; }
    .search-bar input:focus { border-color: rgba(59,130,246,0.5); }

    .badge { display: inline-block; padding: 0.25rem 0.6rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; }
    .badge-avail { background: rgba(34,197,94,0.15);   color: #4ade80; }
    .badge-out   { background: rgba(239,68,68,0.15);   color: #f87171; }
    .badge-maint { background: rgba(148,163,184,0.15); color: #94a3b8; }

    /* Main equipment table */
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid rgba(71,85,105,0.4); }
    td { font-size: 0.78rem; padding: 0.7rem 0.75rem; border-bottom: 1px solid rgba(71,85,105,0.2); color: #cbd5e1; vertical-align: middle; }
    .eq-row:hover td { background: rgba(255,255,255,0.02); cursor: pointer; }
    .eq-row.is-open td { background: rgba(255,255,255,0.03); }
    .eq-name-cell { display: flex; gap: 0.75rem; align-items: flex-start; }
    .eq-thumb { width: 42px; height: 42px; border-radius: 0.4rem; object-fit: cover; border: 1px solid rgba(71,85,105,0.4); background: rgba(15,23,42,0.6); flex-shrink: 0; }
    .eq-name-copy strong { font-size: 0.84rem; color: white; display: block; }
    .eq-name-copy span   { font-size: 0.68rem; color: #64748b; }
    .action-group { display: flex; gap: 0.4rem; flex-wrap: wrap; }

    /* Expanded units section */
    .eq-units-row { display: none; }
    .eq-units-row.open { display: table-row; }
    .eq-units-row td { padding: 0; border-bottom: 1px solid rgba(71,85,105,0.3); }
    .eq-units-card { padding: 1rem 1.25rem 1.25rem; background: linear-gradient(180deg, rgba(15,23,42,0.7), rgba(15,23,42,0.45)); border-top: 1px solid rgba(255,255,255,0.06); }
    .units-section-title { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #475569; margin-bottom: 0.75rem; }

    /* Barcode groups sub-table */
    .barcode-table { width: 100%; border-collapse: collapse; margin-bottom: 1.25rem; }
    .barcode-table th { font-size: 0.6rem; color: #475569; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; padding: 0.5rem 0.6rem; text-align: left; border-bottom: 1px solid rgba(71,85,105,0.3); }
    .barcode-table td { font-size: 0.75rem; padding: 0.6rem 0.6rem; border-bottom: 1px solid rgba(71,85,105,0.15); color: #cbd5e1; vertical-align: top; }
    .barcode-table tr:last-child td { border-bottom: none; }
    .barcode-cell { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.78rem; color: #93c5fd; font-weight: 700; }
    .qty-chip { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.2rem 0.5rem; border-radius: 9999px; font-size: 0.68rem; font-weight: 700; background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.25); color: #93c5fd; }

    /* Loans under a barcode group */
    .loan-sub-row { background: rgba(239,68,68,0.04); }
    .loan-sub-row td { padding: 0.4rem 0.6rem 0.4rem 1.5rem; border-bottom: 1px solid rgba(71,85,105,0.1); }
    .loan-info { font-size: 0.7rem; line-height: 1.5; }
    .loan-info strong { color: white; }
    .loan-info span   { color: #64748b; }
    .loan-overdue { color: #f87171; font-weight: 700; font-size: 0.65rem; }

    /* Barcode group inline edit */
    .barcode-edit-row { display: none; }
    .barcode-edit-row.open { display: table-row; }
    .barcode-edit-row td { padding: 0.65rem 0.6rem; background: rgba(59,130,246,0.05); border-bottom: 1px solid rgba(71,85,105,0.2); }
    .barcode-edit-grid { display: grid; gap: 0.6rem; grid-template-columns: 1fr 2fr auto; align-items: end; }
    .barcode-edit-grid .form-group label { font-size: 0.58rem; }
    .barcode-edit-grid .form-group input, .barcode-edit-grid .form-group select { padding: 0.45rem 0.6rem; font-size: 0.75rem; }

    /* Add unit form */
    .add-unit-form { display: grid; gap: 0.65rem; grid-template-columns: 2fr 1fr 1fr 1fr 2fr auto; align-items: end; padding: 0.85rem; border-radius: 0.75rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); }
    .add-unit-form .form-group label { font-size: 0.58rem; }
    .add-unit-form .form-group input, .add-unit-form .form-group select { padding: 0.5rem 0.65rem; font-size: 0.76rem; }

    /* Toast */
    .toast-wrap { position: fixed; top: 1.25rem; right: 1.25rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }
    .toast { padding: 0.65rem 1rem; border-radius: 0.65rem; font-size: 0.78rem; font-weight: 600; border: 1px solid; animation: dropDown 0.25s ease; }
    .toast.positive { background: rgba(34,197,94,0.15);  color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .toast.negative { background: rgba(239,68,68,0.15);  color: #f87171; border-color: rgba(239,68,68,0.3); }
    .toast.warning  { background: rgba(245,158,11,0.15); color: #fbbf24; border-color: rgba(245,158,11,0.3); }
    @keyframes dropDown { from { opacity: 0; transform: translateY(-14px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main { margin-left: 0; }
      .add-unit-form { grid-template-columns: 1fr 1fr; }
      .barcode-edit-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="admin-layout">

  <!-- Sidebar -->
  <%- include('./partials/sidebar', { activePage: 'equipment', mobileTitle: 'Equipment', admin: admin }) %>
  <div class="toast-wrap" id="toastWrap"></div>

  <main class="main">
    <h1 class="page-title">Equipment Management</h1>
    <p class="page-sub">Add loanable equipment types, then register physical units with barcodes. Multiple units can share the same barcode — useful when identical items don't have individual labels.</p>

    <!-- ── Add / Edit Equipment Type ── -->
    <div class="panel">
      <div class="panel-title" id="formTitle">Add Equipment Type</div>
      <p class="panel-copy">Define the equipment type first (e.g. "Blue Yeti Microphone"). Then expand its row below to register physical units and their barcodes.</p>
      <div class="form-grid">
        <input type="hidden" id="editingId" value="" />
        <div class="form-group span-6">
          <label>Name</label>
          <input type="text" id="nameInput" placeholder="e.g. Blue Yeti Microphone" />
        </div>
        <div class="form-group span-3">
          <label>Category</label>
          <input type="text" id="categoryInput" placeholder="e.g. Audio, Computing…" />
        </div>
        <div class="form-group span-3">
          <label>Loan Duration (days)</label>
          <input type="number" id="loanDaysInput" value="7" min="1" max="365" />
        </div>
        <div class="form-group span-8">
          <label>Image URL</label>
          <input type="text" id="imageInput" placeholder="https://… (optional)" />
        </div>
        <div class="form-group span-12">
          <label>Description</label>
          <textarea id="descriptionInput" placeholder="Brief description and any borrowing notes…"></textarea>
        </div>
      </div>
      <div class="btn-row">
        <button class="btn btn-green" id="addBtn"    onclick="submitEquipment()">ADD EQUIPMENT</button>
        <button class="btn btn-blue"  id="saveBtn"   onclick="submitEquipment()" style="display:none;">SAVE CHANGES</button>
        <button class="btn btn-slate" id="cancelBtn" onclick="cancelEdit()"      style="display:none;">CANCEL</button>
      </div>
    </div>

    <!-- ── Equipment Catalog ── -->
    <div class="panel">
      <div class="panel-title">Equipment Catalog (<%= equipmentList.length %> types)</div>
      <p class="panel-copy">Click any row to expand and manage its barcode groups. Each barcode can represent multiple identical units — the kiosk will check out any available unit with that barcode.</p>
      <div class="search-bar">
        <input type="text" placeholder="Search by name or category…" oninput="filterEquipment(this.value)" />
      </div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Equipment</th>
              <th>Category</th>
              <th>Total Units</th>
              <th>Available</th>
              <th>On Loan</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="equipmentTable">
            <% if (equipmentList.length === 0) { %>
              <tr><td colspan="6" style="color:#334155;text-align:center;padding:2rem;">No equipment added yet.</td></tr>
            <% } %>
            <% equipmentList.forEach(function(item) { %>

              <!-- Equipment type row -->
              <tr class="eq-row" id="eq-row-<%= item.id %>"
                  data-id="<%= item.id %>"
                  data-name="<%= item.name.toLowerCase() %>"
                  data-category="<%= (item.category || '').toLowerCase() %>"
                  onclick="toggleUnits(<%= item.id %>)">
                <td>
                  <div class="eq-name-cell">
                    <% if (item.image) { %>
                      <img class="eq-thumb" src="<%= item.image %>" alt="" onerror="this.style.display='none'" />
                    <% } %>
                    <div class="eq-name-copy">
                      <strong><%= item.name %></strong>
                      <span>Loan period: <%= item.loanDurationDays %> day<%= item.loanDurationDays !== 1 ? 's' : '' %></span>
                    </div>
                  </div>
                </td>
                <td><%= item.category || '—' %></td>
                <td><%= item.totalUnits %></td>
                <td>
                  <span class="badge <%= item.availableUnits > 0 ? 'badge-avail' : 'badge-out' %>">
                    <%= item.availableUnits %>
                  </span>
                </td>
                <td>
                  <% if (item.activeLoans > 0) { %>
                    <span class="badge badge-out"><%= item.activeLoans %></span>
                  <% } else { %>
                    <span style="color:#334155;">0</span>
                  <% } %>
                </td>
                <td onclick="event.stopPropagation()">
                  <div class="action-group">
                    <button class="btn btn-blue btn-sm" onclick="startEdit(<%= JSON.stringify(item).replace(/</g,'\\u003c') %>)">EDIT</button>
                    <button class="btn btn-red  btn-sm" onclick="deleteEquipment(<%= item.id %>, '<%= item.name.replace(/'/g, "\\'") %>')">DELETE</button>
                  </div>
                </td>
              </tr>

              <!-- Expanded barcode groups row -->
              <tr class="eq-units-row" id="eq-units-<%= item.id %>">
                <td colspan="6">
                  <div class="eq-units-card">

                    <div class="units-section-title">Barcode Groups</div>
                    <% if (item.barcodeGroups.length === 0) { %>
                      <p style="font-size:0.78rem;color:#334155;margin-bottom:1rem;">No units registered yet. Add one below.</p>
                    <% } else { %>
                    <table class="barcode-table" id="barcode-table-<%= item.id %>">
                      <thead>
                        <tr>
                          <th>Barcode</th>
                          <th>Qty</th>
                          <th>Available</th>
                          <th>On Loan</th>
                          <th>Condition</th>
                          <th>Notes</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% item.barcodeGroups.forEach(function(group) { %>

                          <!-- Barcode group row -->
                          <tr id="barcode-row-<%= item.id %>-<%= group.barcode %>">
                            <td class="barcode-cell"><%= group.barcode %></td>
                            <td>
                              <span class="qty-chip"><%= group.totalCount %> unit<%= group.totalCount !== 1 ? 's' : '' %></span>
                            </td>
                            <td>
                              <span class="badge <%= group.availableCount > 0 ? 'badge-avail' : 'badge-out' %>">
                                <%= group.availableCount %>
                              </span>
                            </td>
                            <td>
                              <% if (group.onLoanCount > 0) { %>
                                <span class="badge badge-out"><%= group.onLoanCount %></span>
                              <% } else { %>
                                <span style="color:#334155;">0</span>
                              <% } %>
                            </td>
                            <td>
                              <span class="badge <%=
                                group.condition === 'Good' ? 'badge-avail' :
                                group.condition === 'Fair' ? '' : 'badge-out'
                              %>" style="<%= group.condition === 'Fair' ? 'background:rgba(245,158,11,0.15);color:#fbbf24;' : '' %>">
                                <%= group.condition %>
                              </span>
                            </td>
                            <td style="color:#64748b;font-size:0.7rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                              <%= group.notes || '—' %>
                            </td>
                            <td onclick="event.stopPropagation()">
                              <div class="action-group">
                                <button class="btn btn-blue btn-sm"
                                  onclick="showBarcodeEdit(<%= item.id %>, '<%= group.barcode %>', '<%= group.condition %>', `<%= group.notes.replace(/`/g,'\\`') %>`)">
                                  EDIT
                                </button>
                                <button class="btn btn-slate btn-sm"
                                  onclick="addOneUnit(<%= item.id %>, '<%= group.barcode %>')"
                                  title="Add one more unit with this barcode">
                                  +1
                                </button>
                                <% if (group.availableCount > 0) { %>
                                  <button class="btn btn-amber btn-sm"
                                    onclick="removeOneUnit(<%= item.id %>, '<%= group.barcode %>')"
                                    title="Remove one available unit">
                                    −1
                                  </button>
                                <% } %>
                                <button class="btn btn-red btn-sm"
                                  onclick="removeBarcodeGroup(<%= item.id %>, '<%= group.barcode %>', <%= group.totalCount %>)"
                                  title="Remove all units with this barcode">
                                  REMOVE ALL
                                </button>
                              </div>
                            </td>
                          </tr>

                          <!-- Inline edit row for the barcode group -->
                          <tr class="barcode-edit-row" id="barcode-edit-<%= item.id %>-<%= group.barcode %>">
                            <td colspan="7">
                              <div class="barcode-edit-grid">
                                <div class="form-group">
                                  <label>Condition (all units)</label>
                                  <select id="edit-cond-<%= item.id %>-<%= group.barcode %>">
                                    <option value="Good">Good</option>
                                    <option value="Fair">Fair</option>
                                    <option value="Poor">Poor</option>
                                  </select>
                                </div>
                                <div class="form-group">
                                  <label>Notes (all units)</label>
                                  <input type="text" id="edit-notes-<%= item.id %>-<%= group.barcode %>" placeholder="Optional notes…" />
                                </div>
                                <div class="btn-row" style="margin-top:0;">
                                  <button class="btn btn-green btn-sm" onclick="saveBarcodeEdit(<%= item.id %>, '<%= group.barcode %>')">SAVE</button>
                                  <button class="btn btn-slate btn-sm" onclick="hideBarcodeEdit(<%= item.id %>, '<%= group.barcode %>')">CANCEL</button>
                                </div>
                              </div>
                            </td>
                          </tr>

                          <!-- Active loan sub-rows -->
                          <% group.activeLoans.forEach(function(loan) { %>
                            <tr class="loan-sub-row">
                              <td colspan="6">
                                <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                                  <div class="loan-info">
                                    <strong><%= loan.userName %></strong>
                                    <span> · Due: <%=
                                      new Date(loan.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
                                    %></span>
                                    <% if (new Date(loan.dueDate) < new Date()) { %>
                                      <span class="loan-overdue"> — OVERDUE</span>
                                    <% } %>
                                    <% if (loan.studentId) { %><span style="color:#475569;font-size:0.65rem;"> · ID: <%= loan.studentId %></span><% } %>
                                  </div>
                                  <button class="btn btn-amber btn-sm" onclick="returnLoan(<%= loan.id %>)">RETURN</button>
                                </div>
                              </td>
                            </tr>
                          <% }); %>

                        <% }); %>
                      </tbody>
                    </table>
                    <% } %>

                    <!-- Add unit / barcode group form -->
                    <div class="units-section-title" style="margin-top:1rem;">Register New Barcode</div>
                    <div class="add-unit-form">
                      <div class="form-group">
                        <label>Barcode</label>
                        <input type="text" id="new-barcode-<%= item.id %>" placeholder="e.g. MIC-001 or 123455" style="text-transform:uppercase;" />
                      </div>
                      <div class="form-group">
                        <label>Quantity</label>
                        <input type="number" id="new-qty-<%= item.id %>" value="1" min="1" max="50" title="How many units share this barcode" />
                      </div>
                      <div class="form-group">
                        <label>Condition</label>
                        <select id="new-condition-<%= item.id %>">
                          <option value="Good">Good</option>
                          <option value="Fair">Fair</option>
                          <option value="Poor">Poor</option>
                        </select>
                      </div>
                      <div class="form-group" style="grid-column: span 2;">
                        <label>Notes (optional)</label>
                        <input type="text" id="new-notes-<%= item.id %>" placeholder="Any notes about these units…" />
                      </div>
                      <div style="padding-bottom:0.1rem;">
                        <button class="btn btn-green btn-sm" onclick="addUnit(<%= item.id %>)">+ ADD</button>
                      </div>
                    </div>

                  </div>
                </td>
              </tr>

            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script src="/js/admin-mobile.js"></script>
<script>
  // ── Helpers ────────────────────────────────────────────────────────────────
  function toast(msg, type = 'positive') {
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.textContent = msg;
    document.getElementById('toastWrap').appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }

  async function api(path, body) {
    const r = await fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    return { ok: r.ok, status: r.status, data: d };
  }

  // ── Row expand / collapse ──────────────────────────────────────────────────
  function toggleUnits(id) {
    const unitsRow   = document.getElementById(`eq-units-${id}`);
    const summaryRow = document.getElementById(`eq-row-${id}`);
    const isOpen     = unitsRow.classList.contains('open');
    document.querySelectorAll('.eq-units-row.open').forEach(r => r.classList.remove('open'));
    document.querySelectorAll('.eq-row.is-open').forEach(r => r.classList.remove('is-open'));
    if (!isOpen) {
      unitsRow.classList.add('open');
      summaryRow.classList.add('is-open');
    }
  }

  // ── Equipment type CRUD ────────────────────────────────────────────────────
  let isEditing = false;

  function startEdit(item) {
    isEditing = true;
    document.getElementById('editingId').value        = item.id;
    document.getElementById('nameInput').value        = item.name;
    document.getElementById('categoryInput').value    = item.category || '';
    document.getElementById('loanDaysInput').value    = item.loanDurationDays;
    document.getElementById('imageInput').value       = item.image || '';
    document.getElementById('descriptionInput').value = item.description || '';
    document.getElementById('formTitle').textContent   = 'Edit Equipment Type';
    document.getElementById('addBtn').style.display    = 'none';
    document.getElementById('saveBtn').style.display   = '';
    document.getElementById('cancelBtn').style.display = '';
    document.getElementById('nameInput').scrollIntoView({ behavior: 'smooth', block: 'center' });
    document.getElementById('nameInput').focus();
  }

  function cancelEdit() {
    isEditing = false;
    document.getElementById('editingId').value        = '';
    document.getElementById('nameInput').value        = '';
    document.getElementById('categoryInput').value    = '';
    document.getElementById('loanDaysInput').value    = '7';
    document.getElementById('imageInput').value       = '';
    document.getElementById('descriptionInput').value = '';
    document.getElementById('formTitle').textContent   = 'Add Equipment Type';
    document.getElementById('addBtn').style.display    = '';
    document.getElementById('saveBtn').style.display   = 'none';
    document.getElementById('cancelBtn').style.display = 'none';
  }

  async function submitEquipment() {
    const name             = document.getElementById('nameInput').value.trim();
    const category         = document.getElementById('categoryInput').value.trim();
    const loanDurationDays = parseInt(document.getElementById('loanDaysInput').value, 10) || 7;
    const image            = document.getElementById('imageInput').value.trim();
    const description      = document.getElementById('descriptionInput').value.trim();
    if (!name) { toast('Name is required.', 'negative'); return; }
    const path = isEditing ? '/admin/equipment/edit' : '/admin/equipment/add';
    const body = { name, category, loanDurationDays, image, description };
    if (isEditing) body.id = parseInt(document.getElementById('editingId').value, 10);
    const { ok, data } = await api(path, body);
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast(isEditing ? 'Equipment updated.' : 'Equipment added.', 'positive');
    setTimeout(() => location.reload(), 600);
  }

  async function deleteEquipment(id, name) {
    if (!confirm(`Delete "${name}" and all its units? This cannot be undone.`)) return;
    const { ok, data } = await api('/admin/equipment/delete', { id });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast('Equipment deleted.', 'positive');
    setTimeout(() => location.reload(), 600);
  }

  // ── Barcode group actions ──────────────────────────────────────────────────
  async function addUnit(equipmentId) {
    const barcode   = document.getElementById(`new-barcode-${equipmentId}`).value.trim().toUpperCase();
    const quantity  = parseInt(document.getElementById(`new-qty-${equipmentId}`).value, 10) || 1;
    const condition = document.getElementById(`new-condition-${equipmentId}`).value;
    const notes     = document.getElementById(`new-notes-${equipmentId}`).value.trim();
    if (!barcode) { toast('Barcode is required.', 'negative'); return; }
    const { ok, data } = await api('/admin/equipment/units/add', { equipmentId, barcode, quantity, condition, notes });
    if (!ok) { toast(data.error ?? 'Failed to add units.', 'negative'); return; }
    toast(`${data.count} unit${data.count !== 1 ? 's' : ''} registered under barcode ${barcode}.`, 'positive');
    setTimeout(() => location.reload(), 600);
  }

  async function addOneUnit(equipmentId, barcode) {
    const { ok, data } = await api('/admin/equipment/units/add', { equipmentId, barcode, quantity: 1 });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast(`+1 unit added to barcode ${barcode}.`, 'positive');
    setTimeout(() => location.reload(), 600);
  }

  async function removeOneUnit(equipmentId, barcode) {
    if (!confirm(`Remove one available unit from barcode "${barcode}"?`)) return;
    const { ok, data } = await api('/admin/equipment/units/remove-one', { equipmentId, barcode });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast(`One unit removed from barcode ${barcode}.`, 'positive');
    setTimeout(() => location.reload(), 600);
  }

  async function removeBarcodeGroup(equipmentId, barcode, total) {
    if (!confirm(`Remove all ${total} unit${total !== 1 ? 's' : ''} with barcode "${barcode}"? This cannot be undone.`)) return;
    const { ok, data } = await api('/admin/equipment/units/remove-barcode', { equipmentId, barcode });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast(`Barcode ${barcode} removed (${data.removed} unit${data.removed !== 1 ? 's' : ''}).`, 'positive');
    setTimeout(() => location.reload(), 600);
  }

  function showBarcodeEdit(equipmentId, barcode, condition, notes) {
    document.querySelectorAll('.barcode-edit-row.open').forEach(r => r.classList.remove('open'));
    const editRow = document.getElementById(`barcode-edit-${equipmentId}-${barcode}`);
    document.getElementById(`edit-cond-${equipmentId}-${barcode}`).value  = condition;
    document.getElementById(`edit-notes-${equipmentId}-${barcode}`).value = notes;
    editRow.classList.add('open');
  }

  function hideBarcodeEdit(equipmentId, barcode) {
    document.getElementById(`barcode-edit-${equipmentId}-${barcode}`).classList.remove('open');
  }

  async function saveBarcodeEdit(equipmentId, barcode) {
    const condition = document.getElementById(`edit-cond-${equipmentId}-${barcode}`).value;
    const notes     = document.getElementById(`edit-notes-${equipmentId}-${barcode}`).value.trim();
    const { ok, data } = await api('/admin/equipment/units/edit', { equipmentId, barcode, condition, notes });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast('Barcode group updated.', 'positive');
    setTimeout(() => location.reload(), 600);
  }

  async function returnLoan(loanId) {
    if (!confirm('Mark this equipment as returned?')) return;
    const { ok, data } = await api('/admin/equipment/loans/return', { loanId });
    if (!ok) { toast(data.error ?? 'Failed.', 'negative'); return; }
    toast('Equipment returned successfully.', 'positive');
    setTimeout(() => location.reload(), 600);
  }

  // ── Search ─────────────────────────────────────────────────────────────────
  function filterEquipment(query) {
    const q = query.toLowerCase().trim();
    document.querySelectorAll('#equipmentTable tr.eq-row').forEach(row => {
      const matches = !q || row.dataset.name.includes(q) || row.dataset.category.includes(q);
      const id = row.dataset.id;
      row.style.display = matches ? '' : 'none';
      const unitsRow = document.getElementById(`eq-units-${id}`);
      if (unitsRow) unitsRow.style.display = matches ? '' : 'none';
    });
  }
</script>
</body>
</html>
