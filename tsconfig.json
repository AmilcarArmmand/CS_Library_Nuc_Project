{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "es2020",
    "moduleResolution": "nodenext",

    // Remove the empty "types": [] — it was blocking ALL @types/* packages.
    // TypeScript will now automatically pick up @types/passport, @types/express, etc.
    // "types": [],

    // Other Outputs
    // "sourceMap": true,
    // "declaration": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,

    // Disabled — caused the fetch body: undefined error and other false positives
    // "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Required by verbatimModuleSyntax — type-only imports must use "import type"
    "verbatimModuleSyntax": true,

    // Other recommended options
    "strict": true,
    "allowJs": true,
    "noImplicitAny": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}