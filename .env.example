# Application Configuration
NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080/

# Deployment toggles
# Leave these false while temporarily exposing the app directly on HTTP.
# Once Nginx/TLS is in front, set both to true.
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false

# Google OAuth Configuration
# Get these from https://console.cloud.google.com
# Authorized redirect URI to add locally: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Microsoft (Outlook) OAuth Configuration
# Get these from https://portal.azure.com/
# Callback: http://localhost:8080/auth/outlook/callback
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_CALLBACK_URL=http://localhost:8080/auth/outlook/callback
MICROSOFT_TENANT_ID=common

# Session Configuration
# Use any long random string. Just like with the kiosk .env
# run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_super_secret_session_key_here

# Email Configuration
# The current mailer is built for a local Postfix/sendmail setup.
# On the server, /usr/sbin/sendmail should work if Postfix is configured.
EMAIL_FROM=library-noreply@example.edu
EMAIL_FROM_NAME=CS Library
EMAIL_SENDMAIL_PATH=/usr/sbin/sendmail
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
DUE_REMINDER_DAYS=2

# Reserved for future SMTP-based delivery if needed.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=smtp_user@example.edu
EMAIL_PASS=your_app_password

# DB Configuration
# Set these values for your local PostgreSQL instance or the deployment database.
# drizzle.config.ts reads the POSTGRES_* variables directly.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_database_password_here

# Kiosk API Configuration
# This is a shared secret between this server and the Raspberry Pi kiosk app.
# The key MUST match CLOUD_API_KEY in kiosk/.env
# To generate a key...
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_API_KEY=your_kiosk_api_key_here
