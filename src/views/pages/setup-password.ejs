<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <div class="login-outer">

    <!-- ── LEFT PANEL ── -->
    <div class="left-panel">
      <div class="left-logo">
        <img src="/images/scsu_logo.png" alt="SCSU"
             onerror="this.style.display='none'" />
        <div class="accent-bar"></div>
        <span class="dept-label">Department of Computer Science</span>
      </div>

      <div class="left-titles">
        <p class="title-main">CS Library</p>
        <p class="title-sub">Web Portal.</p>
        <p class="title-desc">Set a backup password so you can sign in without Microsoft if needed.</p>
      </div>

      <p class="left-footer">© 2026 SCSU Capstone</p>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="right-panel">
      <div class="form-box">

        <h1>One More Thing</h1>
        <div class="accent-bar-form"></div>
        <p class="subtitle">
          Welcome, <%= user.name.split(' ')[0] %>! Would you like to set a backup password?
          This lets you sign in with email and password if Microsoft is unavailable.
        </p>

        <% if (error) { %>
          <div class="error-msg server"><%= error %></div>
        <% } %>

        <!-- Set password form -->
        <form method="POST" action="/auth/setup-password" id="setupForm">

          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <span>Password</span>
            </div>
            <input type="password" name="password"
                   placeholder="Choose a password"
                   autocomplete="new-password"
                   autofocus />
          </div>

          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <span>Confirm Password</span>
            </div>
            <input type="password" name="confirm"
                   placeholder="Repeat your password"
                   autocomplete="new-password" />
          </div>

          <!-- Client-side error -->
          <p class="error-msg" id="clientError"></p>

          <button type="submit" name="action" value="set" class="btn-primary">
            Set Password
          </button>
        </form>

        <!-- Skip form — separate so it bypasses the set form's validation -->
        <form method="POST" action="/auth/setup-password" style="margin-top:0.75rem;">
          <button type="submit" name="action" value="skip" style="
            width: 100%; padding: 0.875rem;
            border-radius: 9999px;
            font-family: inherit; font-size: 0.875rem; font-weight: 600;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.1);
            color: #475569; cursor: pointer;
            transition: all 0.2s;
          "
          onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#64748b'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='#475569'">
            Skip for now
          </button>
        </form>

        <p style="font-size:0.72rem;color:#334155;text-align:center;margin-top:1rem;">
          You can set a password anytime in your account settings.
        </p>

        <div class="clock-row" style="margin-top:1.5rem;">
          <span style="color:#94a3b8; display:flex;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="clock-text" id="clock">--</span>
        </div>

      </div>
    </div>
  </div>

  <script>
    // Client-side validation — only runs when submitting the set password form
    document.getElementById('setupForm').addEventListener('submit', function(e) {
      const password = this.password.value;
      const confirm  = this.confirm.value;
      const err      = document.getElementById('clientError');

      err.textContent = '';

      if (!password) {
        e.preventDefault();
        err.textContent = 'Please enter a password.';
        return;
      }
      if (password.length < 8) {
        e.preventDefault();
        err.textContent = 'Password must be at least 8 characters.';
        return;
      }
      if (password !== confirm) {
        e.preventDefault();
        err.textContent = 'Passwords do not match.';
        return;
      }
    });

    // Live clock
    function updateClock() {
      const now    = new Date();
      const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      let h = now.getHours(), ampm = 'AM';
      if (h >= 12) { ampm = 'PM'; if (h > 12) h -= 12; }
      if (h === 0) h = 12;
      const m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clock').textContent =
        `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} | ${h}:${m} ${ampm}`;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>
