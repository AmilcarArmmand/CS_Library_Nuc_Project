<%- include('../partials/header') %>

<div class="row">
    <div class="col-lg-6 mx-auto text-center mt-5">

        <img src="/images/scsu_logo.png" alt="SCSU Logo"
             style="height:60px; object-fit:contain; margin-bottom:1.5rem;"
             onerror="this.style.display='none'" />

        <h1 class="display-5 fw-bold mb-2">CS Library</h1>
        <p class="text-muted mb-5">Southern Connecticut State University — Department of Computer Science</p>

        <% if (message) { %>
            <div class="alert alert-success mb-4"><%= message %></div>
        <% } %>

        <div class="d-grid gap-3 mb-5">

            <a href="/auth/login" class="btn btn-primary btn-lg py-3">
                <span style="font-size:1.3rem;">🌐</span>
                <strong>Web Login</strong>
                <div class="small opacity-75 mt-1">Email &amp; Password or Google — for students and staff</div>
            </a>

            <a href="/kiosk" class="btn btn-outline-secondary btn-lg py-3">
                <span style="font-size:1.3rem;">🪪</span>
                <strong>Kiosk Login</strong>
                <div class="small opacity-75 mt-1">Student ID scan — for the library kiosk terminal</div>
            </a>

        </div>

        <p class="text-muted small">
            Don't have an account?
            <a href="/auth/register">Create one here</a>
        </p>

    </div>
</div>

<%- include('../partials/footer') %>
