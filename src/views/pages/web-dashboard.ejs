<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <!-- Header -->
  <%- include('../partials/header', { pageMode: 'dashboard' }) %>

  <!-- Toasts -->
  <div class="toast-wrap" id="toastWrap"></div>

  <main class="page-wrap">

    <!-- CATALOG WORKSPACE -->
    <div class="workspace active" id="ws-catalog">
      <div class="catalog-header">
        <h1 class="catalog-title">Library Catalog</h1>
        <div class="catalog-meta">
          <span class="catalog-count" id="catalogCount">Loading…</span>
          <span class="catalog-page"  id="catalogPage"></span>
        </div>
      </div>

      <!-- Search -->
      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search by title, author, or ISBN…"
               oninput="handleSearch(this.value)" />
      </div>

      <div class="filter-row">
        <button class="filter-btn active" data-filter="all"         onclick="setFilter('all')">ALL</button>
        <button class="filter-btn"        data-filter="available"   onclick="setFilter('available')">AVAILABLE</button>
        <button class="filter-btn"        data-filter="checked_out" onclick="setFilter('checked_out')">CHECKED OUT</button>
        <button class="filter-btn"        data-filter="on_hold"     onclick="setFilter('on_hold')">ON HOLD</button>
      </div>

      <div class="catalog-grid" id="catalogGrid"></div>
      <div class="pagination"   id="pagination"></div>
    </div>

    <!-- MY BOOKS WORKSPACE -->
    <div class="workspace" id="ws-mybooks">
      <div class="mybooks-panel panel">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <p class="panel-title">MY CHECKED OUT BOOKS</p>
          <button class="refresh-btn" onclick="loadMyBooks(true)" id="refreshBtn">
            ↻ Refresh
          </button>
        </div>

        <!-- Summary cards -->
        <div class="loans-summary">
          <div class="summary-card total">
            <span class="summary-num" id="totalOut">—</span>
            <span class="summary-label">Books Out</span>
          </div>
          <div class="summary-card overdue">
            <span class="summary-num" id="totalOverdue">—</span>
            <span class="summary-label">Overdue</span>
          </div>
        </div>

        <!-- Active loans -->
        <p class="section-title">Currently Checked Out</p>
        <div id="activeLoans"></div>
        <div class="empty-state" id="noActiveLoans" style="display:none;">
          <img src="/assets/ph-book-open-text.svg" alt="" />
          <p>No books currently checked out</p>
          <span>Books you borrow from the kiosk will appear here</span>
        </div>

        <div class="divider"></div>

        <!-- History -->
        <p class="section-title">Borrowing History</p>
        <div id="loanHistory"></div>
        <div class="empty-state" id="noHistory" style="display:none;">
          <img src="/assets/ph-clock-counter-clockwise.svg" alt="" />
          <p>No borrowing history yet</p>
        </div>
      </div>

      <!-- Equipment loans panel -->
      <div class="mybooks-panel panel" style="margin-top:1.5rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <p class="panel-title">MY CHECKED OUT EQUIPMENT</p>
          <button class="refresh-btn" onclick="loadMyEquipmentLoans(true)" id="refreshEquipBtn">
            ↻ Refresh
          </button>
        </div>

        <!-- Summary cards -->
        <div class="loans-summary">
          <div class="summary-card total">
            <span class="summary-num" id="totalEquipOut">—</span>
            <span class="summary-label">Items Out</span>
          </div>
          <div class="summary-card overdue">
            <span class="summary-num" id="totalEquipOverdue">—</span>
            <span class="summary-label">Overdue</span>
          </div>
        </div>

        <!-- Active equipment loans -->
        <p class="section-title">Currently Checked Out</p>
        <div id="activeEquipmentLoans"></div>
        <div class="empty-state" id="noEquipmentLoans" style="display:none;">
          <img src="/assets/ph-book-open-text.svg" alt="" />
          <p>No equipment currently checked out</p>
          <span>Equipment borrowed from the kiosk will appear here</span>
        </div>
      </div>

    </div>

    <!-- SUGGEST -->
    <div class="workspace" id="ws-suggest">
      <div class="panel suggest-panel" style="max-width:500px;margin:0 auto;padding:2rem;">
        <p class="section-title" style="margin-bottom:1.25rem;">Suggest a Book</p>
        <p style="color:#94a3b8;font-size:0.78rem;margin-bottom:1.25rem;">Can’t find a book you need? Let us know and the library team will review your suggestion.</p>
        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <input type="text" id="suggestTitle" placeholder="Book title *" style="width:100%;padding:0.6rem 1rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.85rem;outline:none;" />
          <input type="text" id="suggestAuthor" placeholder="Author (optional)" style="width:100%;padding:0.6rem 1rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.85rem;outline:none;" />
          <textarea id="suggestReason" placeholder="Why do you want this book? (optional)" rows="3" style="width:100%;padding:0.6rem 1rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.85rem;outline:none;resize:vertical;"></textarea>
          <button onclick="submitSuggestion()" style="padding:0.65rem;border-radius:0.5rem;background:rgba(59,130,246,0.2);color:#60a5fa;border:1px solid rgba(59,130,246,0.4);font-family:inherit;font-size:0.82rem;font-weight:700;letter-spacing:0.08em;cursor:pointer;transition:all 0.2s;">SUBMIT SUGGESTION</button>
        </div>
      </div>
    </div>

    <!-- ── EQUIPMENT CATALOG WORKSPACE ── -->
    <div class="workspace" id="ws-equipment">
      <div class="catalog-header">
        <h1 class="catalog-title">Equipment Catalog</h1>
        <div class="catalog-meta">
          <span class="catalog-count" id="equipCatalogCount">Loading…</span>
        </div>
      </div>

      <div class="search-bar">
        <input type="text" id="equipSearchInput"
              placeholder="Search by name or category…"
              oninput="filterEquipmentCatalog(this.value)" />
      </div>

      <div class="filter-row">
        <button class="filter-btn active" data-efilter="all"       onclick="setEquipFilter('all')">ALL</button>
        <button class="filter-btn"        data-efilter="available" onclick="setEquipFilter('available')">AVAILABLE</button>
        <button class="filter-btn"        data-efilter="out"       onclick="setEquipFilter('out')">UNAVAILABLE</button>
      </div>

      <div class="catalog-grid" id="equipCatalogGrid"></div>
    </div>

  </main>

  <div class="book-modal" id="bookModal" onclick="maybeCloseBookModal(event)">
    <div class="book-modal-card">
      <button class="book-modal-close" type="button" aria-label="Close book details" onclick="closeBookModal()">×</button>
      <div class="book-modal-content">
        <div class="book-modal-layout">
          <div>
            <img class="book-modal-cover" id="bookModalCover" src="/assets/book-placeholder.svg" alt="" />
          </div>
          <div>
            <div class="book-modal-head">
              <h2 class="book-modal-title" id="bookModalTitle">Book details</h2>
              <p class="book-modal-author" id="bookModalAuthor"></p>
              <p class="book-modal-subline" id="bookModalSubline"></p>
            </div>
            <div class="book-modal-actions">
              <span class="badge" id="bookModalStatus"></span>
              <div class="book-modal-hold" id="bookModalHold"></div>
            </div>
            <div class="book-modal-meta" id="bookModalMeta"></div>
            <div class="book-modal-copy" id="bookModalCopy"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating nav -->
  <%- include('../partials/footer') %>

  <script>
    // ── State ──────────────────────────────────────────────────────────────────
    let allBooks      = [];
    let filtered      = [];
    let currentFilter = 'all';
    let currentPage   = 1;
    const PER_PAGE    = 20;
    let searchQuery   = '';
    let searchTimer   = null;
    let currentUserId = null;
    let activeDetailIsbn = null;

    // ── Toast ──────────────────────────────────────────────────────────────────
    function toast(msg, type = 'positive') {
      const el = document.createElement('div');
      el.className = `toast ${type}`;
      el.textContent = msg;
      document.getElementById('toastWrap').appendChild(el);
      setTimeout(() => el.remove(), 4500);
    }

    // ── Nav ────────────────────────────────────────────────────────────────────
    function showView(view) {
      document.querySelectorAll('.workspace').forEach(w => w.classList.remove('active'));
      document.getElementById(`ws-${view}`).classList.add('active');

      // Update desktop header nav
      document.querySelectorAll('.hdr-nav-btn').forEach(b => b.classList.remove('active'));
      const hb = document.getElementById(`nav-${view}`);
      if (hb) hb.classList.add('active');

      // Update mobile nav
      document.querySelectorAll('.mobile-item[id^="mnav-"]').forEach(b => b.classList.remove('active'));
      const mb = document.getElementById(`mnav-${view}`);
      if (mb) mb.classList.add('active');

      if (view === 'mybooks')  loadMyBooks(false);
      if (view === 'equipment') loadEquipmentCatalog();
    }

    // ── Search ──────────────────────────────────────────────────────────────────
    function toggleSearch() {
      const inp = document.getElementById('searchInput');
      inp.classList.toggle('open');
      if (inp.classList.contains('open')) { showView('catalog'); inp.focus(); }
      else { searchQuery = ''; inp.value = ''; applyFilters(); }
    }
    function handleSearch(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        searchQuery = val.toLowerCase().trim();
        currentPage = 1; applyFilters();
      }, 250);
    }

    // ── Catalog ────────────────────────────────────────────────────────────────
    async function loadCatalog() {
      try {
        const r = await fetch('/web-dashboard/api/catalog');
        const d = await r.json();
        allBooks = d.books ?? [];
        currentUserId = d.currentUserId ?? null;
        applyFilters();
      } catch { toast('Could not load catalog.', 'negative'); }
    }

    // ── Mobile menu ─────────────────────────────────────────────────────────────
    function toggleMobileMenu() {
      document.getElementById('hamburgerBtn').classList.toggle('open');
      document.getElementById('mobileMenu').classList.toggle('open');
    }
    function closeMobileMenu() {
      document.getElementById('hamburgerBtn').classList.remove('open');
      document.getElementById('mobileMenu').classList.remove('open');
    }

    function setFilter(f) {
      currentFilter = f; currentPage = 1;
      document.querySelectorAll('.filter-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.filter === f));
      applyFilters();
    }

    function applyFilters() {
      let b = allBooks;
      if (searchQuery)
        b = b.filter(x =>
          x.title.toLowerCase().includes(searchQuery)  ||
          x.author.toLowerCase().includes(searchQuery) ||
          (x.isbn || '').toLowerCase().includes(searchQuery) ||
          (x.publisher || '').toLowerCase().includes(searchQuery) ||
          (x.subjects || '').toLowerCase().includes(searchQuery) ||
          (x.description || '').toLowerCase().includes(searchQuery) ||
          (x.identifier || '').toLowerCase().includes(searchQuery));
      if (currentFilter === 'available')   b = b.filter(x => x.status === 'Available');
      if (currentFilter === 'checked_out') b = b.filter(x => x.status === 'Checked Out');
      if (currentFilter === 'on_hold')
        b = b.filter(x => x.status === 'On Hold' || x.heldByCurrentUser);
      filtered = b;
      const tp = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (currentPage > tp) currentPage = tp;
      renderCatalog(); renderPagination(tp);
    }

    function getHoldState(b, isBorrower) {
      if (isBorrower) {
        return { label: 'YOU HAVE THIS BOOK', className: 'hold-state-note muted' };
      }
      if (b.heldByCurrentUser && b.status === 'On Hold') {
        return { label: 'READY FOR PICKUP', className: 'hold-state-note ready' };
      }
      if (b.heldByCurrentUser) {
        return { label: 'YOUR HOLD IS ACTIVE', className: 'hold-state-note active' };
      }
      return null;
    }

    function getBookByIsbn(isbn) {
      return allBooks.find(book => book.isbn === isbn) || null;
    }

    function valueOrDash(value) {
      return String(value ?? '').trim() || '—';
    }

    function renderMetaCard(label, value) {
      return `
        <div class="book-meta-card">
          <span class="book-meta-label">${esc(label)}</span>
          <span class="book-meta-value ${value ? '' : 'empty'}">${esc(valueOrDash(value))}</span>
        </div>`;
    }

    function renderCopyCard(label, value, full = false) {
      return `
        <div class="book-copy-card ${full ? 'full' : ''}">
          <h3>${esc(label)}</h3>
          <p class="${value ? '' : 'empty'}">${esc(valueOrDash(value))}</p>
        </div>`;
    }

    function renderBookModal(book) {
      const cover = book.cover || '/assets/book-placeholder.svg';
      const statusBadge = document.getElementById('bookModalStatus');
      const modalHold = document.getElementById('bookModalHold');
      const isBorrower = book.borrowerUserId && book.borrowerUserId === currentUserId;
      const holdState = getHoldState(book, isBorrower);
      const badgeClass = book.status === 'On Hold'
        ? 'badge-hold'
        : (book.status === 'Available' ? 'badge-avail' : 'badge-out');

      document.getElementById('bookModalCover').src = cover;
      document.getElementById('bookModalCover').alt = book.title || 'Book cover';
      document.getElementById('bookModalTitle').textContent = book.title || 'Untitled book';
      document.getElementById('bookModalAuthor').textContent = book.author || 'Unknown creator';
      document.getElementById('bookModalSubline').textContent = [
        book.publisher,
        book.creationDate,
        book.source,
      ].filter(Boolean).join(' · ') || 'No additional publishing data yet';

      statusBadge.className = `badge ${badgeClass}`;
      statusBadge.textContent = (book.status || 'Unknown').toUpperCase();

      if (book.status !== 'Available' && !isBorrower && !holdState) {
        modalHold.innerHTML = `<button class="book-modal-hold-btn" type="button" onclick="placeHoldFromModal('${esc(book.isbn)}')">PLACE HOLD</button>`;
      } else if (holdState) {
        modalHold.innerHTML = `<span class="${holdState.className}">${holdState.label}</span>`;
      } else {
        modalHold.innerHTML = '';
      }

      document.getElementById('bookModalMeta').innerHTML = [
        renderMetaCard('ISBN', book.isbn),
        renderMetaCard('Shelf', book.shelf),
        renderMetaCard('Edition', book.edition),
        renderMetaCard('Language', book.language),
        renderMetaCard('Type', book.bookType),
        renderMetaCard('Identifier', book.identifier),
        renderMetaCard('MMS ID', book.mmsId),
        renderMetaCard('NZ MMS ID', book.nzMmsId),
      ].join('');

      document.getElementById('bookModalCopy').innerHTML = [
        renderCopyCard('Description', book.description, true),
        renderCopyCard('Physical Description', book.physicalDescription),
        renderCopyCard('Subjects', book.subjects),
        renderCopyCard('Contents', book.contents),
        renderCopyCard('Series', book.series),
      ].join('');
    }

    function openBookModal(isbn) {
      const book = getBookByIsbn(isbn);
      if (!book) return;
      activeDetailIsbn = isbn;
      renderBookModal(book);
      document.getElementById('bookModal').classList.add('open');
      document.body.classList.add('modal-open');
    }

    function closeBookModal() {
      document.getElementById('bookModal').classList.remove('open');
      document.body.classList.remove('modal-open');
      activeDetailIsbn = null;
    }

    function maybeCloseBookModal(event) {
      if (event.target.id === 'bookModal') closeBookModal();
    }

    async function placeHoldFromModal(isbn) {
      await placeHold(isbn);
      const refreshed = getBookByIsbn(isbn);
      if (refreshed) renderBookModal(refreshed);
    }

    function renderCatalog() {
      const grid  = document.getElementById('catalogGrid');
      const start = (currentPage - 1) * PER_PAGE;
      const page  = filtered.slice(start, start + PER_PAGE);
      const tp    = Math.max(1, Math.ceil(filtered.length / PER_PAGE));

      document.getElementById('catalogCount').textContent =
        `Showing ${page.length} of ${filtered.length} book${filtered.length !== 1 ? 's' : ''}`;
      document.getElementById('catalogPage').textContent =
        filtered.length > PER_PAGE ? `Page ${currentPage} of ${tp}` : '';

      grid.innerHTML = page.map((b, i) => {
        const avail = b.status === 'Available';
        const isOnHold = b.status === 'On Hold';
        const isBorrower = b.borrowerUserId && b.borrowerUserId === currentUserId;
        const holdState = getHoldState(b, isBorrower);
        const statusLabel = b.status === 'On Hold' ? 'ON HOLD' : (avail ? 'AVAILABLE' : 'CHECKED OUT');
        let holdBtn = '';
        if (!avail && !isBorrower && !holdState) {
          holdBtn = `<button class="catalog-add-btn" onclick="event.stopPropagation(); placeHold('${esc(b.isbn)}')" style="margin-top:0.4rem;padding:0.3rem 0.75rem;border-radius:0.35rem;font-family:inherit;font-size:0.62rem;font-weight:700;letter-spacing:0.08em;cursor:pointer;border:1px solid rgba(168,85,247,0.3);background:rgba(168,85,247,0.15);color:#c084fc;transition:all 0.2s;">PLACE HOLD</button>`;
        } else if (!avail && holdState) {
          holdBtn = `<span class="${holdState.className}">${holdState.label}</span>`;
        }
        return `
          <div class="book-card ${avail ? '' : 'checked-out'} ${b.heldByCurrentUser ? 'held-for-user' : ''}"
               onclick="openBookModal('${esc(b.isbn)}')"
               role="button"
               tabindex="0"
               style="animation-delay:${Math.min(i * 0.04, 0.24)}s">
            <img src="${esc(b.cover || '/assets/book-placeholder.svg')}" loading="lazy"
                 onerror="this.src='/assets/book-placeholder.svg'"
                 alt="${esc(b.title)}" />
            <div class="book-overlay">
              <p class="book-title">${esc(b.title)}</p>
              <p class="book-author">${esc(b.author)}</p>
              <p class="book-isbn">ISBN ${esc(b.isbn || '')}</p>
              <span class="badge ${isOnHold ? 'badge-hold' : (avail ? 'badge-avail' : 'badge-out')}">
                ${statusLabel}
              </span>
              ${holdBtn}
              <p class="book-card-hint">Tap for details</p>
            </div>
          </div>`;
      }).join('');
    }

    function renderPagination(tp) {
      const pg = document.getElementById('pagination');
      if (tp <= 1) { pg.innerHTML = ''; return; }
      let pages = [];
      if (tp <= 7) { pages = Array.from({ length: tp }, (_, i) => i + 1); }
      else {
        pages = [1];
        if (currentPage > 3) pages.push('…');
        for (let p = Math.max(2, currentPage - 1); p <= Math.min(tp - 1, currentPage + 1); p++)
          if (!pages.includes(p)) pages.push(p);
        if (currentPage < tp - 2) pages.push('…');
        if (!pages.includes(tp)) pages.push(tp);
      }
      pg.innerHTML =
        `<button class="page-btn" ${currentPage <= 1 ? 'disabled' : ''} onclick="goPage(${currentPage - 1})">‹</button>` +
        pages.map(p => p === '…'
          ? `<span class="page-dots">···</span>`
          : `<button class="page-btn ${p === currentPage ? 'active' : ''}" onclick="goPage(${p})">${p}</button>`
        ).join('') +
        `<button class="page-btn" ${currentPage >= tp ? 'disabled' : ''} onclick="goPage(${currentPage + 1})">›</button>`;
    }

    function goPage(p) {
      currentPage = Math.max(1, p);
      renderCatalog();
      renderPagination(Math.ceil(filtered.length / PER_PAGE));
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── My Books ───────────────────────────────────────────────────────────────
    async function loadMyBooks(showSpinner = false) {
      const btn = document.getElementById('refreshBtn');
      if (showSpinner && btn) btn.classList.add('spinning');

      try {
        const r    = await fetch('/web-dashboard/api/my-loans');
        const d    = await r.json();
        const loanList = d.loans ?? [];
        const active  = loanList.filter(l => !l.returned);
        const history = loanList.filter(l =>  l.returned);

        // Summary
        const now     = new Date();
        const overdue = active.filter(l => new Date(l.dueDate) < now);
        document.getElementById('totalOut').textContent    = String(active.length);
        document.getElementById('totalOverdue').textContent = String(overdue.length);

        // Active loans
        document.getElementById('noActiveLoans').style.display = active.length ? 'none' : 'flex';
        document.getElementById('activeLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const diffMs  = due - now;
          const diffDay = Math.ceil(diffMs / 86400000);
          const renewalStatus = loan.renewalRequestStatus || '';
          let badgeClass, dueClass, dueLabel;
          if (diffMs < 0) {
            badgeClass = 'overdue'; dueClass = 'due-overdue';
            dueLabel   = `Overdue by ${Math.abs(diffDay)} day${Math.abs(diffDay) !== 1 ? 's' : ''}`;
          } else if (diffDay <= 3) {
            badgeClass = 'soon'; dueClass = 'due-soon';
            dueLabel   = diffDay === 0 ? 'Due today!' : `Due in ${diffDay} day${diffDay !== 1 ? 's' : ''}`;
          } else {
            badgeClass = 'ok'; dueClass = 'due-ok';
            dueLabel   = `Due ${due.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
          }
          const fullDue = due.toLocaleDateString('en-US', { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric' });
          let extensionUi = '';
          if (renewalStatus === 'pending') {
            extensionUi = `
              <div class="loan-status-stack">
                <span class="due-badge pending">REQUEST PENDING</span>
                <p class="loan-extension-note">Library staff is reviewing this request.</p>
              </div>`;
          } else if (renewalStatus === 'approved') {
            extensionUi = `
              <div class="loan-status-stack">
                <span class="due-badge approved">EXTENSION APPROVED</span>
                <p class="loan-extension-note">The due date above has been updated.</p>
              </div>`;
          } else if (renewalStatus === 'rejected') {
            extensionUi = `
              <div class="loan-status-stack">
                <span class="due-badge rejected">REQUEST DECLINED</span>
                <p class="loan-extension-note">This loan was not approved for an extension.</p>
              </div>`;
          } else if (diffMs >= 0) {
            extensionUi = `<button class="loan-extension-btn" onclick="requestExtension(${loan.id}, this)">REQUEST EXTENSION</button>`;
          }
          return `
            <div class="loan-row">
              <img src="${esc(loan.cover || '')}"
                   onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
                <p class="loan-isbn">ISBN ${esc(loan.isbn || '')}</p>
              </div>
              <div class="loan-actions">
                <div class="loan-status-stack">
                  <span class="due-badge ${badgeClass}">${dueLabel}</span>
                  <p class="loan-due ${dueClass}" style="font-size:0.65rem;margin-top:0.2rem;">${fullDue}</p>
                </div>
                ${extensionUi}
              </div>
            </div>`;
        }).join('');

        // History
        document.getElementById('noHistory').style.display = history.length ? 'none' : 'flex';
        document.getElementById('loanHistory').innerHTML = history.map(loan => {
          const ret = loan.returnedDate
            ? new Date(loan.returnedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
            : 'N/A';
          return `
            <div class="loan-row history">
              <img src="${esc(loan.cover || '')}"
                   onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
              </div>
              <div class="loan-due">
                <span class="due-badge" style="background:rgba(71,85,105,0.2);color:#475569;border-color:rgba(71,85,105,0.3);">RETURNED</span>
                <p class="loan-due due-returned" style="font-size:0.65rem;margin-top:0.2rem;">${ret}</p>
              </div>
            </div>`;
        }).join('');

        await loadMyEquipmentLoans(false);
        if (showSpinner) toast('Loans refreshed.', 'positive');
      } catch {
        toast('Could not load loans.', 'negative');
      } finally {
        if (btn) btn.classList.remove('spinning');
      }
    }

    // ── Equipment loans ────────────────────────────────────────────────────────
    async function loadMyEquipmentLoans(showSpinner = false) {
      const btn = document.getElementById('refreshEquipBtn');
      if (showSpinner && btn) btn.classList.add('spinning');

      try {
        const r = await fetch('/web-dashboard/api/my-equipment-loans');
        const d = await r.json();
        const now    = new Date();
        const active = (d.loans ?? []).filter(l => !l.returned);
        const overdue = active.filter(l => new Date(l.dueDate) < now);

        document.getElementById('totalEquipOut').textContent    = String(active.length);
        document.getElementById('totalEquipOverdue').textContent = String(overdue.length);
        document.getElementById('noEquipmentLoans').style.display = active.length ? 'none' : 'flex';

        document.getElementById('activeEquipmentLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const diffMs  = due - now;
          const diffDay = Math.ceil(diffMs / 86400000);
          let badgeClass, dueClass, dueLabel;
          if (diffMs < 0) {
            badgeClass = 'overdue'; dueClass = 'due-overdue';
            dueLabel   = `Overdue by ${Math.abs(diffDay)} day${Math.abs(diffDay) !== 1 ? 's' : ''}`;
          } else if (diffDay <= 3) {
            badgeClass = 'soon'; dueClass = 'due-soon';
            dueLabel   = diffDay === 0 ? 'Due today!' : `Due in ${diffDay} day${diffDay !== 1 ? 's' : ''}`;
          } else {
            badgeClass = 'ok'; dueClass = 'due-ok';
            dueLabel   = `Due ${due.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
          }
          const fullDue = due.toLocaleDateString('en-US', { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric' });
          return `
            <div class="loan-row">
              <img src="${esc(loan.image || '')}"
                  onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.name)}</p>
                <p class="loan-author">${esc(loan.category || 'Equipment')}</p>
                <p class="loan-isbn" style="font-family:ui-monospace,monospace;">${esc(loan.barcode)}</p>
              </div>
              <div class="loan-actions">
                <div class="loan-status-stack">
                  <span class="due-badge ${badgeClass}">${dueLabel}</span>
                  <p class="loan-due ${dueClass}" style="font-size:0.65rem;margin-top:0.2rem;">${fullDue}</p>
                </div>
                <p style="font-size:0.65rem;color:#475569;margin-top:0.35rem;">Return at the kiosk</p>
              </div>
            </div>`;
        }).join('');

        if (showSpinner) toast('Equipment loans refreshed.', 'positive');
      } catch {
        toast('Could not load equipment loans.', 'negative');
      } finally {
        if (btn) btn.classList.remove('spinning');
      }
    }

    // ── Holds ───────────────────────────────────────────────────────────────────
    async function placeHold(isbn) {
      try {
        const r = await fetch('/web-dashboard/api/hold', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not place hold.', r.status === 409 ? 'warning' : 'negative'); return; }
        allBooks = allBooks.map(book =>
          book.isbn === isbn ? { ...book, heldByCurrentUser: true } : book
        );
        applyFilters();
        if (activeDetailIsbn === isbn) {
          const refreshed = getBookByIsbn(isbn);
          if (refreshed) renderBookModal(refreshed);
        }
        toast('Hold placed! You\u2019ll be notified when available.', 'positive');
      } catch { toast('Server error.', 'negative'); }
    }

    // ── Suggestions ─────────────────────────────────────────────────────────────
    async function submitSuggestion() {
      const title  = document.getElementById('suggestTitle').value.trim();
      const author = document.getElementById('suggestAuthor').value.trim();
      const reason = document.getElementById('suggestReason').value.trim();
      if (!title) { toast('Book title is required.', 'negative'); return; }
      try {
        const r = await fetch('/web-dashboard/api/suggest', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ title, author, reason }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not submit.', 'negative'); return; }
        toast('Suggestion submitted! Thank you.', 'positive');
        document.getElementById('suggestTitle').value = '';
        document.getElementById('suggestAuthor').value = '';
        document.getElementById('suggestReason').value = '';
      } catch { toast('Server error.', 'negative'); }
    }

    // ── Equipment catalog ──────────────────────────────────────────────────────
    let allEquipment    = [];
    let filteredEquip   = [];
    let currentEFilter  = 'all';

    async function loadEquipmentCatalog() {
      try {
        const r = await fetch('/web-dashboard/api/equipment-catalog');
        const d = await r.json();
        allEquipment = d.equipment ?? [];
        applyEquipFilters();
      } catch { toast('Could not load equipment catalog.', 'negative'); }
    }

    function setEquipFilter(f) {
      currentEFilter = f;
      document.querySelectorAll('[data-efilter]').forEach(b =>
        b.classList.toggle('active', b.dataset.efilter === f));
      applyEquipFilters();
    }

    function filterEquipmentCatalog(query) {
      applyEquipFilters(query);
    }

    function applyEquipFilters(query) {
      const q = (query ?? document.getElementById('equipSearchInput').value).toLowerCase().trim();
      let items = allEquipment;
      if (q) items = items.filter(e =>
        e.name.toLowerCase().includes(q) ||
        (e.category || '').toLowerCase().includes(q));
      if (currentEFilter === 'available') items = items.filter(e => e.availableUnits > 0);
      if (currentEFilter === 'out')       items = items.filter(e => e.availableUnits === 0);
      filteredEquip = items;
      renderEquipmentCatalog();
    }

    function renderEquipmentCatalog() {
      const grid = document.getElementById('equipCatalogGrid');
      document.getElementById('equipCatalogCount').textContent =
        `Showing ${filteredEquip.length} item${filteredEquip.length !== 1 ? 's' : ''}`;

      if (!filteredEquip.length) {
        grid.innerHTML = `<p style="color:#334155;font-size:0.82rem;grid-column:1/-1;padding:2rem 0;">No equipment found.</p>`;
        return;
      }

      grid.innerHTML = filteredEquip.map((item, i) => {
        const avail = item.availableUnits > 0;
        return `
          <div class="book-card ${avail ? '' : 'checked-out'}" style="animation-delay:${Math.min(i * 0.04, 0.24)}s">
            <img src="${esc(item.image || '')}"
                onerror="this.src='/assets/book-placeholder.svg'"
                alt="${esc(item.name)}" />
            <div class="book-overlay">
              <p class="book-title">${esc(item.name)}</p>
              <p class="book-author">${esc(item.category || 'Equipment')}</p>
              <p class="book-isbn">${item.loanDurationDays}-day loan period</p>
              <span class="badge ${avail ? 'badge-avail' : 'badge-out'}">
                ${avail ? item.availableUnits + ' AVAILABLE' : 'UNAVAILABLE'}
              </span>
              ${item.description
                ? `<p style="font-size:0.65rem;color:#94a3b8;margin-top:0.5rem;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${esc(item.description)}</p>`
                : ''}
              <p style="font-size:0.62rem;color:#475569;margin-top:0.5rem;">Visit the kiosk to borrow</p>
            </div>
          </div>`;
      }).join('');
    }

    async function requestExtension(loanId, btn) {
      if (btn) btn.disabled = true;
      try {
        const r = await fetch('/web-dashboard/api/renewal-request', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ loanId }),
        });
        const d = await r.json();
        if (!r.ok) {
          toast(d.error ?? 'Could not submit extension request.', r.status === 409 ? 'warning' : 'negative');
          if (btn) btn.disabled = false;
          return;
        }
        toast('Extension request submitted. We will email you with the decision.', 'positive');
        await loadMyBooks(false);
      } catch {
        toast('Server error.', 'negative');
        if (btn) btn.disabled = false;
      }
    }

    // ── Helper ──────────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s ?? '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
    }

    // ── Boot ────────────────────────────────────────────────────────────────────
    // Read ?view= query param so header nav links from index.ejs navigate correctly
    const urlParams = new URLSearchParams(window.location.search);
    const startView = urlParams.get('view');
    if (startView && ['catalog', 'mybooks', 'suggest', 'equipment'].includes(startView)) {
      showView(startView);
    } else {
      showView('catalog');
    }
    loadCatalog();
  </script>
</body>
</html>
