<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <%- include('../partials/header', { pageMode: 'index' }) %>

  <div class="page">
    <div style="
      max-width: 560px; margin: 0 auto;
      padding: 3rem 1.5rem 4rem;
      position: relative; z-index: 1;
    ">

      <!-- Page title -->
      <div style="margin-bottom: 2rem;">
        <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#3b82f6;margin-bottom:0.4rem;">Account</p>
        <h1 style="font-size:1.75rem;font-weight:900;letter-spacing:-0.02em;">Settings</h1>
      </div>

      <!-- ── Account Info card ── -->
      <div class="panel" style="padding:1.5rem;margin-bottom:1rem;">
        <p style="font-size:0.68rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#475569;margin-bottom:1.25rem;">Account Information</p>

        <div style="display:flex;flex-direction:column;gap:0.85rem;">

          <!-- Name — read only -->
          <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
            <div>
              <p style="font-size:0.72rem;font-weight:600;color:#64748b;margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.08em;">Name</p>
              <p style="font-size:0.9rem;font-weight:600;color:white;"><%= user.name %></p>
            </div>
          </div>

          <!-- Email — read only -->
          <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
            <div>
              <p style="font-size:0.72rem;font-weight:600;color:#64748b;margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.08em;">Email Address</p>
              <p style="font-size:0.9rem;font-weight:600;color:white;"><%= user.email %></p>
            </div>
          </div>

          <!-- Student ID — read only -->
          <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
            <div>
              <p style="font-size:0.72rem;font-weight:600;color:#64748b;margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.08em;">Student ID</p>
              <% if (user.studentId) { %>
                <p style="font-size:0.9rem;font-weight:600;color:white;font-variant-numeric:tabular-nums;"><%= user.studentId %></p>
              <% } else { %>
                <p style="font-size:0.85rem;color:#475569;font-style:italic;">Not linked yet</p>
              <% } %>
            </div>
          </div>

          <!-- Account Created — read only -->
          <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
            <div>
              <p style="font-size:0.72rem;font-weight:600;color:#64748b;margin-bottom:0.2rem;text-transform:uppercase;letter-spacing:0.08em;">Account Created</p>
              <% if (user.createdAt) { %>
                <p style="font-size:0.9rem;font-weight:600;color:white;"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' }) %></p>
              <% } else { %>
                <p style="font-size:0.85rem;color:#475569;font-style:italic;">Not linked yet</p>
              <% } %>
            </div>
          </div>

          <!-- Sign-in method -->
          <div style="padding:0.75rem 0;">
            <p style="font-size:0.72rem;font-weight:600;color:#64748b;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.08em;">Sign-in Methods</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
              <% if (user.microsoftId) { %>
                <span style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:9999px;background:rgba(0,120,212,0.12);border:1px solid rgba(0,120,212,0.25);font-size:0.72rem;font-weight:700;color:#60a5fa;">
                  <svg viewBox="0 0 21 21" style="width:12px;height:12px;flex-shrink:0;" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1"  y="1"  width="9" height="9" fill="#f25022"/>
                    <rect x="11" y="1"  width="9" height="9" fill="#7fba00"/>
                    <rect x="1"  y="11" width="9" height="9" fill="#00a4ef"/>
                    <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
                  </svg>
                  Microsoft
                </span>
              <% } %>
              <% if (user.googleId && !user.googleId.startsWith('ms_')) { %>
                <span style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:9999px;background:rgba(234,67,53,0.1);border:1px solid rgba(234,67,53,0.25);font-size:0.72rem;font-weight:700;color:#f87171;">
                  Google
                </span>
              <% } %>
              <% if (user.passwordHash) { %>
                <span style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:9999px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);font-size:0.72rem;font-weight:700;color:#4ade80;">
                  Password
                </span>
              <% } %>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Password card ── -->
      <div class="panel" style="padding:1.5rem;margin-bottom:1rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
          <p style="font-size:0.68rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#475569;">
            <%= user.passwordHash ? 'Change Password' : 'Set a Backup Password' %>
          </p>
          <% if (!user.passwordHash) { %>
            <span style="font-size:0.65rem;background:rgba(234,179,8,0.12);color:#facc15;border:1px solid rgba(234,179,8,0.25);padding:0.2rem 0.6rem;border-radius:9999px;font-weight:700;">Optional</span>
          <% } %>
        </div>

        <% if (!user.passwordHash) { %>
          <p style="font-size:0.8rem;color:#64748b;line-height:1.6;margin-bottom:1.25rem;">
            You currently sign in with <%= user.microsoftId ? 'Microsoft' : 'single sign-on' %>.
            Setting a password lets you also sign in directly with your email address as a backup.
          </p>
        <% } %>

        <!-- Flash messages -->
        <% if (typeof passwordError !== 'undefined' && passwordError) { %>
          <div style="padding:0.65rem 1rem;border-radius:0.5rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#f87171;font-size:0.8rem;margin-bottom:1rem;">⚠ <%= passwordError %></div>
        <% } %>
        <% if (typeof passwordSuccess !== 'undefined' && passwordSuccess) { %>
          <div style="padding:0.65rem 1rem;border-radius:0.5rem;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);color:#4ade80;font-size:0.8rem;margin-bottom:1rem;">✓ <%= passwordSuccess %></div>
        <% } %>

        <form method="POST" action="/settings/password">

          <% if (user.passwordHash) { %>
            <div style="margin-bottom:1rem;">
              <label style="font-size:0.72rem;font-weight:600;color:#64748b;display:block;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.06em;">Current Password</label>
              <input type="password" name="current" placeholder="Enter current password"
                     autocomplete="current-password"
                     style="width:100%;padding:0.6rem 0.9rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.875rem;outline:none;transition:border-color 0.2s;" />
            </div>
          <% } %>

          <div style="margin-bottom:1rem;">
            <label style="font-size:0.72rem;font-weight:600;color:#64748b;display:block;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.06em;">New Password</label>
            <input type="password" name="password" placeholder="At least 8 characters"
                   autocomplete="new-password"
                   style="width:100%;padding:0.6rem 0.9rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.875rem;outline:none;transition:border-color 0.2s;" />
          </div>

          <div style="margin-bottom:1.25rem;">
            <label style="font-size:0.72rem;font-weight:600;color:#64748b;display:block;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.06em;">Confirm New Password</label>
            <input type="password" name="confirm" placeholder="Repeat new password"
                   autocomplete="new-password"
                   style="width:100%;padding:0.6rem 0.9rem;border-radius:0.5rem;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:white;font-family:inherit;font-size:0.875rem;outline:none;transition:border-color 0.2s;" />
          </div>

          <button type="submit" style="
            padding:0.65rem 1.5rem; border-radius:9999px;
            font-family:inherit; font-size:0.82rem; font-weight:700;
            color:#60a5fa; cursor:pointer;
            background:rgba(59,130,246,0.1);
            border:1px solid rgba(59,130,246,0.35);
            transition:all 0.2s;
          "
          onmouseover="this.style.background='rgba(59,130,246,0.25)'"
          onmouseout="this.style.background='rgba(59,130,246,0.1)'">
            <%= user.passwordHash ? 'Update Password' : 'Save Password' %>
          </button>

        </form>
      </div>

    </div>

    <%- include('../partials/footer') %>
  </div>

</body>
</html>
