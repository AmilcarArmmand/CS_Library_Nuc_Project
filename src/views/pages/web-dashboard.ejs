      const cond  = item.conditionSummary ?? { Good: 0, Fair: 0, Poor: 0 };

      document.getElementById('equipModalCover').src = item.image || '/assets/book-placeholder.svg';
      document.getElementById('equipModalCover').alt = item.name;
      document.getElementById('equipModalName').textContent     = item.name;
      document.getElementById('equipModalCategory').textContent = item.category || 'Equipment';
