<%- include('partials/header') %>

<h1><%= title %></h1>

<% if (message) { %>
<div class="message">
    <p><%= message %></p>
</div>
<% } %>

<div class="contact-grid">
    <div class="contact-info">
        <h2>Get in Touch</h2>
        <p>Contact the CS Library team if you want to donate a book, report a catalog issue, or ask a question about borrowing.</p>
        
        <div class="contact-details">
            <p><strong>Location:</strong> Computer Science Department Library</p>
            <p><strong>Support:</strong> Contact a department administrator for production access or account help.</p>
        </div>
        
        <div class="async-demo">
            <h3>Library Support</h3>
            <ul>
                <li>Book donations</li>
                <li>Catalog corrections</li>
                <li>Account questions</li>
                <li>Checkout and return help</li>
            </ul>
        </div>
    </div>
    
    <div class="contact-form-container">
        <h2>Send a Message</h2>
        <form id="contact-form" class="contact-form" method="POST" action="/contact">
            <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" value="<%= formData.name || '' %>" required>
            </div>
            
            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required>
                <small class="email-hint">Use a valid email address so the team can follow up.</small>
            </div>
            
            <div class="form-group">
                <label for="message">Message *</label>
                <textarea id="message" name="message" rows="5" required><%= formData.message || '' %></textarea>
            </div>
            
            <button type="submit" class="btn">Send Message</button>
        </form>
        
        <div class="form-info">
            <p><em>Messages are routed through the configured server mailer when email delivery is enabled.</em></p>
        </div>
    </div>
</div>

<script src="/js/contact.js"></script>

<%- include('partials/footer') %>
