<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background-color: #020617;
      overflow-x: hidden;
      min-height: 100vh;
      color: white;
    }

    /* ── Starfield ── */
    .stars-1, .stars-2, .stars-3 { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 0; }
    .stars-1 {
      width: 1px; height: 1px; background: transparent;
      box-shadow:
        120px 340px #fff, 450px 89px #fff, 780px 520px #fff, 1200px 150px #fff,
        90px 670px #fff, 1500px 400px #fff, 330px 210px #fff, 880px 760px #fff,
        1650px 90px #fff, 560px 430px #fff, 1380px 620px #fff, 210px 510px #fff,
        970px 280px #fff, 1750px 700px #fff, 640px 150px #fff, 1100px 480px #fff,
        40px 820px #fff, 1420px 250px #fff, 730px 630px #fff, 1850px 180px #fff,
        290px 740px #fff, 1050px 390px #fff, 500px 560px #fff, 1680px 460px #fff,
        160px 120px #fff, 860px 870px #fff, 1310px 130px #fff, 420px 680px #fff;
      animation: twinkle 8s infinite alternate, drift 60s linear infinite;
    }
    .stars-2 {
      width: 2px; height: 2px; background: transparent;
      box-shadow:
        200px 500px rgba(255,255,255,0.5), 750px 200px rgba(255,255,255,0.4),
        1300px 650px rgba(255,255,255,0.6), 50px 200px rgba(200,220,255,0.6),
        550px 600px rgba(200,220,255,0.7), 1400px 80px rgba(200,220,255,0.5);
      animation: twinkle2 10s infinite alternate-reverse, drift 45s linear infinite reverse;
    }
    .stars-3 {
      width: 3px; height: 3px; background: transparent; border-radius: 50%;
      box-shadow:
        400px 100px rgba(180,200,255,0.7), 950px 300px rgba(180,200,255,0.5),
        1550px 500px rgba(180,200,255,0.8), 700px 700px rgba(200,220,255,0.7);
      animation: twinkle3 14s infinite alternate, drift 80s linear infinite;
    }
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%),
        radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%),
        radial-gradient(ellipse at 50% 80%, rgba(88,28,135,0.08), transparent 40%);
      animation: nebulaPulse 20s ease-in-out infinite alternate;
    }
    @keyframes twinkle  { 0%{opacity:.4} 50%{opacity:.9} 100%{opacity:.6} }
    @keyframes twinkle2 { 0%{opacity:.3} 33%{opacity:.8} 100%{opacity:.9} }
    @keyframes twinkle3 { 0%{opacity:.5} 50%{opacity:1}  100%{opacity:.3} }
    @keyframes drift    { from{transform:translateY(0)} to{transform:translateY(-200px)} }
    @keyframes nebulaPulse { 0%{opacity:.8} 50%{opacity:1} 100%{opacity:.7} }
    @keyframes cardIn   { from{opacity:0;transform:translateY(18px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
    @keyframes slideUp  { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

    /* ── Header ── */
    .app-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      min-height: 5rem; display: flex; align-items: center;
      justify-content: space-between; flex-wrap: nowrap;
      padding: max(1rem, env(safe-area-inset-top)) 2rem 0.75rem;
      background: rgba(10,15,28,0.8);
      border-bottom: 1px solid rgba(255,255,255,0.1);
      backdrop-filter: blur(40px);
      box-shadow: 0 2px 32px rgba(0,0,0,0.5);
    }
    .header-brand { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
    .header-brand img { width: 3rem; max-height: 2rem; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.9; }
    .header-brand-text { display: flex; align-items: center; gap: 0.25rem; }
    .header-title-cs    { font-size: 0.7rem; font-weight: 900; letter-spacing: 0.15em; color: white; }
    .header-title-kiosk { font-size: 0.7rem; font-weight: 300; letter-spacing: 0.15em; color: #60a5fa; }
    .header-user { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
    .header-user-name { font-size: 0.75rem; font-weight: 700; color: #e2e8f0; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .logout-btn {
      display: flex; align-items: center; justify-content: center;
      width: 2rem; height: 2rem; border-radius: 50%;
      background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);
      color: #fca5a5; font-size: 1rem; text-decoration: none; transition: all 0.2s;
    }
    .logout-btn:hover { background: rgba(239,68,68,0.3); }

    /* ── Page wrap ── */
    .page-wrap {
      position: relative; z-index: 1;
      padding-top: calc(6rem + env(safe-area-inset-top));
      padding-bottom: calc(7rem + env(safe-area-inset-bottom));
      display: flex; flex-direction: column; align-items: center;
      min-height: 100vh;
    }

    /* ── Floating nav ── */
    .dash-nav {
      position: fixed;
      bottom: calc(1rem + env(safe-area-inset-bottom));
      left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 0.25rem;
      padding: 0.35rem;
      background: rgba(15,23,42,0.55);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 9999px;
      backdrop-filter: blur(24px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 200; white-space: nowrap;
    }
    .nav-btn {
      display: flex; align-items: center; justify-content: center; gap: 0.35rem;
      padding: 0.5rem 1rem; border-radius: 9999px;
      border: 1px solid transparent; background: transparent;
      color: #94a3b8; font-family: inherit; font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.1em; cursor: pointer; transition: all 0.2s;
    }
    .nav-btn img { width: 18px; height: 18px; opacity: 0.55; transition: opacity 0.2s; }
    .nav-btn:hover { background: rgba(255,255,255,0.08); color: #e2e8f0; }
    .nav-btn:hover img { opacity: 1; }
    .nav-btn.active { background: rgba(255,255,255,0.06); color: white; border-color: rgba(255,255,255,0.1); box-shadow: 0 0 20px rgba(59,130,246,0.4); }
    .nav-btn.active img { opacity: 1; }
    .nav-divider { width: 1px; height: 1.5rem; background: rgba(255,255,255,0.1); margin: 0 0.15rem; }
    .search-input {
      width: 0; max-width: 0; opacity: 0; pointer-events: none; overflow: hidden;
      padding: 0.4rem 1rem; border-radius: 9999px;
      border: 1px solid rgba(59,130,246,0.5); background: rgba(15,23,42,0.9);
      color: white; font-family: inherit; font-size: 0.8rem; outline: none;
      transition: width 0.3s, opacity 0.3s, max-width 0.3s;
    }
    .search-input.open { width: 13rem; max-width: 13rem; opacity: 1; pointer-events: auto; }
    .search-input::placeholder { color: rgba(148,163,184,0.6); }

    /* ── Panel surface ── */
    .panel {
      background: rgba(21,25,36,0.84);
      border: 1px solid rgba(71,85,105,0.55);
      border-radius: 1rem;
      box-shadow: 0 24px 44px -22px rgba(2,6,23,0.95), 0 0 0 1px rgba(59,130,246,0.08);
      backdrop-filter: blur(20px);
      transition: border-color 0.5s, box-shadow 0.5s;
    }
    .panel:hover { border-color: rgba(96,165,250,0.3); box-shadow: 0 30px 52px -20px rgba(2,6,23,0.98), 0 0 0 1px rgba(59,130,246,0.18); }
    .panel-title {
      font-size: 0.72rem; letter-spacing: 0.3em; font-weight: 900; text-transform: uppercase;
      background: linear-gradient(to right, #1d4ed8, #2563eb, #1d4ed8);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* ── Workspaces ── */
    .workspace { display: none; width: 100%; max-width: 80rem; padding: 0 1rem; flex-direction: column; align-items: center; }
    .workspace.active { display: flex; }

    /* Catalog */
    .catalog-header { width: 100%; display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem; }
    .catalog-title { font-size: 1.4rem; font-weight: 700; }
    .catalog-meta  { display: flex; flex-direction: column; align-items: flex-end; }
    .catalog-count { font-size: 0.78rem; font-weight: 600; color: #cbd5e1; }
    .catalog-page  { font-size: 0.68rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; }

    .filter-row { width: 100%; display: flex; gap: 0.5rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .filter-btn {
      padding: 0.3rem 0.9rem; border-radius: 9999px; font-family: inherit;
      font-size: 0.68rem; font-weight: 900; letter-spacing: 0.1em; cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04);
      color: #94a3b8; transition: all 0.2s;
    }
    .filter-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .filter-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 12px rgba(59,130,246,0.35); }

    .catalog-grid {
      width: 100%; display: grid; gap: 0.75rem;
      grid-template-columns: repeat(2, 1fr);
    }
    @media (min-width: 600px)  { .catalog-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 900px)  { .catalog-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (min-width: 1200px) { .catalog-grid { grid-template-columns: repeat(5, 1fr); } }

    .book-card {
      position: relative; border-radius: 1rem; overflow: hidden;
      border: 1px solid rgba(71,85,105,0.5); background: rgba(21,25,36,0.8);
      cursor: pointer; transition: transform 0.3s, opacity 0.3s;
      animation: cardIn 0.45s cubic-bezier(0.16,1,0.3,1) both;
    }
    .book-card:hover { transform: scale(1.03); }
    .book-card.checked-out { opacity: 0.6; filter: grayscale(1); border-color: rgba(239,68,68,0.5); }
    .book-card img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; }
    .book-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to bottom, transparent, rgba(15,23,42,0.75) 30%, rgba(15,23,42,0.97));
      padding: 2.5rem 0.75rem 0.75rem;
    }
    .book-title  { font-size: 0.88rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.2rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .book-author { font-size: 0.72rem; color: #cbd5e1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 0.2rem; }
    .book-isbn   { font-size: 0.62rem; color: #64748b; letter-spacing: 0.05em; margin-bottom: 0.4rem; }
    .badge { display: inline-block; padding: 0.25rem 0.6rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
    .badge-avail { background: rgba(34,197,94,0.2); color: #4ade80; }
    .badge-out   { background: rgba(239,68,68,0.2);  color: #f87171; }

    .pagination { width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-top: 2rem; flex-wrap: wrap; }
    .page-btn {
      width: 2.1rem; height: 2.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: inherit; font-size: 0.72rem; font-weight: 600; cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: #94a3b8;
      transition: all 0.2s;
    }
    .page-btn:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: white; }
    .page-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 12px rgba(59,130,246,0.35); }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .page-dots { color: #64748b; font-size: 0.85rem; display: flex; align-items: center; padding: 0 0.25rem; }

    /* Checkout */
    .checkout-row { display: flex; gap: 1.25rem; width: 100%; flex-direction: column; }
    @media (min-width: 768px) { .checkout-row { flex-direction: row; } }
    .scan-panel, .cart-panel { flex: 1; padding: 1.75rem; display: flex; flex-direction: column; align-items: center; text-align: center; animation: slideUp 0.4s ease-out; }
    .cart-panel { text-align: left; height: 420px; }
    @media (min-width: 768px) { .cart-panel { height: 500px; } }

    .scan-input {
      width: 100%; padding: 0.7rem 1.2rem; border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06);
      color: white; font-family: inherit; font-size: 1rem; text-align: center;
      outline: none; transition: all 0.3s; margin-bottom: 1.25rem;
    }
    .scan-input:focus { border-color: rgba(59,130,246,0.5); background: rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(59,130,246,0.2); }
    .scan-input::placeholder { color: rgba(148,163,184,0.6); }

    .checkout-cover  { width: 7rem; height: 10.5rem; object-fit: cover; border-radius: 0.75rem; border: 1px solid #475569; box-shadow: 0 8px 24px rgba(0,0,0,0.5); margin-bottom: 0.85rem; }
    .checkout-title  { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.2rem; }
    .checkout-author { font-size: 0.82rem; color: #94a3b8; font-style: italic; }
    .checkout-due    { font-size: 0.82rem; color: #60a5fa; font-weight: 700; margin-top: 0.4rem; }

    .cart-items { flex: 1; overflow-y: auto; width: 100%; display: flex; flex-direction: column; gap: 0.6rem; }
    .cart-item  { display: flex; align-items: center; gap: 0.75rem; background: rgba(21,25,36,0.84); padding: 0.85rem; border-radius: 0.75rem; border: 1px solid rgba(71,85,105,0.55); }
    .cart-item img { width: 2.75rem; height: 3.75rem; object-fit: cover; border-radius: 0.35rem; flex-shrink: 0; }
    .cart-item-title  { font-weight: 700; font-size: 0.82rem; }
    .cart-item-author { font-size: 0.7rem; color: #94a3b8; }
    .cart-item-due    { font-size: 0.68rem; color: #60a5fa; font-weight: 700; }

    .empty-cart { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
    .empty-cart img { width: 3rem; height: 3rem; opacity: 0.3; margin-bottom: 0.6rem; }
    .empty-cart p   { color: #64748b; font-size: 0.85rem; font-weight: 700; }
    .empty-cart span{ color: #475569; font-size: 0.72rem; }

    .confirm-btn {
      width: 100%; padding: 0.9rem; margin-top: 0.85rem; border-radius: 1rem;
      font-family: inherit; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.05em;
      cursor: pointer; border: 1px solid; transition: all 0.3s;
    }
    .confirm-btn.off { background: rgba(255,255,255,0.05); color: #64748b; border-color: rgba(255,255,255,0.1); cursor: not-allowed; }
    .confirm-btn.on  { background: rgba(59,130,246,0.2); color: #60a5fa; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 30px -5px rgba(59,130,246,0.3); }
    .confirm-btn.on:hover { background: rgba(59,130,246,0.35); }

    /* Return */
    .return-panel { width: 100%; max-width: 52rem; padding: 2.25rem 1.75rem; text-align: center; animation: slideUp 0.4s ease-out; }
    .return-layout { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; margin-top: 1.25rem; }
    @media (min-width: 768px) { .return-layout { flex-direction: row; justify-content: center; gap: 4rem; text-align: left; } }
    .return-cover { width: 9rem; height: 13.5rem; object-fit: cover; border-radius: 1rem; border: 1px solid #475569; box-shadow: 0 16px 36px rgba(0,0,0,0.6); flex-shrink: 0; }
    .return-status { display: inline-block; padding: 0.3rem 0.9rem; border-radius: 9999px; font-size: 0.62rem; font-weight: 900; letter-spacing: 0.15em; border: 1px solid; margin-bottom: 0.85rem; }
    .return-status.waiting  { color: #94a3b8; background: #1e293b; border-color: #475569; }
    .return-status.returned { color: #60a5fa; background: rgba(59,130,246,0.2); border-color: rgba(59,130,246,0.5); }
    .return-title { font-size: 1.75rem; font-weight: 700; line-height: 1.2; }

    /* My Books */
    .mybooks-panel { width: 100%; max-width: 52rem; padding: 1.75rem; max-height: 75vh; overflow-y: auto; animation: slideUp 0.4s ease-out; }
    .section-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.85rem; }
    .divider { width: 100%; height: 1px; background: rgba(71,85,105,0.5); margin: 1.25rem 0; }

    .loan-row { display: flex; align-items: center; gap: 0.85rem; padding: 0.85rem; border-radius: 0.75rem; margin-bottom: 0.6rem; }
    .loan-row.active  { background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55); box-shadow: 0 16px 30px -20px rgba(2,6,23,0.95), 0 0 0 1px rgba(59,130,246,0.09), inset 0 1px 0 rgba(255,255,255,0.05); }
    .loan-row.history { background: rgba(21,25,36,0.68); border: 1px solid rgba(71,85,105,0.45); opacity: 0.85; }
    .loan-row img { width: 2.75rem; height: 3.75rem; border-radius: 0.35rem; object-fit: cover; flex-shrink: 0; }
    .loan-row.history img { width: 2.25rem; height: 3rem; }
    .loan-info { flex: 1; min-width: 0; }
    .loan-title  { font-weight: 700; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .loan-author { font-size: 0.7rem; color: #94a3b8; }
    .loan-due-label { font-size: 0.68rem; font-weight: 700; }
    .due-ok       { color: #60a5fa; }
    .due-overdue  { color: #f87171; }
    .due-returned { color: #64748b; }
    .loan-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; flex-shrink: 0; }

    .renew-btn {
      padding: 0.35rem 0.9rem; border-radius: 9999px;
      font-family: inherit; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em;
      cursor: pointer; border: none; background: rgba(59,130,246,0.2);
      color: #60a5fa; transition: all 0.2s;
    }
    .renew-btn:hover:not(:disabled) { background: rgba(59,130,246,0.35); }
    .renew-btn:disabled { background: #1e293b; color: #475569; cursor: not-allowed; }
    .hold-warning { font-size: 0.62rem; color: #fbbf24; font-weight: 600; max-width: 8rem; text-align: right; }

    .empty-state { display: flex; flex-direction: column; align-items: center; padding: 1.25rem; }
    .empty-state img { width: 2.75rem; height: 2.75rem; opacity: 0.3; margin-bottom: 0.6rem; }
    .empty-state p { color: #64748b; font-size: 0.82rem; }

    /* Toast */
    .toast-wrap { position: fixed; top: 6rem; right: 1.25rem; z-index: 500; display: flex; flex-direction: column; gap: 0.4rem; }
    .toast {
      padding: 0.7rem 1.1rem; border-radius: 0.75rem; font-size: 0.8rem; font-weight: 600;
      border: 1px solid; min-width: 13rem; max-width: 22rem;
      animation: slideUp 0.3s ease-out; box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .toast.positive { background: rgba(34,197,94,0.15); color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .toast.negative { background: rgba(239,68,68,0.15); color: #f87171; border-color: rgba(239,68,68,0.3); }
    .toast.warning  { background: rgba(234,179,8,0.15);  color: #facc15; border-color: rgba(234,179,8,0.3); }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #3b82f6; }

    @media (max-width: 768px) {
      ::-webkit-scrollbar { display: none; }
      * { scrollbar-width: none; }
      .nav-btn span { display: none; }
      .nav-btn { padding: 0.5rem 0.65rem; }
    }
    @media (max-height: 500px) and (min-width: 700px) {
      .app-header { min-height: 3.85rem; padding-top: max(0.3rem, env(safe-area-inset-top)); padding-bottom: 0.25rem; }
    }
  </style>
</head>
<body>
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <!-- Header -->
  <header class="app-header">
    <div class="header-brand">
      <img src="/assets/scsu_logo.png" alt="SCSU" onerror="this.style.display='none'" />
      <div class="header-brand-text">
        <span class="header-title-cs">CS_LIBRARY</span>
        <span class="header-title-kiosk">KIOSK</span>
      </div>
    </div>
    <div class="header-user">
      <span class="header-user-name"><%= user.name %></span>
      <a href="/kiosk/logout" class="logout-btn" title="Sign out">⏻</a>
    </div>
  </header>

  <!-- Toast container -->
  <div class="toast-wrap" id="toastWrap"></div>

  <main class="page-wrap">

    <!-- ── CATALOG ── -->
    <div class="workspace active" id="ws-catalog">
      <div class="catalog-header">
        <h1 class="catalog-title">Library Catalog</h1>
        <div class="catalog-meta">
          <span class="catalog-count" id="catalogCount">Loading…</span>
          <span class="catalog-page"  id="catalogPage"></span>
        </div>
      </div>
      <div class="filter-row">
        <button class="filter-btn active" data-filter="all"         onclick="setFilter('all')">ALL</button>
        <button class="filter-btn"        data-filter="available"   onclick="setFilter('available')">AVAILABLE</button>
        <button class="filter-btn"        data-filter="checked_out" onclick="setFilter('checked_out')">CHECKED OUT</button>
      </div>
      <div class="catalog-grid" id="catalogGrid"></div>
      <div class="pagination"   id="pagination"></div>
    </div>

    <!-- ── CHECKOUT ── -->
    <div class="workspace" id="ws-checkout">
      <div class="checkout-row">
        <div class="panel scan-panel">
          <p class="panel-title" style="margin-bottom:1.25rem;">SCAN TO ADD TO CART</p>
          <input type="text" class="scan-input" id="checkoutInput"
                 placeholder="Scan ISBN…" autocomplete="off"
                 onkeydown="if(event.key==='Enter') scanISBN()" />
          <img id="checkoutCover" src="https://via.placeholder.com/200x300?text=Waiting%E2%80%A6"
               class="checkout-cover" alt="cover" />
          <p class="checkout-title"  id="checkoutTitle">---</p>
          <p class="checkout-author" id="checkoutAuthor">---</p>
          <p class="checkout-due"    id="checkoutDue"></p>
        </div>
        <div class="panel cart-panel">
          <p class="panel-title" style="margin-bottom:0.85rem;">YOUR CART</p>
          <div class="empty-cart" id="emptyCart">
            <img src="/assets/ph-shopping-cart.svg" alt="" />
            <p>Cart is empty</p><span>Scan a barcode to begin</span>
          </div>
          <div class="cart-items" id="cartItems"></div>
          <button class="confirm-btn off" id="confirmBtn" onclick="confirmCheckout()">
            CONFIRM CHECKOUT (0)
          </button>
        </div>
      </div>
    </div>

    <!-- ── RETURN ── -->
    <div class="workspace" id="ws-return">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">QUICK RETURN</p>
        <input type="text" class="scan-input" id="returnInput"
               placeholder="Scan barcode…" autocomplete="off"
               onkeydown="if(event.key==='Enter') scanReturn()" />
        <div class="return-layout">
          <img id="returnCover" src="https://via.placeholder.com/200x300?text=Drop+Book"
               class="return-cover" alt="cover" />
          <div>
            <span class="return-status waiting" id="returnStatus">WAITING FOR SCAN</span>
            <p class="return-title" id="returnTitle">---</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MY BOOKS ── -->
    <div class="workspace" id="ws-mybooks">
      <div class="panel mybooks-panel">
        <p class="panel-title" style="margin-bottom:1.25rem; text-align:center;">MY BORROWED BOOKS</p>
        <p class="section-title" id="activeCount">Currently Checked Out</p>
        <div id="activeLoans"></div>
        <div class="empty-state" id="noActiveLoans" style="display:none;">
          <img src="/assets/ph-check-circle.svg" alt="" />
          <p>No books currently checked out</p>
        </div>
        <div class="divider"></div>
        <p class="section-title">Borrowing History (Last 6 Months)</p>
        <div id="loanHistory"></div>
        <div class="empty-state" id="noHistory" style="display:none;">
          <img src="/assets/ph-clock-counter-clockwise.svg" alt="" />
          <p>No borrowing history yet</p>
        </div>
      </div>
    </div>

  </main>

  <!-- Floating nav -->
  <nav class="dash-nav">
    <button class="nav-btn active" id="nav-catalog"  onclick="showView('catalog')">
      <img src="/assets/ph-squares-four.svg" alt="" /><span>BROWSE</span>
    </button>
    <button class="nav-btn"        id="nav-checkout" onclick="showView('checkout')">
      <img src="/assets/ph-shopping-cart.svg" alt="" /><span>CHECKOUT</span>
    </button>
    <button class="nav-btn"        id="nav-return"   onclick="showView('return')">
      <img src="/assets/ph-arrow-u-down-left.svg" alt="" /><span>RETURN</span>
    </button>
    <button class="nav-btn"        id="nav-mybooks"  onclick="showView('mybooks')">
      <img src="/assets/ph-book-open-text.svg" alt="" /><span>MY BOOKS</span>
    </button>
    <div class="nav-divider"></div>
    <button class="nav-btn" onclick="toggleSearch()">
      <img src="/assets/ph-magnifying-glass.svg" alt="" /><span>SEARCH</span>
    </button>
    <input type="text" class="search-input" id="searchInput"
           placeholder="Search…" oninput="handleSearch(this.value)" />
  </nav>

  <script>
    // ── Seed cart from server session ──────────────────────────────────────────
    let cart = <%- JSON.stringify(cart || []) %>;

    // ── State ──────────────────────────────────────────────────────────────────
    let allBooks      = [];
    let filtered      = [];
    let currentFilter = 'all';
    let currentPage   = 1;
    const PER_PAGE    = 12;
    let searchQuery   = '';
    let searchTimer   = null;

    // ── Toast ──────────────────────────────────────────────────────────────────
    function toast(msg, type = 'positive') {
      const el = document.createElement('div');
      el.className = `toast ${type}`;
      el.textContent = msg;
      document.getElementById('toastWrap').appendChild(el);
      setTimeout(() => el.remove(), 4500);
    }

    // ── Nav ────────────────────────────────────────────────────────────────────
    function showView(view) {
      document.querySelectorAll('.workspace').forEach(w => w.classList.remove('active'));
      document.querySelectorAll('.nav-btn[id^="nav-"]').forEach(b => b.classList.remove('active'));
      document.getElementById(`ws-${view}`).classList.add('active');
      const nb = document.getElementById(`nav-${view}`);
      if (nb) nb.classList.add('active');
      if (view === 'checkout') document.getElementById('checkoutInput').focus();
      if (view === 'return')   document.getElementById('returnInput').focus();
      if (view === 'mybooks')  loadMyBooks();
    }

    // ── Search ─────────────────────────────────────────────────────────────────
    function toggleSearch() {
      const inp = document.getElementById('searchInput');
      inp.classList.toggle('open');
      if (inp.classList.contains('open')) { showView('catalog'); inp.focus(); }
      else { searchQuery = ''; inp.value = ''; applyFilters(); }
    }
    function handleSearch(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        searchQuery = val.toLowerCase().trim();
        currentPage = 1;
        applyFilters();
      }, 250);
    }

    // ── Catalog ────────────────────────────────────────────────────────────────
    async function loadCatalog() {
      try {
        const r = await fetch('/kiosk/api/catalog');
        const d = await r.json();
        allBooks = d.books ?? [];
        applyFilters();
      } catch { toast('Could not load catalog.', 'negative'); }
    }

    function setFilter(f) {
      currentFilter = f; currentPage = 1;
      document.querySelectorAll('.filter-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.filter === f));
      applyFilters();
    }

    function applyFilters() {
      let b = allBooks;
      if (searchQuery)
        b = b.filter(x => x.title.toLowerCase().includes(searchQuery) ||
                          x.author.toLowerCase().includes(searchQuery) ||
                          (x.isbn||'').toLowerCase().includes(searchQuery));
      if (currentFilter === 'available')   b = b.filter(x => x.status === 'Available');
      if (currentFilter === 'checked_out') b = b.filter(x => x.status !== 'Available');
      filtered = b;
      const tp = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (currentPage > tp) currentPage = tp;
      renderCatalog(); renderPagination(tp);
    }

    function renderCatalog() {
      const grid  = document.getElementById('catalogGrid');
      const start = (currentPage - 1) * PER_PAGE;
      const page  = filtered.slice(start, start + PER_PAGE);
      const tp    = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      document.getElementById('catalogCount').textContent =
        `Showing ${page.length} of ${filtered.length} book${filtered.length !== 1 ? 's' : ''}`;
      document.getElementById('catalogPage').textContent =
        `Page ${currentPage} of ${tp}`;
      grid.innerHTML = page.map((b, i) => {
        const avail = b.status === 'Available';
        return `<div class="book-card ${avail?'':'checked-out'}" style="animation-delay:${Math.min(i*.04,.24)}s">
          <img src="${esc(b.cover||'')}" loading="lazy"
               onerror="this.src='https://via.placeholder.com/200x300?text=No+Cover'" alt="${esc(b.title)}" />
          <div class="book-overlay">
            <p class="book-title">${esc(b.title)}</p>
            <p class="book-author">${esc(b.author)}</p>
            <p class="book-isbn">ISBN ${esc(b.isbn||'')}</p>
            <span class="badge ${avail?'badge-avail':'badge-out'}">${avail?'AVAILABLE':'CHECKED OUT'}</span>
          </div>
        </div>`;
      }).join('');
    }

    function renderPagination(tp) {
      const pg = document.getElementById('pagination');
      if (tp <= 1) { pg.innerHTML=''; return; }
      let pages = [];
      if (tp <= 7) { pages = Array.from({length:tp},(_,i)=>i+1); }
      else {
        pages=[1];
        if (currentPage>3) pages.push('…');
        for (let p=Math.max(2,currentPage-1); p<=Math.min(tp-1,currentPage+1); p++) if(!pages.includes(p)) pages.push(p);
        if (currentPage<tp-2) pages.push('…');
        if (!pages.includes(tp)) pages.push(tp);
      }
      pg.innerHTML =
        `<button class="page-btn" ${currentPage<=1?'disabled':''} onclick="goPage(${currentPage-1})">‹</button>` +
        pages.map(p => p==='…'
          ? `<span class="page-dots">···</span>`
          : `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`
        ).join('') +
        `<button class="page-btn" ${currentPage>=tp?'disabled':''} onclick="goPage(${currentPage+1})">›</button>`;
    }

    function goPage(p) {
      currentPage = Math.max(1, p);
      renderCatalog();
      renderPagination(Math.ceil(filtered.length/PER_PAGE));
      window.scrollTo({top:0,behavior:'smooth'});
    }

    // ── Checkout ───────────────────────────────────────────────────────────────
    function dueString() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
    }
    function dueShort() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    }

    async function scanISBN() {
      const inp  = document.getElementById('checkoutInput');
      const isbn = inp.value.trim(); inp.value = '';
      if (!isbn) return;
      try {
        const r = await fetch('/kiosk/api/cart/add', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({isbn}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not add book.', r.status===409?'warning':'negative'); return; }
        cart = [...cart, d.book];
        refreshCartUI();
        // Update preview panel
        document.getElementById('checkoutCover').src    = d.book.cover || 'https://via.placeholder.com/200x300';
        document.getElementById('checkoutTitle').textContent  = d.book.title;
        document.getElementById('checkoutAuthor').textContent = d.book.author;
        document.getElementById('checkoutDue').textContent    = `Due: ${dueString()}`;
      } catch { toast('Server error.', 'negative'); }
    }

    function refreshCartUI() {
      const empty = document.getElementById('emptyCart');
      const items = document.getElementById('cartItems');
      const btn   = document.getElementById('confirmBtn');
      empty.style.display = cart.length ? 'none' : 'flex';
      items.innerHTML = cart.map(b=>`
        <div class="cart-item">
          <img src="${esc(b.cover||'')}" onerror="this.src='https://via.placeholder.com/200x300'" alt="" />
          <div><p class="cart-item-title">${esc(b.title)}</p>
               <p class="cart-item-author">${esc(b.author)}</p>
               <p class="cart-item-due">Due: ${dueShort()}</p></div>
        </div>`).join('');
      btn.textContent = `CONFIRM CHECKOUT (${cart.length})`;
      btn.className   = `confirm-btn ${cart.length?'on':'off'}`;
    }

    async function confirmCheckout() {
      if (!cart.length) return;
      try {
        const r = await fetch('/kiosk/api/checkout', {method:'POST'});
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Checkout failed.','negative'); return; }
        const {checkedOut, requested} = d;
        if (checkedOut === requested)
          toast(`Checked out ${checkedOut} item(s)! Return by ${dueString()}.`, 'positive');
        else if (checkedOut > 0)
          toast(`Checked out ${checkedOut} of ${requested} item(s). Some were unavailable.`, 'warning');
        else
          toast('No items checked out — books may be unavailable.', 'warning');
        cart = [];
        refreshCartUI();
        document.getElementById('checkoutCover').src = 'https://via.placeholder.com/200x300?text=Waiting%E2%80%A6';
        document.getElementById('checkoutTitle').textContent  = '---';
        document.getElementById('checkoutAuthor').textContent = '---';
        document.getElementById('checkoutDue').textContent    = '';
        await loadCatalog();
      } catch { toast('Server error.','negative'); }
    }

    // ── Return ─────────────────────────────────────────────────────────────────
    async function scanReturn() {
      const inp  = document.getElementById('returnInput');
      const isbn = inp.value.trim(); inp.value='';
      if (!isbn) return;
      try {
        const r = await fetch('/kiosk/api/return', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({isbn}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Return failed.', r.status===409?'warning':'negative'); return; }
        document.getElementById('returnCover').src   = d.book?.cover || 'https://via.placeholder.com/200x300';
        document.getElementById('returnTitle').textContent = d.book?.title ?? isbn;
        const badge = document.getElementById('returnStatus');
        badge.textContent = 'RETURNED SUCCESSFULLY';
        badge.className   = 'return-status returned';
        toast('Book returned!','positive');
        await loadCatalog();
      } catch { toast('Server error.','negative'); }
    }

    // ── My Books ───────────────────────────────────────────────────────────────
    async function loadMyBooks() {
      try {
        const r = await fetch('/kiosk/api/my-loans');
        const d = await r.json();
        const loans   = d.loans ?? [];
        const active  = loans.filter(l => !l.returned);
        const history = loans.filter(l =>  l.returned);

        document.getElementById('activeCount').textContent =
          `Currently Checked Out${active.length ? ` — Total: ${active.length}` : ''}`;
        document.getElementById('noActiveLoans').style.display = active.length  ? 'none' : 'flex';
        document.getElementById('noHistory').style.display     = history.length ? 'none' : 'flex';

        document.getElementById('activeLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const overdue = due < new Date();
          const dueStr  = due.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
          const dueClass= overdue ? 'due-overdue' : 'due-ok';
          const dueLabel= overdue ? `OVERDUE: ${dueStr}` : `Due: ${dueStr}`;
          return `
            <div class="loan-row active">
              <img src="${esc(loan.cover||'')}" onerror="this.src='https://via.placeholder.com/200x300'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
                <p class="loan-due-label ${dueClass}">${dueLabel}</p>
              </div>
              <div class="loan-actions">
                <button class="renew-btn" ${overdue?'disabled':''} onclick="renewLoan(${loan.id}, this)">RENEW</button>
              </div>
            </div>`;
        }).join('');

        document.getElementById('loanHistory').innerHTML = history.map(loan => {
          const ret = loan.returnedDate
            ? new Date(loan.returnedDate).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
            : 'N/A';
          return `
            <div class="loan-row history">
              <img src="${esc(loan.cover||'')}" onerror="this.src='https://via.placeholder.com/200x300'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
              </div>
              <span class="loan-due-label due-returned">Returned: ${ret}</span>
            </div>`;
        }).join('');
      } catch { toast('Could not load loans.','negative'); }
    }

    async function renewLoan(loanId, btn) {
      btn.disabled = true;
      try {
        const r = await fetch('/kiosk/api/renew', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({loanId}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Could not renew.','warning'); btn.disabled=false; return; }
        toast('Book renewed for 14 more days!','positive');
        await loadMyBooks();
      } catch { toast('Server error.','negative'); btn.disabled=false; }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s??'')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Boot ───────────────────────────────────────────────────────────────────
    // Show welcome toast if redirected here after login
    <% if (welcome) { %>
      toast(decodeURIComponent('<%= encodeURIComponent(welcome) %>'), 'positive');
    <% } %>

    refreshCartUI();
    loadCatalog();
  </script>
</body>
</html>
