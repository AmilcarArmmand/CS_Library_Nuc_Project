<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <div class="login-outer">
    <div class="left-panel">
      <div class="left-logo">
        <img src="/images/scsu_logo.png" alt="SCSU"
             onerror="this.style.display='none'" />
        <div class="accent-bar"></div>
        <span class="dept-label">Department of Computer Science</span>
      </div>

      <div class="left-titles">
        <p class="title-main">CS Library</p>
        <p class="title-sub">New Password.</p>
        <p class="title-desc">Choose a strong password to restore access to your account and return to the library portal.</p>
      </div>

      <p class="left-footer">© 2026 SCSU Capstone</p>
    </div>

    <div class="right-panel">
      <div class="form-box">
        <a href="/" class="form-top-link">← Back to home</a>
        <h1>Reset Password</h1>
        <div class="accent-bar-form"></div>
        <p class="subtitle">
          <% if (tokenValid) { %>
            Enter a new password for your CS Library account.
          <% } else { %>
            This link is not usable anymore. Request a fresh reset link to continue.
          <% } %>
        </p>

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>
        <% if (message) { %>
          <div class="status-msg"><%= message %></div>
        <% } %>

        <% if (tokenValid) { %>
          <form method="POST" action="/auth/reset-password">
            <input type="hidden" name="token" value="<%= token %>" />

            <div class="field-group">
              <div class="field-label">
                <span class="icon" style="display:flex;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </span>
                <span>New Password</span>
              </div>
              <input type="password" name="password" placeholder="Choose a strong password" required autofocus autocomplete="new-password" />
            </div>

            <div class="field-group">
              <div class="field-label">
                <span class="icon" style="display:flex;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </span>
                <span>Confirm Password</span>
              </div>
              <input type="password" name="confirm" placeholder="Repeat your new password" required autocomplete="new-password" />
            </div>

            <button type="submit" class="btn-primary">Save New Password</button>
          </form>
        <% } %>

        <div class="links-row">
          <span>Need another reset link?</span>
          <a href="/auth/forgot-password" class="back-link">Request one</a>
        </div>
        <div class="links-row">
          <span>Back to the sign in page?</span>
          <a href="/auth/login" class="back-link">Sign in</a>
        </div>

        <div class="clock-row">
          <span style="color:#94a3b8; display:flex;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="clock-text" id="clock">--</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    function updateClock() {
      const now = new Date();
      const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      let h = now.getHours(), ampm = 'AM';
      if (h >= 12) { ampm = 'PM'; if (h > 12) h -= 12; }
      if (h === 0) h = 12;
      const m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clock').textContent =
        `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} | ${h}:${m} ${ampm}`;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>
