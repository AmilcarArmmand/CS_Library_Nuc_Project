<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <!-- Starfield layers -->
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <div class="login-outer">

    <!-- ── LEFT PANEL ── -->
    <div class="left-panel">
      <div class="left-logo">
        <img src="/images/scsu_logo.png" alt="SCSU"
             onerror="this.style.display='none'" />
        <div class="accent-bar"></div>
        <span class="dept-label">Department of Computer Science</span>
      </div>

      <div class="left-titles">
        <p class="title-main">CS Library</p>
        <p class="title-sub">Web Portal.</p>
        <p class="title-desc">Create an account to access the CS Library catalog.</p>
      </div>

      <p class="left-footer">© 2026 SCSU Capstone</p>
    </div>

    <!-- ── RIGHT PANEL ── -->
    <div class="right-panel">
      <div class="form-box">
        <a href="/" class="form-top-link">← Back to home</a>
        <h1>Create Account</h1>
        <div class="accent-bar-form"></div>
        <p class="subtitle">Fill in your details to get started</p>

        <!-- Server-side error (from failed POST redirect) -->
        <% if (error) { %>
          <div class="error-msg server"><%= error %></div>
        <% } %>

        <form method="POST" action="/auth/register" id="registerForm">

          <!-- Full Name -->
          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </span>
              <span>Full Name</span>
            </div>
            <input type="text" name="name"
                   placeholder="Jane Doe"
                   value="<%= fields.name || '' %>"
                   autofocus autocomplete="name" />
          </div>

          <!-- Email -->
          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              <span>Email Address</span>
            </div>
            <input type="email" name="email"
                   placeholder="you@example.com"
                   value="<%= fields.email || '' %>"
                   autocomplete="email" />
          </div>

          <!-- Student ID -->
          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 10h2"/><path d="M16 14h2"/><path d="M6.17 15a3 3 0 0 1 5.66 0"/><circle cx="9" cy="11" r="2"/><rect x="2" y="5" width="20" height="14" rx="2"/></svg>
              </span>
              <span>Student ID</span>
            </div>
            <input type="text" name="studentId"
                   placeholder="e.g., 12345678"
                   value="<%= fields.studentId || '' %>"
                   autocomplete="off" />
          </div>

          <!-- Password -->
          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <span>Password</span>
            </div>
            <input type="password" name="password"
                   placeholder="Choose a strong password"
                   autocomplete="new-password" />
          </div>

          <!-- Confirm Password -->
          <div class="field-group">
            <div class="field-label">
              <span class="icon" style="display:flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <span>Confirm Password</span>
            </div>
            <input type="password" name="confirm"
                   placeholder="Repeat your password"
                   autocomplete="new-password" />
          </div>

          <!-- Client-side error label -->
          <p class="error-msg" id="clientError"></p>

          <button type="submit" class="btn-primary">Create Account</button>
        </form>

        <div class="links-row">
          <span>Already have an account?</span>
          <a href="/auth/login" class="back-link">Sign in</a>
        </div>

        <div class="clock-row">
          <span style="color:#94a3b8; display:flex;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="clock-text" id="clock">--</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Client-side validation (mirrors register.py _handle_register) ──────────
    document.getElementById('registerForm').addEventListener('submit', function(e) {
      const name      = this.name.value.trim();
      const email     = this.email.value.trim();
      const studentId = this.studentId.value.trim();
      const password  = this.password.value;
      const confirm   = this.confirm.value;
      const err       = document.getElementById('clientError');

      err.textContent = '';

      if (!name || !email || !studentId || !password) {
        e.preventDefault();
        err.textContent = 'All fields are required.';
        return;
      }
      if (password !== confirm) {
        e.preventDefault();
        err.textContent = 'Passwords do not match.';
        return;
      }
      if (password.length < 8) {
        e.preventDefault();
        err.textContent = 'Password must be at least 8 characters.';
        return;
      }
    });

    // ── Live clock ──────────────────────────────────────────────────────────────
    function updateClock() {
      const now    = new Date();
      const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      let h = now.getHours(), ampm = 'AM';
      if (h >= 12) { ampm = 'PM'; if (h > 12) h -= 12; }
      if (h === 0) h = 12;
      const m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clock').textContent =
        `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} | ${h}:${m} ${ampm}`;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>
