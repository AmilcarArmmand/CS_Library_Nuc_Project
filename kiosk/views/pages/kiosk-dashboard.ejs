<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-user-select: none;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background-color: #020617;
      overflow-x: hidden;
      min-height: 100vh;
      color: white;
      touch-action: pan-y;
      -webkit-touch-callout: none;
      overscroll-behavior-y: contain;
    }

    input, textarea {
      -webkit-user-select: text;
      user-select: text;
      touch-action: manipulation;
    }

    button, a, .book-card, .filter-btn, .nav-btn, .nav-search-btn {
      touch-action: manipulation;
    }

    /* ── Starfield ── */
    .stars-1, .stars-2, .stars-3 { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 0; }
    .stars-1 {
      width: 1px; height: 1px; background: transparent;
      box-shadow:
        120px 340px #fff, 450px 89px #fff, 780px 520px #fff, 1200px 150px #fff,
        90px 670px #fff, 1500px 400px #fff, 330px 210px #fff, 880px 760px #fff,
        1650px 90px #fff, 560px 430px #fff, 1380px 620px #fff, 210px 510px #fff,
        970px 280px #fff, 1750px 700px #fff, 640px 150px #fff, 1100px 480px #fff,
        40px 820px #fff, 1420px 250px #fff, 730px 630px #fff, 1850px 180px #fff,
        290px 740px #fff, 1050px 390px #fff, 500px 560px #fff, 1680px 460px #fff,
        160px 120px #fff, 860px 870px #fff, 1310px 130px #fff, 420px 680px #fff;
      animation: twinkle 8s infinite alternate, drift 60s linear infinite;
    }
    .stars-2 {
      width: 2px; height: 2px; background: transparent;
      box-shadow:
        200px 500px rgba(255,255,255,0.5), 750px 200px rgba(255,255,255,0.4),
        1300px 650px rgba(255,255,255,0.6), 50px 200px rgba(200,220,255,0.6),
        550px 600px rgba(200,220,255,0.7), 1400px 80px rgba(200,220,255,0.5);
      animation: twinkle2 10s infinite alternate-reverse, drift 45s linear infinite reverse;
    }
    .stars-3 {
      width: 3px; height: 3px; background: transparent; border-radius: 50%;
      box-shadow:
        400px 100px rgba(180,200,255,0.7), 950px 300px rgba(180,200,255,0.5),
        1550px 500px rgba(180,200,255,0.8), 700px 700px rgba(200,220,255,0.7);
      animation: twinkle3 14s infinite alternate, drift 80s linear infinite;
    }
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%),
        radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%),
        radial-gradient(ellipse at 50% 80%, rgba(88,28,135,0.08), transparent 40%);
      animation: nebulaPulse 20s ease-in-out infinite alternate;
    }
    @keyframes twinkle  { 0%{opacity:.4} 50%{opacity:.9} 100%{opacity:.6} }
    @keyframes twinkle2 { 0%{opacity:.3} 33%{opacity:.8} 100%{opacity:.9} }
    @keyframes twinkle3 { 0%{opacity:.5} 50%{opacity:1}  100%{opacity:.3} }
    @keyframes drift    { from{transform:translateY(0)} to{transform:translateY(-200px)} }
    @keyframes nebulaPulse { 0%{opacity:.8} 50%{opacity:1} 100%{opacity:.7} }
    @keyframes cardIn   { from{opacity:0;transform:translateY(18px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
    @keyframes slideUp  { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
    @keyframes dropDown { from{opacity:0;transform:translateY(-24px)} to{opacity:1;transform:translateY(0)} }

    /* ── Header ── */
    .app-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      height: calc(3.25rem + env(safe-area-inset-top));
      display: flex; align-items: center; justify-content: space-between;
      padding: env(safe-area-inset-top) 1.5rem 0;
      gap: 1.5rem;
      background: rgba(8,12,24,0.92);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      backdrop-filter: blur(24px);
    }
    .header-left {
      display: flex; align-items: center; gap: 0.9rem; min-width: 0;
    }
    .header-brand {
      display: flex; align-items: center; gap: 0.6rem;
      text-decoration: none; flex-shrink: 0;
    }
    .header-brand img {
      height: 1.6rem;
      object-fit: contain;
      filter: brightness(0) invert(1);
      opacity: 0.85;
    }
    .brand-text {
      display: flex; align-items: center; gap: 0.2rem;
      font-size: 0.8rem; font-weight: 900; letter-spacing: 0.12em;
    }
    .brand-cs   { color: white; }
    .brand-sep  { color: rgba(255,255,255,0.25); margin: 0 0.1rem; }
    .brand-kiosk { color: #60a5fa; font-weight: 300; }
    .header-user {
      display: flex; align-items: center; gap: 0.75rem;
      flex-shrink: 0;
    }
    .header-user-name {
      font-size: 0.78rem;
      font-weight: 600;
      color: #64748b;
      max-width: 10rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .logout-btn {
      font-size: 0.75rem;
      font-weight: 500;
      color: #f87171;
      text-decoration: none;
      transition: color 0.15s;
    }
    .logout-btn:hover { color: white; }

    /* ── Page wrap ── */
    .page-wrap {
      position: relative; z-index: 1;
      padding-top: calc(4rem + env(safe-area-inset-top));
      padding-bottom: calc(7rem + env(safe-area-inset-bottom));
      display: flex; flex-direction: column; align-items: center;
      min-height: 100vh;
    }

    /* ── Floating nav ── */
    .dash-nav-shell {
      position: fixed;
      bottom: calc(0.72rem + env(safe-area-inset-bottom));
      left: 50%; transform: translateX(-50%);
      display: flex; align-items: flex-end; gap: 0.55rem;
      z-index: 200;
    }
    .dash-nav {
      display: flex; align-items: center; gap: 0.25rem;
      padding: 0.32rem 0.54rem;
      background: rgba(15,23,42,0.55);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 9999px;
      backdrop-filter: blur(24px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      white-space: nowrap;
    }
    .nav-btn {
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.18rem;
      padding: 0.38rem 0.78rem; border-radius: 9999px;
      border: 1px solid transparent; background: transparent;
      color: #94a3b8; font-family: inherit; font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.07em; line-height: 1.05; cursor: pointer; transition: all 0.2s;
      text-align: center;
    }
    .nav-btn img { width: 16px; height: 16px; opacity: 0.55; transition: opacity 0.2s; filter: brightness(0) invert(1); }
    .nav-btn svg { width: 16px; height: 16px; opacity: 0.55; transition: opacity 0.2s; }
    .nav-btn:hover { background: rgba(255,255,255,0.08); color: #e2e8f0; }
    .nav-btn:hover img { opacity: 1; }
    .nav-btn:hover svg { opacity: 1; }
    .nav-btn.active { background: rgba(255,255,255,0.06); color: white; border-color: rgba(255,255,255,0.1); box-shadow: 0 0 20px rgba(59,130,246,0.4); }
    .nav-btn.active img { opacity: 1; }
    .nav-btn.active svg { opacity: 1; }
    .nav-search-stack {
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .nav-search-btn {
      width: 3.55rem; height: 3.55rem;
      display: flex; align-items: center; justify-content: center;
      border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(15,23,42,0.55);
      backdrop-filter: blur(24px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      cursor: pointer;
      transition: all 0.2s;
    }
    .nav-search-btn:hover,
    .nav-search-btn.active {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.18);
      box-shadow: 0 0 20px rgba(59,130,246,0.28);
    }
    .nav-search-btn img {
      width: 20px; height: 20px;
      opacity: 0.85;
      filter: brightness(0) invert(1);
    }
    .search-input {
      position: absolute;
      right: 0;
      bottom: calc(100% + 0.55rem);
      width: 0; max-width: 0; opacity: 0; pointer-events: none; overflow: hidden;
      padding: 0.5rem 1rem; border-radius: 9999px;
      border: 1px solid rgba(59,130,246,0.5); background: rgba(15,23,42,0.9);
      color: white; font-family: inherit; font-size: 0.78rem; outline: none;
      backdrop-filter: blur(20px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.45);
      transition: width 0.3s, opacity 0.3s, max-width 0.3s, transform 0.3s;
      transform: translateY(6px);
    }
    .search-input.open {
      width: 12rem; max-width: 12rem; opacity: 1; pointer-events: auto;
      transform: translateY(0);
    }
    .search-input::placeholder { color: rgba(148,163,184,0.6); }

    /* ── Panel surface ── */
    .panel {
      background: rgba(21,25,36,0.84);
      border: 1px solid rgba(71,85,105,0.55);
      border-radius: 1rem;
      box-shadow: 0 24px 44px -22px rgba(2,6,23,0.95), 0 0 0 1px rgba(59,130,246,0.08);
      backdrop-filter: blur(20px);
      transition: border-color 0.5s, box-shadow 0.5s;
    }
    .panel:hover { border-color: rgba(96,165,250,0.3); box-shadow: 0 30px 52px -20px rgba(2,6,23,0.98), 0 0 0 1px rgba(59,130,246,0.18); }
    .panel-title {
      font-size: 0.72rem; letter-spacing: 0.3em; font-weight: 900; text-transform: uppercase;
      background: linear-gradient(to right, #1d4ed8, #2563eb, #1d4ed8);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* ── Workspaces ── */
    .workspace { display: none; width: 100%; max-width: 80rem; padding: 0 1rem; flex-direction: column; align-items: center; }
    .workspace.active { display: flex; }

    /* Catalog */
    .catalog-header { width: 100%; display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem; }
    .catalog-title { font-size: 1.4rem; font-weight: 700; }
    .catalog-meta  { display: flex; flex-direction: column; align-items: flex-end; }
    .catalog-count { font-size: 0.78rem; font-weight: 600; color: #cbd5e1; }
    .catalog-page  { font-size: 0.68rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; }

    .filter-row { width: 100%; display: flex; gap: 0.5rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .filter-btn {
      padding: 0.3rem 0.9rem; border-radius: 9999px; font-family: inherit;
      font-size: 0.68rem; font-weight: 900; letter-spacing: 0.1em; cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04);
      color: #94a3b8; transition: all 0.2s;
    }
    .filter-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .filter-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 12px rgba(59,130,246,0.35); }

    .catalog-grid {
      width: 100%; display: grid; gap: 0.75rem;
      grid-template-columns: repeat(2, 1fr);
    }
    @media (min-width: 600px)  { .catalog-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 900px)  { .catalog-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (min-width: 1200px) { .catalog-grid { grid-template-columns: repeat(5, 1fr); } }

    .book-card {
      position: relative; border-radius: 1rem; overflow: hidden;
      border: 1px solid rgba(71,85,105,0.5); background: rgba(21,25,36,0.8);
      cursor: pointer; transition: transform 0.3s, opacity 0.3s;
      animation: cardIn 0.45s cubic-bezier(0.16,1,0.3,1) both;
    }
    .book-card:hover { transform: scale(1.03); }
    .book-card.checked-out { opacity: 0.6; filter: grayscale(1); border-color: rgba(239,68,68,0.5); }
    .book-card.held-for-user { opacity: 1; filter: none; border-color: rgba(168,85,247,0.55); box-shadow: 0 0 0 1px rgba(168,85,247,0.18), 0 18px 36px -26px rgba(168,85,247,0.5); }
    .book-card img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; }
    .book-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to bottom, transparent, rgba(15,23,42,0.75) 30%, rgba(15,23,42,0.97));
      padding: 2.5rem 0.75rem 0.75rem;
    }
    .book-title  { font-size: 0.88rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.2rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .book-author { font-size: 0.72rem; color: #cbd5e1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 0.2rem; }
    .book-isbn   { font-size: 0.62rem; color: #64748b; letter-spacing: 0.05em; margin-bottom: 0.4rem; }
    .badge { display: inline-block; padding: 0.25rem 0.6rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
    .badge-avail { background: rgba(34,197,94,0.2); color: #4ade80; }
    .badge-out   { background: rgba(239,68,68,0.2);  color: #f87171; }
    .badge-hold  { background: rgba(168,85,247,0.2); color: #c084fc; }
    .hold-state-note {
      display: inline-block;
      margin-top: 0.4rem;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }
    .hold-state-note.active { color: #c084fc; }
    .hold-state-note.ready  { color: #fbbf24; }
    .hold-state-note.muted  { color: #64748b; }

    .pagination { width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-top: 2rem; flex-wrap: wrap; }
    .page-btn {
      width: 2.1rem; height: 2.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: inherit; font-size: 0.72rem; font-weight: 600; cursor: pointer;
      border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: #94a3b8;
      transition: all 0.2s;
    }
    .page-btn:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: white; }
    .page-btn.active { background: rgba(59,130,246,0.2); color: white; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 12px rgba(59,130,246,0.35); }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .page-dots { color: #64748b; font-size: 0.85rem; display: flex; align-items: center; padding: 0 0.25rem; }

    /* Checkout */
    .checkout-row { display: flex; gap: 1.25rem; width: 100%; flex-direction: column; }
    @media (min-width: 768px) { .checkout-row { flex-direction: row; } }
    .scan-panel, .cart-panel { flex: 1; padding: 1.75rem; display: flex; flex-direction: column; align-items: center; text-align: center; animation: slideUp 0.4s ease-out; }
    .cart-panel { text-align: left; height: 420px; }
    @media (min-width: 768px) { .cart-panel { height: 500px; } }

    .scan-input {
      width: 100%; padding: 0.7rem 1.2rem; border-radius: 9999px;
      border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06);
      color: white; font-family: inherit; font-size: 1rem; text-align: center;
      outline: none; transition: all 0.3s; margin-bottom: 1.25rem;
    }
    .scan-input:focus { border-color: rgba(59,130,246,0.5); background: rgba(255,255,255,0.1); box-shadow: 0 0 15px rgba(59,130,246,0.2); }
    .scan-input::placeholder { color: rgba(148,163,184,0.6); }

    .checkout-cover  { width: 7rem; height: 10.5rem; object-fit: cover; border-radius: 0.75rem; border: 1px solid #475569; box-shadow: 0 8px 24px rgba(0,0,0,0.5); margin-bottom: 0.85rem; }
    .checkout-title  { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.2rem; }
    .checkout-author { font-size: 0.82rem; color: #94a3b8; font-style: italic; }
    .checkout-due    { font-size: 0.82rem; color: #60a5fa; font-weight: 700; margin-top: 0.4rem; }

    .cart-items { flex: 1; overflow-y: auto; width: 100%; display: flex; flex-direction: column; gap: 0.6rem; }
    .cart-item  { display: flex; align-items: center; gap: 0.75rem; background: rgba(21,25,36,0.84); padding: 0.85rem; border-radius: 0.75rem; border: 1px solid rgba(71,85,105,0.55); }
    .cart-item img { width: 2.75rem; height: 3.75rem; object-fit: cover; border-radius: 0.35rem; flex-shrink: 0; }
    .cart-item-title  { font-weight: 700; font-size: 0.82rem; }
    .cart-item-author { font-size: 0.7rem; color: #94a3b8; }
    .cart-item-due    { font-size: 0.68rem; color: #60a5fa; font-weight: 700; }
    .remove-btn { width: 1.85rem; height: 1.85rem; border-radius: 50%; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #f87171; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; flex-shrink: 0; margin-left: auto; }
    .remove-btn:hover { background: rgba(239,68,68,0.3); color: white; }
    .catalog-add-btn { margin-top: 0.5rem; width: 100%; padding: 0.4rem; border-radius: 0.5rem; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em; cursor: pointer; background: rgba(59,130,246,0.2); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); transition: all 0.2s; }
    .catalog-add-btn:hover { background: rgba(59,130,246,0.4); color: white; }

    .empty-cart { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
    .empty-cart img { width: 3rem; height: 3rem; opacity: 0.3; margin-bottom: 0.6rem; filter: brightness(0) invert(1); }
    .empty-cart p   { color: #64748b; font-size: 0.85rem; font-weight: 700; }
    .empty-cart span{ color: #475569; font-size: 0.72rem; }

    .confirm-btn {
      width: 100%; padding: 0.9rem; margin-top: 0.85rem; border-radius: 1rem;
      font-family: inherit; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.05em;
      cursor: pointer; border: 1px solid; transition: all 0.3s;
    }
    .confirm-btn.off { background: rgba(255,255,255,0.05); color: #64748b; border-color: rgba(255,255,255,0.1); cursor: not-allowed; }
    .confirm-btn.on  { background: rgba(59,130,246,0.2); color: #60a5fa; border-color: rgba(59,130,246,0.5); box-shadow: 0 0 30px -5px rgba(59,130,246,0.3); }
    .confirm-btn.on:hover { background: rgba(59,130,246,0.35); }

    /* Return */
    .return-panel { width: 100%; max-width: 52rem; padding: 2.25rem 1.75rem; text-align: center; animation: slideUp 0.4s ease-out; }
    .return-layout { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; margin-top: 1.25rem; }
    @media (min-width: 768px) { .return-layout { flex-direction: row; justify-content: center; gap: 4rem; text-align: left; } }
    .return-cover { width: 9rem; height: 13.5rem; object-fit: cover; border-radius: 1rem; border: 1px solid #475569; box-shadow: 0 16px 36px rgba(0,0,0,0.6); flex-shrink: 0; }
    .return-status { display: inline-block; padding: 0.3rem 0.9rem; border-radius: 9999px; font-size: 0.62rem; font-weight: 900; letter-spacing: 0.15em; border: 1px solid; margin-bottom: 0.85rem; }
    .return-status.waiting  { color: #94a3b8; background: #1e293b; border-color: #475569; }
    .return-status.returned { color: #60a5fa; background: rgba(59,130,246,0.2); border-color: rgba(59,130,246,0.5); }
    .return-title { font-size: 1.75rem; font-weight: 700; line-height: 1.2; }

    /* My Books */
    .mybooks-panel { width: 100%; max-width: 52rem; padding: 1.75rem; max-height: 75vh; overflow-y: auto; animation: slideUp 0.4s ease-out; }
    .section-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.85rem; }
    .divider { width: 100%; height: 1px; background: rgba(71,85,105,0.5); margin: 1.25rem 0; }

    .loan-row { display: flex; align-items: center; gap: 0.85rem; padding: 0.85rem; border-radius: 0.75rem; margin-bottom: 0.6rem; }
    .loan-row.active  { background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55); box-shadow: 0 16px 30px -20px rgba(2,6,23,0.95), 0 0 0 1px rgba(59,130,246,0.09), inset 0 1px 0 rgba(255,255,255,0.05); }
    .loan-row.history { background: rgba(21,25,36,0.68); border: 1px solid rgba(71,85,105,0.45); opacity: 0.85; }
    .loan-row img { width: 2.75rem; height: 3.75rem; border-radius: 0.35rem; object-fit: cover; flex-shrink: 0; }
    .loan-row.history img { width: 2.25rem; height: 3rem; }
    .loan-info { flex: 1; min-width: 0; }
    .loan-title  { font-weight: 700; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .loan-author { font-size: 0.7rem; color: #94a3b8; }
    .loan-due-label { font-size: 0.68rem; font-weight: 700; }
    .due-ok       { color: #60a5fa; }
    .due-overdue  { color: #f87171; }
    .due-returned { color: #64748b; }
    .loan-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; flex-shrink: 0; }

    .renew-btn {
      padding: 0.35rem 0.9rem; border-radius: 9999px;
      font-family: inherit; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em;
      cursor: pointer; border: none; background: rgba(59,130,246,0.2);
      color: #60a5fa; transition: all 0.2s;
    }
    .renew-btn:hover:not(:disabled) { background: rgba(59,130,246,0.35); }
    .renew-btn:disabled { background: #1e293b; color: #475569; cursor: not-allowed; }
    .hold-warning { font-size: 0.62rem; color: #fbbf24; font-weight: 600; max-width: 8rem; text-align: right; }

    .empty-state { display: flex; flex-direction: column; align-items: center; padding: 1.25rem; }
    .empty-state img { width: 2.75rem; height: 2.75rem; opacity: 0.3; margin-bottom: 0.6rem; filter: brightness(0) invert(1); }
    .empty-state p { color: #64748b; font-size: 0.82rem; }

    /* Toast */
    .toast-wrap { position: fixed; top: 6rem; left: 50%; transform: translateX(-50%); z-index: 500; display: flex; flex-direction: column; gap: 0.4rem; align-items: center; pointer-events: none; }
    .toast {
      padding: 0.7rem 1.1rem; border-radius: 0.75rem; font-size: 0.82rem; font-weight: 700;
      border: 1px solid; min-width: 15rem; max-width: 24rem; text-align: center;
      backdrop-filter: blur(12px); pointer-events: auto;
      animation: dropDown 0.4s cubic-bezier(0.16,1,0.3,1); box-shadow: 0 12px 32px rgba(0,0,0,0.5);
    }
    .toast.positive { background: rgba(34,197,94,0.15); color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .toast.negative { background: rgba(239,68,68,0.15); color: #f87171; border-color: rgba(239,68,68,0.3); }
    .toast.warning  { background: rgba(234,179,8,0.15);  color: #facc15; border-color: rgba(234,179,8,0.3); }

    .idle-overlay {
      position: fixed;
      inset: 0;
      z-index: 600;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1.25rem;
      background: rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(14px);
    }
    .idle-overlay.open {
      display: flex;
    }
    .idle-card {
      width: min(100%, 26rem);
      padding: 1.35rem 1.25rem;
      border-radius: 1.15rem;
      background: rgba(15, 23, 42, 0.95);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 24px 44px rgba(2, 6, 23, 0.75);
      text-align: center;
    }
    .idle-eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      font-weight: 900;
      text-transform: uppercase;
      color: #facc15;
      margin-bottom: 0.65rem;
    }
    .idle-title {
      font-size: 1.4rem;
      font-weight: 800;
      margin-bottom: 0.55rem;
      color: white;
    }
    .idle-copy {
      font-size: 0.82rem;
      line-height: 1.65;
      color: #cbd5e1;
      margin-bottom: 1rem;
    }
    .idle-countdown {
      font-size: 2rem;
      font-weight: 900;
      letter-spacing: -0.04em;
      color: #facc15;
      margin-bottom: 1rem;
    }
    .idle-actions {
      display: flex;
      gap: 0.65rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .idle-btn {
      min-width: 8.5rem;
      padding: 0.7rem 1rem;
      border-radius: 9999px;
      font-family: inherit;
      font-size: 0.75rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      border: 1px solid;
      transition: all 0.2s;
      text-decoration: none;
    }
    .idle-btn.primary {
      background: rgba(59,130,246,0.18);
      border-color: rgba(59,130,246,0.35);
      color: #60a5fa;
    }
    .idle-btn.primary:hover {
      background: rgba(59,130,246,0.32);
      color: white;
    }
    .idle-btn.secondary {
      background: rgba(239,68,68,0.12);
      border-color: rgba(239,68,68,0.24);
      color: #f87171;
    }
    .idle-btn.secondary:hover {
      background: rgba(239,68,68,0.26);
      color: white;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #3b82f6; }

    @media (max-width: 768px) {
      ::-webkit-scrollbar { display: none; }
      * { scrollbar-width: none; }
      .app-header { padding-left: 1rem; padding-right: 1rem; gap: 0.75rem; }
      .header-left { gap: 0.65rem; }
      .header-user-name { max-width: 6rem; font-size: 0.72rem; }
      .dash-nav-shell { gap: 0.42rem; }
      .dash-nav {
        max-width: calc(100vw - 1.05rem);
        gap: 0.14rem;
        padding: 0.3rem 0.5rem;
      }
      .nav-btn {
        padding: 0.36rem 0.62rem;
        min-width: 3.4rem;
        flex: 0 0 auto;
        font-size: 0.45rem;
        letter-spacing: 0.055em;
      }
      .nav-btn span { display: inline; }
      .nav-btn img, .nav-btn svg { width: 14px; height: 14px; }
      .nav-search-btn { width: 3.2rem; height: 3.2rem; }
      .nav-search-btn img { width: 18px; height: 18px; }
      .search-input.open { width: 8.2rem; max-width: 8.2rem; }
    }
    @media (max-height: 500px) and (min-width: 700px) {
      .app-header { min-height: 3.85rem; padding-top: max(0.3rem, env(safe-area-inset-top)); padding-bottom: 0.25rem; }
    }

    @media (pointer: coarse), (prefers-reduced-motion: reduce) {
      .stars-1, .stars-2, .stars-3 { display: none; }
      body::before {
        animation: none;
        opacity: 0.72;
      }
      .app-header,
      .dash-nav,
      .nav-search-btn,
      .search-input,
      .panel,
      .toast,
      .idle-overlay {
        -webkit-backdrop-filter: none;
        backdrop-filter: none;
      }
      .panel,
      .dash-nav,
      .nav-search-btn,
      .book-card,
      .loan-row.active,
      .toast,
      .idle-card {
        box-shadow: none;
      }
      .book-card,
      .scan-panel,
      .cart-panel,
      .return-panel,
      .mybooks-panel,
      .toast {
        animation: none;
      }
      .book-card,
      .nav-btn,
      .filter-btn,
      .page-btn,
      .confirm-btn,
      .scan-input,
      .renew-btn,
      .idle-btn {
        transition: none;
      }
      .book-card:hover {
        transform: none;
      }
      .book-card.checked-out {
        filter: none;
        opacity: 0.7;
      }
    }
  </style>
</head>
<body>
  <div class="stars-1"></div>
  <div class="stars-2"></div>
  <div class="stars-3"></div>

  <!-- Header -->
  <header class="app-header">
    <div class="header-left">
      <div class="header-brand">
        <img src="/assets/scsu_logo.png" alt="SCSU" onerror="this.style.display='none'" />
        <div class="brand-text">
          <span class="brand-cs">CS_LIBRARY</span>
          <span class="brand-sep">|</span>
          <span class="brand-kiosk">KIOSK</span>
        </div>
      </div>
    </div>
    <div class="header-user">
      <span class="header-user-name"><%= user.name %></span>
      <a href="/logout" class="logout-btn" title="Sign out">Sign out</a>
    </div>
  </header>

  <!-- Toast container -->
  <div class="toast-wrap" id="toastWrap"></div>
  <div class="idle-overlay" id="idleOverlay" aria-hidden="true">
    <div class="idle-card">
      <p class="idle-eyebrow">Session Timeout</p>
      <h2 class="idle-title">Still here?</h2>
      <p class="idle-copy">This kiosk signs people out automatically when it sits idle. Tap continue to keep using your account.</p>
      <div class="idle-countdown" id="idleCountdown">30</div>
      <div class="idle-actions">
        <button type="button" class="idle-btn primary" onclick="continueSession()">Continue Session</button>
        <button type="button" class="idle-btn secondary" onclick="logoutForIdle()">Sign Out Now</button>
      </div>
    </div>
  </div>

  <main class="page-wrap">

    <!-- ── CATALOG ── -->
    <div class="workspace active" id="ws-catalog">
      <div class="catalog-header">
        <h1 class="catalog-title">Library Catalog</h1>
        <div class="catalog-meta">
          <span class="catalog-count" id="catalogCount">Loading…</span>
          <span class="catalog-page"  id="catalogPage"></span>
        </div>
      </div>
      <div class="filter-row">
        <button class="filter-btn active" data-filter="all"         onclick="setFilter('all')">ALL</button>
        <button class="filter-btn"        data-filter="available"   onclick="setFilter('available')">AVAILABLE</button>
        <button class="filter-btn"        data-filter="checked_out" onclick="setFilter('checked_out')">CHECKED OUT</button>
        <button class="filter-btn"        data-filter="on_hold"     onclick="setFilter('on_hold')">ON HOLD</button>
      </div>
      <div class="catalog-grid" id="catalogGrid"></div>
      <div class="pagination"   id="pagination"></div>
    </div>

    <!-- ── CHECKOUT ── -->
    <div class="workspace" id="ws-checkout">
      <div class="checkout-row">
        <div class="panel scan-panel">
          <p class="panel-title" style="margin-bottom:1.25rem;">SCAN TO ADD TO CART</p>
        <input type="text" class="scan-input" id="checkoutInput"
                 placeholder="Scan ISBN…" autocomplete="off"
                 onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); scanISBN(); }" />
          <img id="checkoutCover" src="/assets/book-placeholder.svg"
               class="checkout-cover" alt="cover" />
          <p class="checkout-title"  id="checkoutTitle">---</p>
          <p class="checkout-author" id="checkoutAuthor">---</p>
          <p class="checkout-due"    id="checkoutDue"></p>
        </div>
        <div class="panel cart-panel">
          <p class="panel-title" style="margin-bottom:0.85rem;">YOUR CART</p>
          <div class="empty-cart" id="emptyCart">
            <img src="/assets/ph-shopping-cart.svg" alt="" />
            <p>Cart is empty</p><span>Scan a barcode to begin</span>
          </div>
          <div class="cart-items" id="cartItems"></div>
          <button class="confirm-btn off" id="confirmBtn" onclick="confirmCheckout()">
            CONFIRM CHECKOUT (0)
          </button>
        </div>
      </div>
    </div>

    <!-- ── RETURN ── -->
    <div class="workspace" id="ws-return">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">QUICK RETURN</p>
        <input type="text" class="scan-input" id="returnInput"
               placeholder="Scan barcode…" autocomplete="off"
               onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); scanReturn(); }" />
        <div class="return-layout">
          <img id="returnCover" src="/assets/book-placeholder.svg"
               class="return-cover" alt="cover" />
          <div>
            <span class="return-status waiting" id="returnStatus">WAITING FOR SCAN</span>
            <p class="return-title" id="returnTitle">---</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MY BOOKS ── -->
    <div class="workspace" id="ws-mybooks">
      <div class="panel mybooks-panel">
        <p class="panel-title" style="margin-bottom:1.25rem; text-align:center;">MY BORROWED BOOKS</p>
        <p class="section-title" id="activeCount">Currently Checked Out</p>
        <div id="activeLoans"></div>
        <div class="empty-state" id="noActiveLoans" style="display:none;">
          <img src="/assets/ph-check-circle.svg" alt="" />
          <p>No books currently checked out</p>
        </div>
        <div class="divider"></div>
        <p class="section-title">Borrowing History (Last 6 Months)</p>
        <div id="loanHistory"></div>
        <div class="empty-state" id="noHistory" style="display:none;">
          <img src="/assets/ph-clock-counter-clockwise.svg" alt="" />
          <p>No borrowing history yet</p>
        </div>
      </div>
      </div>
    </div>

    <!-- ── DONATE ── -->
    <div class="workspace" id="ws-donate">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">DONATE A BOOK</p>
        <input type="text" class="scan-input" id="donateIsbnInput"
               placeholder="Scan or type ISBN…" autocomplete="off"
               onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); lookupDonation(); }" />
        <div id="donatePreview" style="display:none;margin-top:1.25rem;">
          <img id="donateCover" src="" class="checkout-cover" alt="cover" style="margin:0 auto 0.85rem;" />
          <p class="checkout-title" id="donateTitle"></p>
          <p class="checkout-author" id="donateAuthor"></p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;margin-top:1rem;max-width:320px;margin-left:auto;margin-right:auto;">
            <input type="text" class="scan-input" id="donateTitleInput" placeholder="Title (edit if needed)" />
            <input type="text" class="scan-input" id="donateAuthorInput" placeholder="Author (edit if needed)" />
          </div>
          <button class="confirm-btn on" style="max-width:320px;margin:1rem auto 0;" onclick="confirmDonation()">CONFIRM DONATION</button>
        </div>
        <div id="donateManual" style="display:none;margin-top:1.25rem;">
          <p style="color:#fbbf24;font-size:0.82rem;margin-bottom:0.75rem;">Not found on Open Library — enter details manually:</p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;max-width:320px;margin:0 auto;">
            <input type="text" class="scan-input" id="donateManualTitle" placeholder="Book title" />
            <input type="text" class="scan-input" id="donateManualAuthor" placeholder="Author" />
          </div>
          <button class="confirm-btn on" style="max-width:320px;margin:1rem auto 0;" onclick="confirmManualDonation()">DONATE THIS BOOK</button>
        </div>
      </div>
    </div>

  </main>

  <!-- Floating nav -->
  <div class="dash-nav-shell">
    <nav class="dash-nav">
      <button class="nav-btn active" id="nav-catalog"  onclick="showView('catalog')">
        <img src="/assets/ph-squares-four.svg" alt="" /><span>BROWSE</span>
      </button>
      <button class="nav-btn"        id="nav-checkout" onclick="showView('checkout')">
        <img src="/assets/ph-shopping-cart.svg" alt="" /><span>CHECK<br>OUT</span>
      </button>
      <button class="nav-btn"        id="nav-return"   onclick="showView('return')">
        <img src="/assets/ph-arrow-u-down-left.svg" alt="" /><span>RETURN</span>
      </button>
      <button class="nav-btn"        id="nav-mybooks"  onclick="showView('mybooks')">
        <img src="/assets/ph-book-open-text.svg" alt="" /><span>MY<br>BOOKS</span>
      </button>
      <button class="nav-btn"        id="nav-donate"   onclick="showView('donate')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" style="opacity:0.55;"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg><span>DONATE</span>
      </button>
    </nav>
    <div class="nav-search-stack">
      <button class="nav-search-btn" id="searchBtn" onclick="toggleSearch()" aria-label="Search catalog">
        <img src="/assets/ph-magnifying-glass.svg" alt="" />
      </button>
      <input type="text" class="search-input" id="searchInput"
             placeholder="Search…" oninput="handleSearch(this.value)" />
    </div>
  </div>

  <script>
    // ── Seed cart from server session ──────────────────────────────────────────
    let cart = <%- JSON.stringify(cart || []) %>;

    // ── State ──────────────────────────────────────────────────────────────────
    let allBooks      = [];
    let filtered      = [];
    let currentFilter = 'all';
    let currentPage   = 1;
    const PER_PAGE    = window.matchMedia('(pointer: coarse)').matches ? 8 : 12;
    let searchQuery   = '';
    let searchTimer   = null;
    const currentUserId = <%= user.id %>;
    const IDLE_TIMEOUT_MS = <%= idleTimeoutMs %>;
    const IDLE_WARNING_MS = <%= idleWarningMs %>;
    const SESSION_PING_MS = Math.max(60 * 1000, Math.floor(IDLE_TIMEOUT_MS / 2));
    const SCANNER_CHAR_GAP_MS = 45;
    const MIN_SCANNER_LENGTH = 5;
    let idleTimer = null;
    let idleWarningTimer = null;
    let idleCountdownInterval = null;
    let idleDeadline = 0;
    let lastSessionPingAt = 0;
    const scannerState = { buffer: '', lastAt: 0 };

    // ── Toast ──────────────────────────────────────────────────────────────────
    function toast(msg, type = 'positive') {
      const el = document.createElement('div');
      el.className = `toast ${type}`;
      el.textContent = msg;
      document.getElementById('toastWrap').appendChild(el);
      setTimeout(() => el.remove(), 4500);
    }

    // ── Nav ────────────────────────────────────────────────────────────────────
    function getActiveView() {
      return document.querySelector('.workspace.active')?.id.replace('ws-', '') ?? 'catalog';
    }

    function getScannerTargetView() {
      const activeView = getActiveView();
      if (activeView === 'return') return 'return';
      if (activeView === 'donate') return 'donate';
      return 'checkout';
    }

    function getScannerInput(view = getScannerTargetView()) {
      if (view === 'return') return document.getElementById('returnInput');
      if (view === 'donate') return document.getElementById('donateIsbnInput');
      return document.getElementById('checkoutInput');
    }

    function getInteractiveTextInputIds() {
      return new Set([
        'checkoutInput',
        'returnInput',
        'donateIsbnInput',
        'donateTitleInput',
        'donateAuthorInput',
        'donateManualTitle',
        'donateManualAuthor',
        'searchInput',
      ]);
    }

    function isEditableElement(element) {
      return element instanceof HTMLInputElement ||
        element instanceof HTMLTextAreaElement ||
        element instanceof HTMLSelectElement ||
        element?.isContentEditable;
    }

    function isVisible(element) {
      return !!element && element.offsetParent !== null;
    }

    function focusPrimaryScannerInput() {
      const activeView = getActiveView();
      if (!['checkout', 'return', 'donate'].includes(activeView)) return;

      const activeElement = document.activeElement;
      const interactiveInputIds = getInteractiveTextInputIds();
      if (isEditableElement(activeElement) && interactiveInputIds.has(activeElement.id) && activeElement.id !== 'searchInput') {
        return;
      }

      const targetInput = getScannerInput(activeView);
      if (!isVisible(targetInput)) return;
      requestAnimationFrame(() => targetInput.focus());
    }

    function removeScannerLeak(buffer, intendedInput) {
      const activeElement = document.activeElement;
      if (!(activeElement instanceof HTMLInputElement || activeElement instanceof HTMLTextAreaElement)) return;
      if (activeElement === intendedInput) return;
      if (typeof activeElement.value !== 'string') return;
      if (activeElement.value.endsWith(buffer)) {
        activeElement.value = activeElement.value.slice(0, -buffer.length);
      }
    }

    async function submitScannerBuffer(buffer) {
      const targetView = getScannerTargetView();
      const activeView = getActiveView();

      if (targetView !== activeView) {
        showView(targetView);
      }

      const input = getScannerInput(targetView);
      if (!input) return;
      removeScannerLeak(buffer, input);
      input.value = buffer;

      if (targetView === 'return') {
        await scanReturn();
        return;
      }
      if (targetView === 'donate') {
        await lookupDonation();
        return;
      }
      await scanISBN();
    }

    function showView(view) {
      registerActivity();
      document.querySelectorAll('.workspace').forEach(w => w.classList.remove('active'));
      document.querySelectorAll('.nav-btn[id^="nav-"]').forEach(b => b.classList.remove('active'));
      document.getElementById(`ws-${view}`).classList.add('active');
      const nb = document.getElementById(`nav-${view}`);
      if (nb) nb.classList.add('active');
      if (view === 'checkout') document.getElementById('checkoutInput').focus();
      if (view === 'return')   document.getElementById('returnInput').focus();
      if (view === 'mybooks')  loadMyBooks();
      if (view === 'donate')   document.getElementById('donateIsbnInput')?.focus();
    }

    // ── Search ─────────────────────────────────────────────────────────────────
    function toggleSearch() {
      registerActivity();
      const inp = document.getElementById('searchInput');
      const btn = document.getElementById('searchBtn');
      inp.classList.toggle('open');
      btn.classList.toggle('active', inp.classList.contains('open'));
      if (inp.classList.contains('open')) { showView('catalog'); inp.focus(); }
      else { searchQuery = ''; inp.value = ''; applyFilters(); }
    }
    function handleSearch(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        searchQuery = val.toLowerCase().trim();
        currentPage = 1;
        applyFilters();
      }, 250);
    }

    // ── Catalog ────────────────────────────────────────────────────────────────
    async function loadCatalog() {
      try {
        const r = await fetch('/api/catalog');
        const d = await r.json();
        allBooks = d.books ?? [];
        applyFilters();
      } catch { toast('Could not load catalog.', 'negative'); }
    }

    function setFilter(f) {
      registerActivity();
      currentFilter = f; currentPage = 1;
      document.querySelectorAll('.filter-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.filter === f));
      applyFilters();
    }

    function applyFilters() {
      let b = allBooks;
      if (searchQuery)
        b = b.filter(x => x.title.toLowerCase().includes(searchQuery) ||
                          x.author.toLowerCase().includes(searchQuery) ||
                          (x.isbn||'').toLowerCase().includes(searchQuery));
      if (currentFilter === 'available')   b = b.filter(x => x.status === 'Available');
      if (currentFilter === 'checked_out') b = b.filter(x => x.status === 'Checked Out');
      if (currentFilter === 'on_hold')
        b = b.filter(x => x.status === 'On Hold' || x.heldByCurrentUser);
      filtered = b;
      const tp = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (currentPage > tp) currentPage = tp;
      renderCatalog(); renderPagination(tp);
    }

    function getHoldState(b, isBorrower) {
      if (isBorrower) {
        return { label: 'YOU HAVE THIS BOOK', className: 'hold-state-note muted' };
      }
      if (b.heldByCurrentUser && b.status === 'On Hold') {
        return { label: 'READY FOR PICKUP', className: 'hold-state-note ready' };
      }
      if (b.heldByCurrentUser) {
        return { label: 'YOUR HOLD IS ACTIVE', className: 'hold-state-note active' };
      }
      return null;
    }

    function renderCatalog() {
      const grid  = document.getElementById('catalogGrid');
      const start = (currentPage - 1) * PER_PAGE;
      const page  = filtered.slice(start, start + PER_PAGE);
      const tp    = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      document.getElementById('catalogCount').textContent =
        `Showing ${page.length} of ${filtered.length} book${filtered.length !== 1 ? 's' : ''}`;
      document.getElementById('catalogPage').textContent =
        `Page ${currentPage} of ${tp}`;
      grid.innerHTML = page.map((b, i) => {
        const avail = b.status === 'Available';
        const isOnHold = b.status === 'On Hold';
        const isBorrower = b.borrowerUserId && b.borrowerUserId === currentUserId;
        const holdState = getHoldState(b, isBorrower);
        return `<div class="book-card ${avail ? '' : 'checked-out'} ${b.heldByCurrentUser ? 'held-for-user' : ''}" style="animation-delay:${Math.min(i*.04,.24)}s">
          <img src="${esc(b.cover||'')}" loading="lazy" decoding="async"
               onerror="this.src='/assets/book-placeholder.svg'" alt="${esc(b.title)}" />
          <div class="book-overlay">
            <p class="book-title">${esc(b.title)}</p>
            <p class="book-author">${esc(b.author)}</p>
            <p class="book-isbn">ISBN ${esc(b.isbn||'')}</p>
            <span class="badge ${isOnHold ? 'badge-hold' : (avail ? 'badge-avail' : 'badge-out')}">${isOnHold ? 'ON HOLD' : (avail ? 'AVAILABLE' : 'CHECKED OUT')}</span>
            ${(() => {
              if (!avail) {
                if (holdState) {
                  return `<span class="${holdState.className}">${holdState.label}</span>`;
                }
                return `<button class="catalog-add-btn" onclick="event.stopPropagation(); placeHold('${esc(b.isbn)}')" style="background: rgba(168,85,247,0.15); color: #c084fc; border-color: rgba(168,85,247,0.3);">PLACE HOLD</button>`;
              }
              const inCart = cart.some(c => c.isbn === b.isbn);
              if (inCart) {
                return `<button class="catalog-add-btn" disabled style="background: rgba(34,197,94,0.15); color: #4ade80; border-color: rgba(34,197,94,0.3); cursor: default;">ADDED TO CART</button>`;
              }
              return `<button class="catalog-add-btn" onclick="addToCartByIsbn(event, '${esc(b.isbn)}')">ADD TO CART</button>`;
            })()}
          </div>
        </div>`;
      }).join('');
    }

    function renderPagination(tp) {
      const pg = document.getElementById('pagination');
      if (tp <= 1) { pg.innerHTML=''; return; }
      let pages = [];
      if (tp <= 7) { pages = Array.from({length:tp},(_,i)=>i+1); }
      else {
        pages=[1];
        if (currentPage>3) pages.push('…');
        for (let p=Math.max(2,currentPage-1); p<=Math.min(tp-1,currentPage+1); p++) if(!pages.includes(p)) pages.push(p);
        if (currentPage<tp-2) pages.push('…');
        if (!pages.includes(tp)) pages.push(tp);
      }
      pg.innerHTML =
        `<button class="page-btn" ${currentPage<=1?'disabled':''} onclick="goPage(${currentPage-1})">‹</button>` +
        pages.map(p => p==='…'
          ? `<span class="page-dots">···</span>`
          : `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`
        ).join('') +
        `<button class="page-btn" ${currentPage>=tp?'disabled':''} onclick="goPage(${currentPage+1})">›</button>`;
    }

    function goPage(p) {
      registerActivity();
      currentPage = Math.max(1, p);
      renderCatalog();
      renderPagination(Math.ceil(filtered.length/PER_PAGE));
      window.scrollTo({top:0,behavior:'smooth'});
    }

    // ── Checkout ───────────────────────────────────────────────────────────────
    function dueString() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
    }
    function dueShort() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    }

    async function scanISBN() {
      registerActivity();
      const inp  = document.getElementById('checkoutInput');
      const isbn = inp.value.trim(); inp.value = '';
      if (!isbn) return;
      try {
        const r = await fetch('/api/cart/add', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({isbn}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not add book.', r.status===409?'warning':'negative'); return; }
        cart = [...cart, d.book];
        refreshCartUI();
        // Update preview panel
        document.getElementById('checkoutCover').src    = d.book.cover || '/assets/book-placeholder.svg';
        document.getElementById('checkoutTitle').textContent  = d.book.title;
        document.getElementById('checkoutAuthor').textContent = d.book.author;
        document.getElementById('checkoutDue').textContent    = `Due: ${dueString()}`;
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    function refreshCartUI() {
      const empty = document.getElementById('emptyCart');
      const items = document.getElementById('cartItems');
      const btn   = document.getElementById('confirmBtn');
      empty.style.display = cart.length ? 'none' : 'flex';
      items.innerHTML = cart.map(b=>`
        <div class="cart-item">
          <img src="${esc(b.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
          <div><p class="cart-item-title">${esc(b.title)}</p>
               <p class="cart-item-author">${esc(b.author)}</p>
               <p class="cart-item-due">Due: ${dueShort()}</p></div>
          <button class="remove-btn" onclick="removeFromCart('${esc(b.isbn)}')">✕</button>
        </div>`).join('');
      btn.textContent = `CONFIRM CHECKOUT (${cart.length})`;
      btn.className   = `confirm-btn ${cart.length?'on':'off'}`;
      if (typeof renderCatalog === 'function' && filtered && filtered.length) {
        renderCatalog();
      }
    }

    async function addToCartByIsbn(e, isbn) {
      e.stopPropagation();
      const inp = document.getElementById('checkoutInput');
      inp.value = isbn;
      
      const preCartSize = cart.length;
      await scanISBN();
      
      if (cart.length > preCartSize) {
        toast('Added to cart!', 'positive');
      }
    }

    async function removeFromCart(isbn) {
      registerActivity();
      try {
        const r = await fetch('/api/cart/remove', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isbn }),
        });
        if (!r.ok) return;
        cart = cart.filter(b => b.isbn !== isbn);
        refreshCartUI();
      } catch (err) { toast('Error removing item.', 'negative'); }
    }

    async function confirmCheckout() {
      registerActivity();
      if (!cart.length) return;
      try {
        const r = await fetch('/api/checkout', {method:'POST'});
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Checkout failed.','negative'); return; }
        const {checkedOut, requested} = d;
        if (checkedOut === requested)
          toast(`Checked out ${checkedOut} item(s)! Return by ${dueString()}.`, 'positive');
        else if (checkedOut > 0)
          toast(`Checked out ${checkedOut} of ${requested} item(s). Some were unavailable.`, 'warning');
        else
          toast('No items checked out — books may be unavailable.', 'warning');
        cart = [];
        refreshCartUI();
        document.getElementById('checkoutCover').src = '/assets/book-placeholder.svg';
        document.getElementById('checkoutTitle').textContent  = '---';
        document.getElementById('checkoutAuthor').textContent = '---';
        document.getElementById('checkoutDue').textContent    = '';
        await loadCatalog();
      } catch { toast('Server error.','negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── Return ─────────────────────────────────────────────────────────────────
    async function scanReturn() {
      registerActivity();
      const inp  = document.getElementById('returnInput');
      const isbn = inp.value.trim(); inp.value='';
      if (!isbn) return;
      try {
        const r = await fetch('/api/return', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({isbn}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Return failed.', r.status===409?'warning':'negative'); return; }
        document.getElementById('returnCover').src   = d.book?.cover || '/assets/book-placeholder.svg';
        document.getElementById('returnTitle').textContent = d.book?.title ?? isbn;
        const badge = document.getElementById('returnStatus');
        badge.textContent = 'RETURNED SUCCESSFULLY';
        badge.className   = 'return-status returned';
        toast('Book returned!','positive');
        await loadCatalog();
      } catch { toast('Server error.','negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── My Books ───────────────────────────────────────────────────────────────
    async function loadMyBooks() {
      try {
        const r = await fetch('/api/my-loans');
        const d = await r.json();
        const loans   = d.loans ?? [];
        const active  = loans.filter(l => !l.returned);
        const history = loans.filter(l =>  l.returned);

        document.getElementById('activeCount').textContent =
          `Currently Checked Out${active.length ? ` — Total: ${active.length}` : ''}`;
        document.getElementById('noActiveLoans').style.display = active.length  ? 'none' : 'flex';
        document.getElementById('noHistory').style.display     = history.length ? 'none' : 'flex';

        document.getElementById('activeLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const overdue = due < new Date();
          const dueStr  = due.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
          const dueClass= overdue ? 'due-overdue' : 'due-ok';
          const dueLabel= overdue ? `OVERDUE: ${dueStr}` : `Due: ${dueStr}`;
          return `
            <div class="loan-row active">
              <img src="${esc(loan.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
                <p class="loan-due-label ${dueClass}">${dueLabel}</p>
              </div>
              <div class="loan-actions">
                <button class="renew-btn" ${overdue?'disabled':''} onclick="renewLoan(${loan.id}, this)">RENEW</button>
              </div>
            </div>`;
        }).join('');

        document.getElementById('loanHistory').innerHTML = history.map(loan => {
          const ret = loan.returnedDate
            ? new Date(loan.returnedDate).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
            : 'N/A';
          return `
            <div class="loan-row history">
              <img src="${esc(loan.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
              </div>
              <span class="loan-due-label due-returned">Returned: ${ret}</span>
            </div>`;
        }).join('');
      } catch { toast('Could not load loans.','negative'); }
    }

    async function renewLoan(loanId, btn) {
      registerActivity();
      btn.disabled = true;
      try {
        const r = await fetch('/api/renew', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({loanId}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Could not renew.','warning'); btn.disabled=false; return; }
        toast('Book renewed for 14 more days!','positive');
        await loadMyBooks();
      } catch { toast('Server error.','negative'); btn.disabled=false; }
    }

    // ── Donate ──────────────────────────────────────────────────────────────────
    let donateIsbn = '';
    let donateMeta = {};

    async function lookupDonation() {
      registerActivity();
      const isbn = document.getElementById('donateIsbnInput').value.trim();
      if (!isbn) return;
      donateIsbn = isbn;

      document.getElementById('donatePreview').style.display = 'none';
      document.getElementById('donateManual').style.display = 'none';

      try {
        const r = await fetch('/api/donate/lookup', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn }),
        });
        const d = await r.json();

        if (!r.ok) {
          // Show manual entry
          document.getElementById('donateManual').style.display = 'block';
          return;
        }

        donateMeta = d;
        document.getElementById('donateCover').src = d.cover || '';
        document.getElementById('donateTitle').textContent = d.title;
        document.getElementById('donateAuthor').textContent = d.author;
        document.getElementById('donateTitleInput').value = d.title;
        document.getElementById('donateAuthorInput').value = d.author;
        document.getElementById('donatePreview').style.display = 'block';
      } catch {
        document.getElementById('donateManual').style.display = 'block';
      }
      finally { focusPrimaryScannerInput(); }
    }

    async function confirmDonation() {
      registerActivity();
      const title  = document.getElementById('donateTitleInput').value.trim();
      const author = document.getElementById('donateAuthorInput').value.trim();
      if (!title) { toast('Title is required.', 'negative'); return; }
      try {
        const r = await fetch('/api/donate', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn: donateIsbn, title, author, cover: donateMeta.cover || '' }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Donation failed.', 'negative'); return; }
        toast('Book donated! Thank you! 📚', 'positive');
        document.getElementById('donateIsbnInput').value = '';
        document.getElementById('donatePreview').style.display = 'none';
        donateIsbn = '';
        donateMeta = {};
        loadCatalog(); // Refresh catalog to show new book
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    async function confirmManualDonation() {
      registerActivity();
      const title  = document.getElementById('donateManualTitle').value.trim();
      const author = document.getElementById('donateManualAuthor').value.trim();
      if (!title) { toast('Title is required.', 'negative'); return; }
      try {
        const r = await fetch('/api/donate', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn: donateIsbn, title, author }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Donation failed.', 'negative'); return; }
        toast('Book donated! Thank you! 📚', 'positive');
        document.getElementById('donateIsbnInput').value = '';
        document.getElementById('donateManual').style.display = 'none';
        donateIsbn = '';
        loadCatalog();
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── Holds ───────────────────────────────────────────────────────────────────
    async function placeHold(isbn) {
      registerActivity();
      try {
        const r = await fetch('/api/hold', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not place hold.', r.status===409 ? 'warning' : 'negative'); return; }
        allBooks = allBooks.map(book =>
          book.isbn === isbn ? { ...book, heldByCurrentUser: true } : book
        );
        applyFilters();
        toast('Hold placed! You will be notified when available.', 'positive');
      } catch { toast('Server error.', 'negative'); }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s??'')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    document.addEventListener('keydown', (event) => {
      if (event.ctrlKey || event.metaKey || event.altKey) return;
      if (document.getElementById('idleOverlay').classList.contains('open')) return;

      const { key } = event;
      const isPrintable = key.length === 1;
      const isTerminator = key === 'Enter' || key === 'Tab';
      if (!isPrintable && !isTerminator) return;

      const now = performance.now();
      if (!isTerminator) {
        if (!scannerState.lastAt || now - scannerState.lastAt > SCANNER_CHAR_GAP_MS) {
          scannerState.buffer = '';
        }
        scannerState.buffer += key;
        scannerState.lastAt = now;
        return;
      }

      if (scannerState.buffer.length >= MIN_SCANNER_LENGTH) {
        const buffer = scannerState.buffer;
        scannerState.buffer = '';
        scannerState.lastAt = 0;
        event.preventDefault();
        submitScannerBuffer(buffer).catch(() => toast('Scanner input failed.', 'negative'));
        return;
      }

      scannerState.buffer = '';
      scannerState.lastAt = 0;
    }, true);

    // ── Idle timeout ───────────────────────────────────────────────────────────
    function closeIdleWarning() {
      clearInterval(idleCountdownInterval);
      idleCountdownInterval = null;
      const overlay = document.getElementById('idleOverlay');
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    function updateIdleCountdown() {
      const secondsRemaining = Math.max(0, Math.ceil((idleDeadline - Date.now()) / 1000));
      document.getElementById('idleCountdown').textContent = String(secondsRemaining);
      if (secondsRemaining <= 0) {
        logoutForIdle();
      }
    }

    function showIdleWarning() {
      const overlay = document.getElementById('idleOverlay');
      idleDeadline = Date.now() + IDLE_WARNING_MS;
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      updateIdleCountdown();
      clearInterval(idleCountdownInterval);
      idleCountdownInterval = setInterval(updateIdleCountdown, 1000);
      toast('Session will end soon due to inactivity.', 'warning');
    }

    async function pingSessionIfNeeded() {
      const now = Date.now();
      if (now - lastSessionPingAt < SESSION_PING_MS) return;
      lastSessionPingAt = now;
      try {
        await fetch('/api/session/ping', {
          method: 'POST',
          keepalive: true,
          headers: { 'Content-Type': 'application/json' },
        });
      } catch {
        // Silent on purpose — the timeout flow will handle a dead session naturally.
      }
    }

    function scheduleIdleTimers() {
      clearTimeout(idleTimer);
      clearTimeout(idleWarningTimer);
      idleWarningTimer = setTimeout(showIdleWarning, Math.max(1000, IDLE_TIMEOUT_MS - IDLE_WARNING_MS));
      idleTimer = setTimeout(logoutForIdle, IDLE_TIMEOUT_MS);
    }

    function registerActivity() {
      closeIdleWarning();
      scheduleIdleTimers();
      pingSessionIfNeeded();
    }

    function continueSession() {
      registerActivity();
      toast('Session extended.', 'positive');
    }

    function logoutForIdle() {
      window.location.assign('/logout?reason=idle');
    }

    ['pointerdown', 'pointermove', 'keydown', 'scroll', 'touchstart', 'wheel'].forEach((eventName) => {
      window.addEventListener(eventName, registerActivity, { passive: true });
    });
    window.addEventListener('focus', focusPrimaryScannerInput);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') focusPrimaryScannerInput();
    });

    // ── Boot ───────────────────────────────────────────────────────────────────
    // Show welcome toast if redirected here after login
    <% if (welcome) { %>
      toast(decodeURIComponent('<%= encodeURIComponent(welcome) %>'), 'positive');
    <% } %>

    refreshCartUI();
    loadCatalog();
    scheduleIdleTimers();
    focusPrimaryScannerInput();
  </script>
</body>
</html>
