# Application Configuration
KIOSK_PORT=8081

# Application Configuration
CLOUD_HOST=localhost
CLOUD_PORT=8080
CLOUD_PROTOCOL=http

# Shared Secret Configuration
# This MUST match KIOSK_API_KEY in the server's .env exactly.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLOUD_API_KEY=your_kiosk_api_key_here

# Kiosk Session Configuration
# Local session secret for the Pi's Express session (not shared with the server).
# Generate one. Without it, it won't work.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_SESSION_SECRET=another_random_string_here
