      badge.textContent = avail ? 'AVAILABLE' : 'UNAVAILABLE';

      document.getElementById('equipModalMeta').innerHTML = [
        renderMetaCard('Category',    item.category),
        renderMetaCard('Loan Period', item.loanDurationDays ? item.loanDurationDays + ' days' : null),
        renderMetaCard('Total Units', item.totalUnits ?? '—'),
        renderMetaCard('Available',   item.availableUnits),
        renderMetaCard('Good Condition',  cond.Good  || '—'),
        renderMetaCard('Fair Condition',  cond.Fair  || '—'),
        renderMetaCard('Poor Condition',  cond.Poor  || '—'),
      ].join('');

      document.getElementById('equipModalCopy').innerHTML = item.description
