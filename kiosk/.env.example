# ── CS Library Kiosk — Raspberry Pi environment ───────────────────────────────
# Copy this file to kiosk/.env and fill in real values.
# NEVER commit kiosk/.env to git.

# URL of the cloud server's kiosk REST API — no trailing slash.
# Must end with /api/kiosk  (e.g. https://your-domain.com/api/kiosk)
# For the Virtual Machine, please use something like:
# CLOUD_API_URL=http://136.113.201.79:8080/api/kiosk
CLOUD_API_URL=https://your-server-domain.com/api/kiosk

# Shared secret — must match KIOSK_API_KEY in the server's .env exactly.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLOUD_API_KEY=your_kiosk_api_key_here

# Local session secret for the Pi's Express session (not shared with the server).
# Generate one. Without it, it won't work.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_SESSION_SECRET=another_random_string_here

# Port the kiosk UI listens on locally.
# Chromium will open http://localhost:8080 on boot.
KIOSK_PORT=8080
