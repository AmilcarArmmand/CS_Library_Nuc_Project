<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin-mobile.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Space Grotesk', sans-serif; background: #020617; color: white; min-height: 100vh; }

    /* Background */
    body::before {
      content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at 15% 50%, rgba(29,78,216,0.15), transparent 35%),
        radial-gradient(ellipse at 85% 30%, rgba(6,182,212,0.12), transparent 35%),
        radial-gradient(ellipse at 50% 80%, rgba(88,28,135,0.08), transparent 40%);
    }

    /* Layout */
    .admin-layout { display: flex; min-height: 100vh; position: relative; z-index: 1; }

    /* Sidebar */
    .sidebar {
      width: 250px; background: rgba(10,15,28,0.95); border-right: 1px solid rgba(255,255,255,0.08);
      display: flex; flex-direction: column; padding: 1.5rem 0; flex-shrink: 0;
      backdrop-filter: blur(20px); position: fixed; top: 0; left: 0; bottom: 0; z-index: 10;
    }
    .sidebar-brand { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 1rem; }
    .sidebar-brand h1 { font-size: 0.85rem; font-weight: 900; letter-spacing: 0.15em; }
    .sidebar-brand span { font-size: 0.65rem; color: #60a5fa; font-weight: 300; letter-spacing: 0.15em; }
    .nav-items { display: flex; flex-direction: column; gap: 0.15rem; padding: 0 0.75rem; flex: 1; }
    .nav-item {
      display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem;
      border-radius: 0.5rem; text-decoration: none; color: #94a3b8; font-size: 0.78rem;
      font-weight: 600; letter-spacing: 0.03em; transition: all 0.2s;
    }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
    .nav-item.active { background: rgba(59,130,246,0.15); color: #60a5fa; }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }
    .sidebar-footer .admin-name { font-size: 0.75rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.15rem; }
    .sidebar-footer .admin-email { font-size: 0.65rem; color: #64748b; margin-bottom: 0.6rem; }
    .signout-btn {
      display: inline-block; padding: 0.35rem 0.75rem; border-radius: 0.35rem;
      font-size: 0.68rem; font-weight: 700; color: #f87171; background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.2); text-decoration: none; transition: all 0.2s;
    }
    .signout-btn:hover { background: rgba(239,68,68,0.25); }

    /* Main */
    .main { flex: 1; margin-left: 250px; padding: 2rem; }
    .page-title { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.25rem; }
    .page-sub { font-size: 0.82rem; color: #64748b; margin-bottom: 2rem; }

    /* Stat cards */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .stat-card {
      background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55);
      border-radius: 0.75rem; padding: 1.25rem; backdrop-filter: blur(12px);
      transition: border-color 0.3s;
    }
    .stat-card:hover { border-color: rgba(96,165,250,0.3); }
    .stat-label { font-size: 0.68rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 0.5rem; }
    .stat-value { font-size: 2rem; font-weight: 900; line-height: 1; }
    .stat-value.blue { color: #60a5fa; }
    .stat-value.green { color: #4ade80; }
    .stat-value.amber { color: #fbbf24; }
    .stat-value.red { color: #f87171; }

    /* Panels */
    .panel {
      background: rgba(21,25,36,0.84); border: 1px solid rgba(71,85,105,0.55);
      border-radius: 1rem; padding: 1.5rem; backdrop-filter: blur(12px); margin-bottom: 1.5rem;
    }
    .panel-title {
      font-size: 0.72rem; letter-spacing: 0.2em; font-weight: 900; text-transform: uppercase;
      color: #60a5fa; margin-bottom: 1rem;
    }

    /* Table */
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid rgba(71,85,105,0.4); }
    td { font-size: 0.78rem; padding: 0.65rem 0.75rem; border-bottom: 1px solid rgba(71,85,105,0.2); color: #cbd5e1; }
    tr:hover td { background: rgba(255,255,255,0.02); }
    .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 9999px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.08em; }
    .badge-active { background: rgba(34,197,94,0.15); color: #4ade80; }
    .badge-returned { background: rgba(100,116,139,0.2); color: #94a3b8; }
    .badge-overdue { background: rgba(239,68,68,0.15); color: #f87171; }

    /* Two-column grid */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

    /* Popular books list */
    .pop-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid rgba(71,85,105,0.2); }
    .pop-item:last-child { border-bottom: none; }
    .pop-rank { width: 1.5rem; height: 1.5rem; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(59,130,246,0.15); color: #60a5fa; font-size: 0.65rem; font-weight: 900; flex-shrink: 0; }
    .pop-title { font-size: 0.78rem; font-weight: 700; }
    .pop-author { font-size: 0.68rem; color: #64748b; }
    .pop-count { margin-left: auto; font-size: 0.72rem; font-weight: 700; color: #60a5fa; }

    @media (max-width: 1024px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .two-col { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main { margin-left: 0; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
  <%- include('./partials/sidebar', { activePage: 'dashboard', mobileTitle: 'Dashboard', admin: admin }) %>

    <!-- Main content -->
    <main class="main">
      <h1 class="page-title">Dashboard</h1>
      <p class="page-sub">Overview of library activity and system health</p>

      <!-- Book stats -->
      <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#475569;margin-bottom:0.6rem;">Books</div>
      <div class="stats-grid" style="margin-bottom:0.75rem;">
        <div class="stat-card">
          <div class="stat-label">Registered Users</div>
          <div class="stat-value blue"><%= stats.users %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Books in Catalog</div>
          <div class="stat-value green"><%= stats.books %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Book Loans</div>
          <div class="stat-value amber"><%= stats.activeLoans %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Overdue Books</div>
          <div class="stat-value red"><%= stats.overdue %></div>
        </div>
      </div>

      <!-- Equipment stats -->
      <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#475569;margin-bottom:0.6rem;">Equipment</div>
      <div class="stats-grid" style="margin-bottom:2rem;">
        <div class="stat-card">
          <div class="stat-label">Equipment Types</div>
          <div class="stat-value blue"><%= stats.equipmentTypes %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Equipment Units</div>
          <div class="stat-value green"><%= stats.equipmentUnits %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Equipment Loans</div>
          <div class="stat-value amber"><%= stats.activeEquipmentLoans %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Overdue Equipment</div>
          <div class="stat-value red"><%= stats.overdueEquipment %></div>
        </div>
      </div>

      <!-- Row 1: Recent activity -->
      <div class="two-col">
        <!-- Recent Book Activity -->
        <div class="panel">
          <div class="panel-title">Recent Activity</div>
          <table>
            <thead><tr><th>Book</th><th>Borrower</th><th>Status</th><th>Date</th></tr></thead>
            <tbody>
              <% recentActivity.forEach(a => { %>
              <% const overdue = !a.returned && new Date(a.dueDate) < new Date(); %>
              <tr>
                <td style="font-weight:700;"><%= a.title %></td>
                <td><%= a.userName %></td>
                <td>
                  <% if (a.returned) { %>
                    <span class="badge badge-returned">RETURNED</span>
                  <% } else if (overdue) { %>
                    <span class="badge badge-overdue">OVERDUE</span>
                  <% } else { %>
                    <span class="badge badge-active">ACTIVE</span>
                  <% } %>
                </td>
                <td><%= new Date(a.checkedOut).toLocaleDateString('en-US', {month:'short',day:'numeric'}) %></td>
              </tr>
              <% }); %>
              <% if (!recentActivity.length) { %>
              <tr><td colspan="4" style="text-align:center;color:#64748b;">No activity yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Recent Equipment Activity -->
        <div class="panel">
          <div class="panel-title">Recent Equipment Activity</div>
          <table>
            <thead><tr><th>Item</th><th>Borrower</th><th>Status</th><th>Date</th></tr></thead>
            <tbody>
              <% recentEquipmentActivity.forEach(a => { %>
              <% const overdue = !a.returned && new Date(a.dueDate) < new Date(); %>
              <tr>
                <td style="font-weight:700;"><%= a.name %></td>
                <td><%= a.userName %></td>
                <td>
                  <% if (a.returned) { %>
                    <span class="badge badge-returned">RETURNED</span>
                  <% } else if (overdue) { %>
                    <span class="badge badge-overdue">OVERDUE</span>
                  <% } else { %>
                    <span class="badge badge-active">ACTIVE</span>
                  <% } %>
                </td>
                <td><%= new Date(a.checkedOut).toLocaleDateString('en-US', {month:'short',day:'numeric'}) %></td>
              </tr>
              <% }); %>
              <% if (!recentEquipmentActivity.length) { %>
              <tr><td colspan="4" style="text-align:center;color:#64748b;">No equipment activity yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Row 2: Popular lists -->
      <div class="two-col">
        <!-- Popular Books -->
        <div class="panel">
          <div class="panel-title">Most Popular Books</div>
          <% popularBooks.forEach((b, i) => { %>
          <div class="pop-item">
            <div class="pop-rank"><%= i + 1 %></div>
            <div>
              <div class="pop-title"><%= b.title %></div>
              <div class="pop-author"><%= b.author %></div>
            </div>
            <div class="pop-count"><%= b.checkoutCount %> checkouts</div>
          </div>
          <% }); %>
          <% if (!popularBooks.length) { %>
          <p style="color:#64748b;font-size:0.82rem;text-align:center;padding:1rem;">No data yet</p>
          <% } %>
        </div>

        <!-- Popular Equipment -->
        <div class="panel">
          <div class="panel-title">Most Popular Equipment</div>
          <% popularEquipment.forEach((e, i) => { %>
          <div class="pop-item">
            <div class="pop-rank"><%= i + 1 %></div>
            <div>
              <div class="pop-title"><%= e.name %></div>
              <div class="pop-author"><%= e.category || 'Equipment' %></div>
            </div>
            <div class="pop-count"><%= e.checkoutCount %> checkouts</div>
          </div>
          <% }); %>
          <% if (!popularEquipment.length) { %>
          <p style="color:#64748b;font-size:0.82rem;text-align:center;padding:1rem;">No data yet</p>
          <% } %>
        </div>
      </div>
    </main>
  </div>
  <script src="/js/admin-mobile.js"></script>
</body>
</html>
