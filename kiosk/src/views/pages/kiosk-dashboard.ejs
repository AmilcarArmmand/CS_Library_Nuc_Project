<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon1.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/kiosk-dashboard.css" />
</head>
<body>

  <!-- Header -->
  <header class="app-header">
    <div class="header-left">
      <div class="header-brand">
        <img src="/assets/scsu_logo.png" alt="SCSU" onerror="this.style.display='none'" />
        <div class="brand-text">
          <span class="brand-cs">CS_LIBRARY</span>
          <span class="brand-sep">|</span>
          <span class="brand-kiosk">KIOSK</span>
        </div>
      </div>
    </div>
    <div class="header-user">
      <span class="header-user-name"><%= user.name %></span>
      <a href="/logout" class="logout-btn" title="Sign out">Sign out</a>
    </div>
  </header>

  <!-- Toast container -->
  <div class="toast-wrap" id="toastWrap"></div>
  <div class="idle-overlay" id="idleOverlay" aria-hidden="true">
    <div class="idle-card">
      <p class="idle-eyebrow">Session Timeout</p>
      <h2 class="idle-title">Still here?</h2>
      <p class="idle-copy">This kiosk signs people out automatically when it sits idle. Tap continue to keep using your account.</p>
      <div class="idle-countdown" id="idleCountdown">30</div>
      <div class="idle-actions">
        <button type="button" class="idle-btn primary" onclick="continueSession()">Continue Session</button>
        <button type="button" class="idle-btn secondary" onclick="logoutForIdle()">Sign Out Now</button>
      </div>
    </div>
  </div>

  <main class="page-wrap">

    <!-- ── CATALOG ── -->
    <div class="workspace active" id="ws-catalog">
      <div class="catalog-header">
        <h1 class="catalog-title">Library Catalog</h1>
        <div class="catalog-meta">
          <span class="catalog-count" id="catalogCount">Loading…</span>
          <span class="catalog-page"  id="catalogPage"></span>
        </div>
      </div>
      <div class="filter-row">
        <button class="filter-btn active" data-filter="all"         onclick="setFilter('all')">ALL</button>
        <button class="filter-btn"        data-filter="available"   onclick="setFilter('available')">AVAILABLE</button>
        <button class="filter-btn"        data-filter="checked_out" onclick="setFilter('checked_out')">CHECKED OUT</button>
        <button class="filter-btn"        data-filter="on_hold"     onclick="setFilter('on_hold')">ON HOLD</button>
      </div>
      <div class="pagination" id="pagination-top"></div>
      <div class="catalog-grid" id="catalogGrid"></div>
      <div class="pagination"   id="pagination"></div>
    </div>

    <!-- ── CHECKOUT ── -->
    <div class="workspace" id="ws-checkout">
      <div class="checkout-row">
        <div class="panel scan-panel">
          <p class="panel-title" style="margin-bottom:1.25rem;">SCAN TO ADD TO CART</p>
          <input type="text" class="scan-input" id="checkoutInput"
                 placeholder="Scan ISBN…" autocomplete="off"
                 onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); scanISBN(); }" />
          <img id="checkoutCover" src="/assets/book-placeholder.svg"
               class="checkout-cover" alt="cover" />
          <p class="checkout-title"  id="checkoutTitle">---</p>
          <p class="checkout-author" id="checkoutAuthor">---</p>
          <p class="checkout-due"    id="checkoutDue"></p>
        </div>
        <div class="panel cart-panel">
          <p class="panel-title" style="margin-bottom:0.85rem;">YOUR CART</p>
          <div class="empty-cart" id="emptyCart">
            <img src="/assets/ph-shopping-cart.svg" alt="" />
            <p>Cart is empty</p><span>Scan a barcode to begin</span>
          </div>
          <div class="cart-items" id="cartItems"></div>
          <button class="confirm-btn off" id="confirmBtn" onclick="confirmCheckout()">
            CONFIRM CHECKOUT (0)
          </button>
        </div>
      </div>
    </div>

    <!-- ── RETURN ── -->
    <div class="workspace" id="ws-return">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">QUICK RETURN</p>
        <input type="text" class="scan-input" id="returnInput"
               placeholder="Scan book or equipment barcode…" autocomplete="off"
               onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); scanReturn(); }" />
        <div class="return-layout">
          <img id="returnCover" src="/assets/book-placeholder.svg"
               class="return-cover" alt="cover" />
          <div>
            <span class="return-status waiting" id="returnStatus">WAITING FOR SCAN</span>
            <p class="return-title" id="returnTitle">---</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MY BOOKS ── -->
    <div class="workspace" id="ws-mybooks">
      <div class="panel mybooks-panel">
        <p class="panel-title" style="margin-bottom:1.25rem; text-align:center;">MY BORROWED ITEMS</p>

        <!-- Books section -->
        <p class="section-title" id="activeCount">Books Checked Out</p>
        <div id="activeLoans"></div>
        <div class="empty-state" id="noActiveLoans" style="display:none;">
          <img src="/assets/ph-check-circle.svg" alt="" />
          <p>No books currently checked out</p>
        </div>

        <div class="divider"></div>
        <p class="section-title">Book Borrowing History (Last 6 Months)</p>
        <div id="loanHistory"></div>
        <div class="empty-state" id="noHistory" style="display:none;">
          <img src="/assets/ph-clock-counter-clockwise.svg" alt="" />
          <p>No borrowing history yet</p>
        </div>

        <!-- Equipment section -->
        <div class="divider"></div>
        <p class="section-title" id="equipmentLoanTitle">Equipment Checked Out</p>
        <div id="activeEquipmentLoans"></div>
        <div class="empty-state" id="noEquipmentLoans" style="display:none;">
          <img src="/assets/ph-check-circle.svg" alt="" />
          <p>No equipment currently checked out</p>
        </div>
      </div>
    </div>

    <!-- ── DONATE ── -->
    <div class="workspace" id="ws-donate">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">DONATE A BOOK</p>
        <input type="text" class="scan-input" id="donateIsbnInput"
               placeholder="Scan or type ISBN…" autocomplete="off"
               onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); lookupDonation(); }" />
        <div id="donatePreview" style="display:none;margin-top:1.25rem;">
          <img id="donateCover" src="" class="checkout-cover" alt="cover" style="margin:0 auto 0.85rem;" />
          <p class="checkout-title" id="donateTitle"></p>
          <p class="checkout-author" id="donateAuthor"></p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;margin-top:1rem;max-width:320px;margin-left:auto;margin-right:auto;">
            <input type="text" class="scan-input" id="donateTitleInput" placeholder="Title (edit if needed)" />
            <input type="text" class="scan-input" id="donateAuthorInput" placeholder="Author (edit if needed)" />
          </div>
          <button class="confirm-btn on" style="max-width:320px;margin:1rem auto 0;" onclick="confirmDonation()">CONFIRM DONATION</button>
        </div>
        <div id="donateManual" style="display:none;margin-top:1.25rem;">
          <p style="color:#fbbf24;font-size:0.82rem;margin-bottom:0.75rem;">Not found on Open Library — enter details manually:</p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;max-width:320px;margin:0 auto;">
            <input type="text" class="scan-input" id="donateManualTitle" placeholder="Book title" />
            <input type="text" class="scan-input" id="donateManualAuthor" placeholder="Author" />
          </div>
          <button class="confirm-btn on" style="max-width:320px;margin:1rem auto 0;" onclick="confirmManualDonation()">DONATE THIS BOOK</button>
        </div>
      </div>
    </div>

    <!-- ── EQUIPMENT ── -->
    <div class="workspace" id="ws-equipment">
      <div class="panel return-panel">
        <p class="panel-title" style="margin-bottom:1.25rem;">EQUIPMENT CHECKOUT / RETURN</p>

        <input type="text" class="scan-input" id="equipmentInput"
               placeholder="Scan equipment barcode…" autocomplete="off"
               onkeydown="if(event.key==='Enter' || event.key==='Tab'){ event.preventDefault(); scanEquipment(); }" />

        <!-- Preview card — hidden until a scan succeeds -->
        <div id="equipmentPreview" style="display:none;margin-top:1.5rem;">
          <div style="display:flex;gap:1rem;align-items:flex-start;justify-content:center;flex-wrap:wrap;">
            <img id="equipPreviewImg"
                 src="/assets/book-placeholder.svg"
                 style="width:80px;height:80px;object-fit:cover;border-radius:0.5rem;border:1px solid rgba(71,85,105,0.4);flex-shrink:0;"
                 alt="" />
            <div style="text-align:left;">
              <p id="equipPreviewName"    style="font-size:1rem;font-weight:800;color:white;margin-bottom:0.2rem;"></p>
              <p id="equipPreviewCat"     style="font-size:0.72rem;color:#64748b;margin-bottom:0.35rem;"></p>
              <p id="equipPreviewBarcode" style="font-size:0.68rem;font-family:monospace;color:#475569;margin-bottom:0.5rem;"></p>
              <span id="equipPreviewBadge" class="return-status waiting"></span>
            </div>
          </div>

          <!-- Loan info (shown when unit is checked out by someone else) -->
          <div id="equipLoanInfo" style="display:none;margin-top:1rem;padding:0.65rem 0.85rem;border-radius:0.6rem;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);font-size:0.76rem;color:#fca5a5;text-align:center;">
            Checked out by <strong id="equipLoanName"></strong>
            <span id="equipLoanDue" style="margin-left:0.5rem;color:#64748b;"></span>
          </div>

          <!-- Action buttons -->
          <div style="display:flex;gap:0.75rem;margin-top:1.25rem;justify-content:center;flex-wrap:wrap;">
            <button id="equipCheckoutBtn"
                    onclick="confirmEquipmentCheckout()"
                    style="display:none;padding:0.85rem 2rem;border-radius:0.65rem;font-family:inherit;font-size:0.85rem;font-weight:800;letter-spacing:0.06em;cursor:pointer;border:1px solid rgba(34,197,94,0.4);background:rgba(34,197,94,0.15);color:#4ade80;transition:all 0.2s;">
              CHECKOUT THIS ITEM
            </button>
            <button id="equipReturnBtn"
                    onclick="confirmEquipmentReturn()"
                    style="display:none;padding:0.85rem 2rem;border-radius:0.65rem;font-family:inherit;font-size:0.85rem;font-weight:800;letter-spacing:0.06em;cursor:pointer;border:1px solid rgba(59,130,246,0.4);background:rgba(59,130,246,0.15);color:#60a5fa;transition:all 0.2s;">
              RETURN THIS ITEM
            </button>
          </div>
        </div>

        <p style="margin-top:1.5rem;font-size:0.72rem;color:#334155;text-align:center;">
          Scan a barcode label to check out or return equipment.<br>
          For books, use the <strong style="color:#475569;">CHECK OUT</strong> and <strong style="color:#475569;">RETURN</strong> tabs.
        </p>
      </div>
    </div>

  </main>

  <!-- Floating nav -->
  <div class="dash-nav-shell">
    <nav class="dash-nav">
      <button class="nav-btn active" id="nav-catalog"   onclick="showView('catalog')">
        <img src="/assets/ph-squares-four.svg" alt="" /><span>BROWSE</span>
      </button>
      <button class="nav-btn"        id="nav-checkout"  onclick="showView('checkout')">
        <img src="/assets/ph-shopping-cart.svg" alt="" /><span>CHECK<br>OUT</span>
      </button>
      <button class="nav-btn"        id="nav-return"    onclick="showView('return')">
        <img src="/assets/ph-arrow-u-down-left.svg" alt="" /><span>RETURN</span>
      </button>
      <button class="nav-btn"        id="nav-mybooks"   onclick="showView('mybooks')">
        <img src="/assets/ph-book-open-text.svg" alt="" /><span>MY<br>ITEMS</span>
      </button>
      <button class="nav-btn"        id="nav-donate"    onclick="showView('donate')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" style="opacity:0.55;"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg><span>DONATE</span>
      </button>
      <button class="nav-btn"        id="nav-equipment" onclick="showView('equipment')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" style="opacity:0.55;"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg><span>EQUIP<br>MENT</span>
      </button>
    </nav>
    <div class="nav-search-stack">
      <button class="nav-search-btn" id="searchBtn" onclick="toggleSearch()" aria-label="Search catalog">
        <img src="/assets/ph-magnifying-glass.svg" alt="" />
      </button>
      <input type="text" class="search-input" id="searchInput"
             placeholder="Search…" oninput="handleSearch(this.value)" />
    </div>
  </div>

  <script>
    // ── Seed cart from server session ──────────────────────────────────────────
    let cart = <%- JSON.stringify(cart || []) %>;

    // ── State ──────────────────────────────────────────────────────────────────
    let allBooks      = [];
    let filtered      = [];
    let currentFilter = 'all';
    let currentPage   = 1;
    const PER_PAGE    = window.matchMedia('(pointer: coarse)').matches ? 8 : 12;
    let searchQuery   = '';
    let searchTimer   = null;
    const currentUserId = <%= user.id %>;
    const IDLE_TIMEOUT_MS = <%= idleTimeoutMs %>;
    const IDLE_WARNING_MS = <%= idleWarningMs %>;
    const SESSION_PING_MS = Math.max(60 * 1000, Math.floor(IDLE_TIMEOUT_MS / 2));
    const SCANNER_CHAR_GAP_MS = 45;
    const MIN_SCANNER_LENGTH = 5;
    let idleTimer = null;
    let idleWarningTimer = null;
    let idleCountdownInterval = null;
    let idleDeadline = 0;
    let lastSessionPingAt = 0;
    const scannerState = { buffer: '', lastAt: 0 };
    const renewedLoanIds = new Set();

    // ── Equipment state ────────────────────────────────────────────────────────
    let currentEquipUnit = null;

    // ── Toast ──────────────────────────────────────────────────────────────────
    function toast(msg, type = 'positive') {
      const el = document.createElement('div');
      el.className = `toast ${type}`;
      el.textContent = msg;
      document.getElementById('toastWrap').appendChild(el);
      setTimeout(() => el.remove(), 4500);
    }

    // ── Nav ────────────────────────────────────────────────────────────────────
    function getActiveView() {
      return document.querySelector('.workspace.active')?.id.replace('ws-', '') ?? 'catalog';
    }

    function getScannerTargetView() {
      const activeView = getActiveView();
      if (activeView === 'return')    return 'return';
      if (activeView === 'donate')    return 'donate';
      if (activeView === 'equipment') return 'equipment';
      return 'checkout';
    }

    function getScannerInput(view = getScannerTargetView()) {
      if (view === 'return')    return document.getElementById('returnInput');
      if (view === 'donate')    return document.getElementById('donateIsbnInput');
      if (view === 'equipment') return document.getElementById('equipmentInput');
      return document.getElementById('checkoutInput');
    }

    function getInteractiveTextInputIds() {
      return new Set([
        'checkoutInput',
        'returnInput',
        'donateIsbnInput',
        'donateTitleInput',
        'donateAuthorInput',
        'donateManualTitle',
        'donateManualAuthor',
        'equipmentInput',
        'searchInput',
      ]);
    }

    function isEditableElement(element) {
      return element instanceof HTMLInputElement ||
        element instanceof HTMLTextAreaElement ||
        element instanceof HTMLSelectElement ||
        element?.isContentEditable;
    }

    function isVisible(element) {
      return !!element && element.offsetParent !== null;
    }

    function focusPrimaryScannerInput() {
      const activeView = getActiveView();
      if (!['checkout', 'return', 'donate', 'equipment'].includes(activeView)) return;

      const activeElement = document.activeElement;
      const interactiveInputIds = getInteractiveTextInputIds();
      if (isEditableElement(activeElement) && interactiveInputIds.has(activeElement.id) && activeElement.id !== 'searchInput') {
        return;
      }

      const targetInput = getScannerInput(activeView);
      if (!isVisible(targetInput)) return;
      requestAnimationFrame(() => targetInput.focus());
    }

    function removeScannerLeak(buffer, intendedInput) {
      const activeElement = document.activeElement;
      if (!(activeElement instanceof HTMLInputElement || activeElement instanceof HTMLTextAreaElement)) return;
      if (activeElement === intendedInput) return;
      if (typeof activeElement.value !== 'string') return;
      if (activeElement.value.endsWith(buffer)) {
        activeElement.value = activeElement.value.slice(0, -buffer.length);
      }
    }

    async function submitScannerBuffer(buffer) {
      const targetView = getScannerTargetView();
      const activeView = getActiveView();

      if (targetView !== activeView) {
        showView(targetView);
      }

      const input = getScannerInput(targetView);
      if (!input) return;
      removeScannerLeak(buffer, input);
      input.value = buffer;

      if (targetView === 'return') {
        await scanReturn();
        return;
      }
      if (targetView === 'donate') {
        await lookupDonation();
        return;
      }
      if (targetView === 'equipment') {
        await scanEquipment();
        return;
      }
      await scanISBN();
    }

    function showView(view) {
      registerActivity();
      document.querySelectorAll('.workspace').forEach(w => w.classList.remove('active'));
      document.querySelectorAll('.nav-btn[id^="nav-"]').forEach(b => b.classList.remove('active'));
      document.getElementById(`ws-${view}`).classList.add('active');
      const nb = document.getElementById(`nav-${view}`);
      if (nb) nb.classList.add('active');
      if (view === 'checkout')  document.getElementById('checkoutInput').focus();
      if (view === 'return')    document.getElementById('returnInput').focus();
      if (view === 'mybooks')   loadMyBooks();
      if (view === 'donate')    document.getElementById('donateIsbnInput')?.focus();
      if (view === 'equipment') document.getElementById('equipmentInput')?.focus();
    }

    // ── Search ─────────────────────────────────────────────────────────────────
    function toggleSearch() {
      registerActivity();
      const inp = document.getElementById('searchInput');
      const btn = document.getElementById('searchBtn');
      inp.classList.toggle('open');
      btn.classList.toggle('active', inp.classList.contains('open'));
      if (inp.classList.contains('open')) { showView('catalog'); inp.focus(); }
      else { searchQuery = ''; inp.value = ''; applyFilters(); }
    }
    function handleSearch(val) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        searchQuery = val.toLowerCase().trim();
        currentPage = 1;
        applyFilters();
      }, 250);
    }

    // ── Catalog ────────────────────────────────────────────────────────────────
    async function loadCatalog() {
      try {
        const r = await fetch('/api/catalog');
        const d = await r.json();
        allBooks = d.books ?? [];
        applyFilters();
      } catch { toast('Could not load catalog.', 'negative'); }
    }

    function setFilter(f) {
      registerActivity();
      currentFilter = f; currentPage = 1;
      document.querySelectorAll('.filter-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.filter === f));
      applyFilters();
    }

    function applyFilters() {
      let b = allBooks;
      if (searchQuery)
        b = b.filter(x => x.title.toLowerCase().includes(searchQuery) ||
                          x.author.toLowerCase().includes(searchQuery) ||
                          (x.isbn||'').toLowerCase().includes(searchQuery));
      if (currentFilter === 'available')   b = b.filter(x => x.status === 'Available');
      if (currentFilter === 'checked_out') b = b.filter(x => x.status === 'Checked Out');
      if (currentFilter === 'on_hold')
        b = b.filter(x => x.status === 'On Hold' || x.heldByCurrentUser);
      filtered = b;
      const tp = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (currentPage > tp) currentPage = tp;
      renderCatalog(); renderPagination(tp);
    }

    function getHoldState(b, isBorrower) {
      if (isBorrower) {
        return { label: 'YOU HAVE THIS BOOK', className: 'hold-state-note muted' };
      }
      if (b.heldByCurrentUser && b.status === 'On Hold') {
        return { label: 'READY FOR PICKUP', className: 'hold-state-note ready' };
      }
      if (b.heldByCurrentUser) {
        return { label: 'YOUR HOLD IS ACTIVE', className: 'hold-state-note active' };
      }
      return null;
    }

    function renderCatalog() {
      const grid  = document.getElementById('catalogGrid');
      const start = (currentPage - 1) * PER_PAGE;
      const page  = filtered.slice(start, start + PER_PAGE);
      const tp    = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      document.getElementById('catalogCount').textContent =
        `Showing ${page.length} of ${filtered.length} book${filtered.length !== 1 ? 's' : ''}`;
      document.getElementById('catalogPage').textContent =
        `Page ${currentPage} of ${tp}`;
      grid.innerHTML = page.map((b, i) => {
        const avail = b.status === 'Available';
        const isOnHold = b.status === 'On Hold';
        const isBorrower = b.borrowerUserId && b.borrowerUserId === currentUserId;
        const holdState = getHoldState(b, isBorrower);
        return `<div class="book-card ${avail ? '' : 'checked-out'} ${b.heldByCurrentUser ? 'held-for-user' : ''}" style="animation-delay:${Math.min(i*.04,.24)}s">
          <img src="${esc(b.cover||'')}" loading="lazy" decoding="async"
               onerror="this.src='/assets/book-placeholder.svg'" alt="${esc(b.title)}" />
          <div class="book-overlay">
            <p class="book-title">${esc(b.title)}</p>
            <p class="book-author">${esc(b.author)}</p>
            <p class="book-isbn">ISBN ${esc(b.isbn||'')}</p>
            <span class="badge ${isOnHold ? 'badge-hold' : (avail ? 'badge-avail' : 'badge-out')}">${isOnHold ? 'ON HOLD' : (avail ? 'AVAILABLE' : 'CHECKED OUT')}</span>
            ${(() => {
              if (!avail) {
                if (holdState) {
                  return `<span class="${holdState.className}">${holdState.label}</span>`;
                }
                return `<button class="catalog-add-btn" onclick="event.stopPropagation(); placeHold('${esc(b.isbn)}')" style="background: rgba(168,85,247,0.15); color: #c084fc; border-color: rgba(168,85,247,0.3);">PLACE HOLD</button>`;
              }
              const inCart = cart.some(c => c.isbn === b.isbn);
              if (inCart) {
                return `<button class="catalog-add-btn" disabled style="background: rgba(34,197,94,0.15); color: #4ade80; border-color: rgba(34,197,94,0.3); cursor: default;">ADDED TO CART</button>`;
              }
              return `<button class="catalog-add-btn" onclick="addToCartByIsbn(event, '${esc(b.isbn)}')">ADD TO CART</button>`;
            })()}
          </div>
        </div>`;
      }).join('');
    }

    function renderPagination(tp) {
      const html = buildPaginationHTML(tp);
      document.getElementById('pagination').innerHTML = html;
      document.getElementById('pagination-top').innerHTML = html;
    }

    function buildPaginationHTML(tp) {
      if (tp <= 1) return '';
      let pages = [];
      if (tp <= 7) { pages = Array.from({length:tp},(_,i)=>i+1); }
      else {
        pages=[1];
        if (currentPage>3) pages.push('…');
        for (let p=Math.max(2,currentPage-1); p<=Math.min(tp-1,currentPage+1); p++) if(!pages.includes(p)) pages.push(p);
        if (currentPage<tp-2) pages.push('…');
        if (!pages.includes(tp)) pages.push(tp);
      }
      return (
        `<button class="page-btn" ${currentPage<=1?'disabled':''} onclick="goPage(${currentPage-1})">‹</button>` +
        pages.map(p => p==='…'
          ? `<span class="page-dots">···</span>`
          : `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`
        ).join('') +
        `<button class="page-btn" ${currentPage>=tp?'disabled':''} onclick="goPage(${currentPage+1})">›</button>`
      );
    }

    function goPage(p) {
      registerActivity();
      currentPage = Math.max(1, p);
      renderCatalog();
      renderPagination(Math.ceil(filtered.length/PER_PAGE));
      window.scrollTo({top:0,behavior:'smooth'});
    }

    // ── Checkout ───────────────────────────────────────────────────────────────
    function dueString() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
    }
    function dueShort() {
      const d = new Date(); d.setDate(d.getDate()+14);
      return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    }

    async function scanISBN() {
      registerActivity();
      const inp  = document.getElementById('checkoutInput');
      const isbn = inp.value.trim(); inp.value = '';
      if (!isbn) return;
      try {
        const r = await fetch('/api/cart/add', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({isbn}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not add book.', r.status===409?'warning':'negative'); return; }
        cart = [...cart, d.book];
        refreshCartUI();
        document.getElementById('checkoutCover').src    = d.book.cover || '/assets/book-placeholder.svg';
        document.getElementById('checkoutTitle').textContent  = d.book.title;
        document.getElementById('checkoutAuthor').textContent = d.book.author;
        document.getElementById('checkoutDue').textContent    = `Due: ${dueString()}`;
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    function refreshCartUI() {
      const empty = document.getElementById('emptyCart');
      const items = document.getElementById('cartItems');
      const btn   = document.getElementById('confirmBtn');
      empty.style.display = cart.length ? 'none' : 'flex';
      items.innerHTML = cart.map(b=>`
        <div class="cart-item">
          <img src="${esc(b.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
          <div><p class="cart-item-title">${esc(b.title)}</p>
               <p class="cart-item-author">${esc(b.author)}</p>
               <p class="cart-item-due">Due: ${dueShort()}</p></div>
          <button class="remove-btn" onclick="removeFromCart('${esc(b.isbn)}')">✕</button>
        </div>`).join('');
      btn.textContent = `CONFIRM CHECKOUT (${cart.length})`;
      btn.className   = `confirm-btn ${cart.length?'on':'off'}`;
      if (typeof renderCatalog === 'function' && filtered && filtered.length) {
        renderCatalog();
      }
    }

    async function addToCartByIsbn(e, isbn) {
      e.stopPropagation();
      const inp = document.getElementById('checkoutInput');
      inp.value = isbn;
      const preCartSize = cart.length;
      await scanISBN();
      if (cart.length > preCartSize) {
        toast('Added to cart!', 'positive');
      }
    }

    async function removeFromCart(isbn) {
      registerActivity();
      try {
        const r = await fetch('/api/cart/remove', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isbn }),
        });
        if (!r.ok) return;
        cart = cart.filter(b => b.isbn !== isbn);
        refreshCartUI();
      } catch (err) { toast('Error removing item.', 'negative'); }
    }

    async function confirmCheckout() {
      registerActivity();
      if (!cart.length) return;
      try {
        const r = await fetch('/api/checkout', {method:'POST'});
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Checkout failed.','negative'); return; }
        const {checkedOut, requested} = d;
        if (checkedOut === requested)
          toast(`Checked out ${checkedOut} item(s)! Return by ${dueString()}.`, 'positive');
        else if (checkedOut > 0)
          toast(`Checked out ${checkedOut} of ${requested} item(s). Some were unavailable.`, 'warning');
        else
          toast('No items checked out — books may be unavailable.', 'warning');
        cart = [];
        refreshCartUI();
        document.getElementById('checkoutCover').src = '/assets/book-placeholder.svg';
        document.getElementById('checkoutTitle').textContent  = '---';
        document.getElementById('checkoutAuthor').textContent = '---';
        document.getElementById('checkoutDue').textContent    = '';
        await loadCatalog();
      } catch { toast('Server error.','negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── Return (smart — handles both books and equipment) ─────────────────────
    async function scanReturn() {
      registerActivity();
      const inp   = document.getElementById('returnInput');
      const input = inp.value.trim(); inp.value = '';
      if (!input) return;
      try {
        const r = await fetch('/api/return', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ isbn: input }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Return failed.', r.status===409?'warning':'negative'); return; }

        const badge = document.getElementById('returnStatus');
        badge.textContent = 'RETURNED SUCCESSFULLY';
        badge.className   = 'return-status returned';

        if (d.type === 'equipment') {
          document.getElementById('returnCover').src = d.image || '/assets/book-placeholder.svg';
          document.getElementById('returnTitle').textContent = d.name ?? input;
          toast(`${d.name ?? 'Equipment'} returned!`, 'positive');
        } else {
          document.getElementById('returnCover').src = d.book?.cover || '/assets/book-placeholder.svg';
          document.getElementById('returnTitle').textContent = d.book?.title ?? input;
          toast('Book returned!', 'positive');
          await loadCatalog();
        }
      } catch { toast('Server error.','negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── My Books (books + equipment) ──────────────────────────────────────────
    async function loadMyBooks() {
      try {
        const r = await fetch('/api/my-loans');
        const d = await r.json();
        const loans   = d.loans ?? [];
        const active  = loans.filter(l => !l.returned);
        const history = loans.filter(l =>  l.returned);

        document.getElementById('activeCount').textContent =
          `Books Checked Out${active.length ? ` — Total: ${active.length}` : ''}`;
        document.getElementById('noActiveLoans').style.display = active.length  ? 'none' : 'flex';
        document.getElementById('noHistory').style.display     = history.length ? 'none' : 'flex';

        document.getElementById('activeLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const overdue = due < new Date();
          const dueStr  = due.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
          const dueClass= overdue ? 'due-overdue' : 'due-ok';
          const dueLabel= overdue ? `OVERDUE: ${dueStr}` : `Due: ${dueStr}`;
          return `
            <div class="loan-row active">
              <img src="${esc(loan.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
                <p class="loan-due-label ${dueClass}">${dueLabel}</p>
              </div>
              <div class="loan-actions">
                <button class="renew-btn" ${(overdue || renewedLoanIds.has(loan.id)) ? 'disabled' : ''} onclick="renewLoan(${loan.id}, this)">
                  ${renewedLoanIds.has(loan.id) ? 'RENEWED' : 'RENEW'}
                </button>
              </div>
            </div>`;
        }).join('');

        document.getElementById('loanHistory').innerHTML = history.map(loan => {
          const ret = loan.returnedDate
            ? new Date(loan.returnedDate).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
            : 'N/A';
          return `
            <div class="loan-row history">
              <img src="${esc(loan.cover||'')}" loading="lazy" decoding="async" onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.title)}</p>
                <p class="loan-author">${esc(loan.author)}</p>
              </div>
              <span class="loan-due-label due-returned">Returned: ${ret}</span>
            </div>`;
        }).join('');
      } catch { toast('Could not load loans.','negative'); }

      // Load equipment loans alongside book loans
      await loadEquipmentLoans();
    }

    async function renewLoan(loanId, btn) {
      registerActivity();
      btn.disabled = true;
      try {
        const r = await fetch('/api/renew', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({loanId}),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error??'Could not renew.','warning'); btn.disabled=false; return; }
        renewedLoanIds.add(loanId);
        toast('Book renewed for 14 more days!','positive');
        await loadMyBooks();
      } catch { toast('Server error.','negative'); btn.disabled=false; }
    }

    // ── Equipment loans (My Items section) ────────────────────────────────────
    async function loadEquipmentLoans() {
      try {
        const r = await fetch('/api/equipment/loans');
        const d = await r.json();
        const active = (d.loans ?? []).filter(l => !l.returned);

        document.getElementById('equipmentLoanTitle').textContent =
          `Equipment Checked Out${active.length ? ` — Total: ${active.length}` : ''}`;
        document.getElementById('noEquipmentLoans').style.display =
          active.length ? 'none' : 'flex';

        document.getElementById('activeEquipmentLoans').innerHTML = active.map(loan => {
          const due     = new Date(loan.dueDate);
          const overdue = due < new Date();
          const dueStr  = due.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          const dueClass = overdue ? 'due-overdue' : 'due-ok';
          const dueLabel = overdue ? `OVERDUE: ${dueStr}` : `Due: ${dueStr}`;
          return `
            <div class="loan-row active">
              <img src="${esc(loan.image||'')}" loading="lazy" decoding="async"
                   onerror="this.src='/assets/book-placeholder.svg'" alt="" />
              <div class="loan-info">
                <p class="loan-title">${esc(loan.name)}</p>
                <p class="loan-author">${esc(loan.category || 'Equipment')}</p>
                <p class="loan-due-label ${dueClass}">${dueLabel}</p>
              </div>
            </div>`;
        }).join('');
      } catch {
        // Silent fail — don't block the books section
      }
    }

    // ── Equipment scan & actions ───────────────────────────────────────────────
    async function scanEquipment() {
      registerActivity();
      const inp     = document.getElementById('equipmentInput');
      const barcode = inp.value.trim().toUpperCase();
      inp.value     = '';
      if (!barcode) return;

      try {
        const r = await fetch(`/api/equipment/scan/${encodeURIComponent(barcode)}`);
        const d = await r.json();

        if (!r.ok) {
          toast(d.error ?? 'Equipment not found.', 'negative');
          hideEquipPreview();
          return;
        }

        currentEquipUnit = d.unit;
        const activeLoan = d.activeLoan;

        document.getElementById('equipPreviewImg').src =
          d.unit.image || '/assets/book-placeholder.svg';
        document.getElementById('equipPreviewName').textContent    = d.unit.name;
        document.getElementById('equipPreviewCat').textContent     = d.unit.category || '';
        document.getElementById('equipPreviewBarcode').textContent = `Barcode: ${d.unit.barcode}`;

        const badge       = document.getElementById('equipPreviewBadge');
        const loanInfo    = document.getElementById('equipLoanInfo');
        const checkoutBtn = document.getElementById('equipCheckoutBtn');
        const returnBtn   = document.getElementById('equipReturnBtn');

        if (d.unit.status === 'Available' && !activeLoan) {
          badge.textContent         = 'AVAILABLE';
          badge.className           = 'return-status returned';
          loanInfo.style.display    = 'none';
          checkoutBtn.style.display = '';
          returnBtn.style.display   = 'none';
        } else if (activeLoan) {
          badge.textContent         = 'CHECKED OUT';
          badge.className           = 'return-status waiting';
          document.getElementById('equipLoanName').textContent = activeLoan.borrowerName;
          document.getElementById('equipLoanDue').textContent  =
            '— Due: ' + new Date(activeLoan.dueDate).toLocaleDateString('en-US', {
              month: 'long', day: 'numeric', year: 'numeric',
            });
          loanInfo.style.display    = '';
          checkoutBtn.style.display = 'none';
          // Show Return — user may be returning their own item
          returnBtn.style.display   = '';
        } else {
          badge.textContent         = d.unit.status.toUpperCase();
          badge.className           = 'return-status waiting';
          loanInfo.style.display    = 'none';
          checkoutBtn.style.display = 'none';
          returnBtn.style.display   = 'none';
        }

        document.getElementById('equipmentPreview').style.display = '';
      } catch {
        toast('Server error.', 'negative');
      } finally {
        focusPrimaryScannerInput();
      }
    }

    function hideEquipPreview() {
      currentEquipUnit = null;
      document.getElementById('equipmentPreview').style.display = 'none';
    }

    async function confirmEquipmentCheckout() {
      registerActivity();
      if (!currentEquipUnit) return;
      try {
        const r = await fetch('/api/equipment/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ barcode: currentEquipUnit.barcode }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Checkout failed.', 'negative'); return; }
        const due = new Date(d.dueDate).toLocaleDateString('en-US', {
          month: 'long', day: 'numeric', year: 'numeric',
        });
        toast(`${d.name} checked out! Return by ${due}.`, 'positive');
        hideEquipPreview();
      } catch {
        toast('Server error.', 'negative');
      } finally {
        focusPrimaryScannerInput();
      }
    }

    async function confirmEquipmentReturn() {
      registerActivity();
      if (!currentEquipUnit) return;
      try {
        const r = await fetch('/api/equipment/return', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ barcode: currentEquipUnit.barcode }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Return failed.', 'negative'); return; }
        toast(`${d.name ?? 'Equipment'} returned successfully!`, 'positive');
        hideEquipPreview();
      } catch {
        toast('Server error.', 'negative');
      } finally {
        focusPrimaryScannerInput();
      }
    }

    // ── Donate ──────────────────────────────────────────────────────────────────
    let donateIsbn = '';
    let donateMeta = {};

    async function lookupDonation() {
      registerActivity();
      const isbn = document.getElementById('donateIsbnInput').value.trim();
      if (!isbn) return;
      donateIsbn = isbn;

      document.getElementById('donatePreview').style.display = 'none';
      document.getElementById('donateManual').style.display = 'none';

      try {
        const r = await fetch('/api/donate/lookup', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn }),
        });
        const d = await r.json();

        if (!r.ok) {
          document.getElementById('donateManual').style.display = 'block';
          return;
        }

        donateMeta = d;
        document.getElementById('donateCover').src = d.cover || '';
        document.getElementById('donateTitle').textContent = d.title;
        document.getElementById('donateAuthor').textContent = d.author;
        document.getElementById('donateTitleInput').value = d.title;
        document.getElementById('donateAuthorInput').value = d.author;
        document.getElementById('donatePreview').style.display = 'block';
      } catch {
        document.getElementById('donateManual').style.display = 'block';
      }
      finally { focusPrimaryScannerInput(); }
    }

    async function confirmDonation() {
      registerActivity();
      const title  = document.getElementById('donateTitleInput').value.trim();
      const author = document.getElementById('donateAuthorInput').value.trim();
      if (!title) { toast('Title is required.', 'negative'); return; }
      try {
        const r = await fetch('/api/donate', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn: donateIsbn, title, author, cover: donateMeta.cover || '' }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Donation failed.', 'negative'); return; }
        toast('Book donated! Thank you! 📚', 'positive');
        document.getElementById('donateIsbnInput').value = '';
        document.getElementById('donatePreview').style.display = 'none';
        donateIsbn = '';
        donateMeta = {};
        loadCatalog();
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    async function confirmManualDonation() {
      registerActivity();
      const title  = document.getElementById('donateManualTitle').value.trim();
      const author = document.getElementById('donateManualAuthor').value.trim();
      if (!title) { toast('Title is required.', 'negative'); return; }
      try {
        const r = await fetch('/api/donate', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn: donateIsbn, title, author }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Donation failed.', 'negative'); return; }
        toast('Book donated! Thank you! 📚', 'positive');
        document.getElementById('donateIsbnInput').value = '';
        document.getElementById('donateManual').style.display = 'none';
        donateIsbn = '';
        loadCatalog();
      } catch { toast('Server error.', 'negative'); }
      finally { focusPrimaryScannerInput(); }
    }

    // ── Holds ───────────────────────────────────────────────────────────────────
    async function placeHold(isbn) {
      registerActivity();
      try {
        const r = await fetch('/api/hold', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ isbn }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not place hold.', r.status===409 ? 'warning' : 'negative'); return; }
        allBooks = allBooks.map(book =>
          book.isbn === isbn ? { ...book, heldByCurrentUser: true } : book
        );
        applyFilters();
        toast('Hold placed! You will be notified when available.', 'positive');
      } catch { toast('Server error.', 'negative'); }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s??'')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    document.addEventListener('keydown', (event) => {
      if (event.ctrlKey || event.metaKey || event.altKey) return;
      if (document.getElementById('idleOverlay').classList.contains('open')) return;

      const { key } = event;
      const isPrintable = key.length === 1;
      const isTerminator = key === 'Enter' || key === 'Tab';
      if (!isPrintable && !isTerminator) return;

      const now = performance.now();
      if (!isTerminator) {
        if (!scannerState.lastAt || now - scannerState.lastAt > SCANNER_CHAR_GAP_MS) {
          scannerState.buffer = '';
        }
        scannerState.buffer += key;
        scannerState.lastAt = now;
        return;
      }

      if (scannerState.buffer.length >= MIN_SCANNER_LENGTH) {
        const buffer = scannerState.buffer;
        scannerState.buffer = '';
        scannerState.lastAt = 0;
        event.preventDefault();
        submitScannerBuffer(buffer).catch(() => toast('Scanner input failed.', 'negative'));
        return;
      }

      scannerState.buffer = '';
      scannerState.lastAt = 0;
    }, true);

    // ── Idle timeout ───────────────────────────────────────────────────────────
    function closeIdleWarning() {
      clearInterval(idleCountdownInterval);
      idleCountdownInterval = null;
      const overlay = document.getElementById('idleOverlay');
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    function updateIdleCountdown() {
      const secondsRemaining = Math.max(0, Math.ceil((idleDeadline - Date.now()) / 1000));
      document.getElementById('idleCountdown').textContent = String(secondsRemaining);
      if (secondsRemaining <= 0) {
        logoutForIdle();
      }
    }

    function showIdleWarning() {
      const overlay = document.getElementById('idleOverlay');
      idleDeadline = Date.now() + IDLE_WARNING_MS;
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      updateIdleCountdown();
      clearInterval(idleCountdownInterval);
      idleCountdownInterval = setInterval(updateIdleCountdown, 1000);
      toast('Session will end soon due to inactivity.', 'warning');
    }

    async function pingSessionIfNeeded() {
      const now = Date.now();
      if (now - lastSessionPingAt < SESSION_PING_MS) return;
      lastSessionPingAt = now;
      try {
        await fetch('/api/session/ping', {
          method: 'POST',
          keepalive: true,
          headers: { 'Content-Type': 'application/json' },
        });
      } catch {
        // Silent on purpose — the timeout flow will handle a dead session naturally.
      }
    }

    function scheduleIdleTimers() {
      clearTimeout(idleTimer);
      clearTimeout(idleWarningTimer);
      idleWarningTimer = setTimeout(showIdleWarning, Math.max(1000, IDLE_TIMEOUT_MS - IDLE_WARNING_MS));
      idleTimer = setTimeout(logoutForIdle, IDLE_TIMEOUT_MS);
    }

    function registerActivity() {
      closeIdleWarning();
      scheduleIdleTimers();
      pingSessionIfNeeded();
    }

    function continueSession() {
      registerActivity();
      toast('Session extended.', 'positive');
    }

    function logoutForIdle() {
      window.location.assign('/logout?reason=idle');
    }

    ['pointerdown', 'pointermove', 'keydown', 'scroll', 'touchstart', 'wheel'].forEach((eventName) => {
      window.addEventListener(eventName, registerActivity, { passive: true });
    });
    window.addEventListener('focus', focusPrimaryScannerInput);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') focusPrimaryScannerInput();
    });

    // ── Boot ───────────────────────────────────────────────────────────────────
    <% if (welcome) { %>
      toast(decodeURIComponent('<%= encodeURIComponent(welcome) %>'), 'positive');
    <% } %>

    refreshCartUI();
    loadCatalog();
    scheduleIdleTimers();
    focusPrimaryScannerInput();
  </script>
</body>
</html>
