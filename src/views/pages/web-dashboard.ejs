      if (e.target.id === 'equipModal') closeEquipModal();
    }

    // ── Book reviews ───────────────────────────────────────────────────────────
    let bookRatingSelected = 0;

    function setBookRating(val) {
      bookRatingSelected = val;
      document.querySelectorAll('#bookStarInput button').forEach(btn => {
        btn.classList.toggle('active', Number(btn.dataset.val) <= val);
      });
      document.getElementById('bookReviewHint').textContent = '';
    }

    function starsHTML(rating) {
      return Array.from({length: 5}, (_, i) =>
        `<span class="${i < Math.round(rating) ? 'star-filled' : 'star-empty'}">★</span>`
      ).join('');
    }

    async function loadBookReviews(isbn) {
      const loading  = document.getElementById('bookReviewLoading');
      const avgEl    = document.getElementById('bookReviewAvg');
      const listEl   = document.getElementById('bookReviewList');
      const deleteBtn = document.getElementById('bookDeleteBtn');

      if (!loading) return;
      loading.style.display = '';
      avgEl.style.display   = 'none';
      listEl.innerHTML      = '';
      bookRatingSelected    = 0;

      // Reset star input
      document.querySelectorAll('#bookStarInput button').forEach(b => b.classList.remove('active'));
      const bodyEl = document.getElementById('bookReviewBody');
      if (bodyEl) bodyEl.value = '';
      if (deleteBtn) deleteBtn.style.display = 'none';

      try {
        const r = await fetch(`/web-dashboard/api/reviews/book/${encodeURIComponent(isbn)}`);
        const d = await r.json();
        loading.style.display = 'none';

        if (d.avgRating !== null) {
          document.getElementById('bookAvgNum').textContent  = d.avgRating.toFixed(1);
          document.getElementById('bookAvgStars').innerHTML  = starsHTML(d.avgRating);
          document.getElementById('bookAvgSub').textContent  =
            `${d.total} review${d.total !== 1 ? 's' : ''}`;
          avgEl.style.display = '';
        }

        // Pre-fill form if user already has a review
        if (d.myReview) {
          setBookRating(d.myReview.rating);
          if (bodyEl) bodyEl.value = d.myReview.body ?? '';
          if (deleteBtn) deleteBtn.style.display = '';
          document.getElementById('bookReviewHint').textContent = 'You have already reviewed this book — submitting will update your review.';
        }

        // Render other users' reviews (exclude own — they can see it in the form)
        const others = d.reviews.filter(rv => !d.myReview || rv.id !== d.myReview.id);
        if (others.length === 0 && !d.myReview) {
          listEl.innerHTML = '<div class="review-no-reviews">No reviews yet. Be the first!</div>';
        } else {
          listEl.innerHTML = others.map(rv => `
            <div class="review-item">
              <div class="review-item-header">
                <span class="review-item-name">${esc(rv.userName)}</span>
                <span class="stars-display">${starsHTML(rv.rating)}</span>
                <span class="review-item-date">${new Date(rv.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'})}</span>
              </div>
              ${rv.body ? `<p class="review-item-body">${esc(rv.body)}</p>` : ''}
            </div>`).join('');
        }
      } catch {
        if (loading) loading.textContent = 'Could not load reviews.';
      }
    }

    async function submitBookReview() {
      if (!activeDetailIsbn) return;
      if (!bookRatingSelected) {
        document.getElementById('bookReviewHint').textContent = 'Please select a star rating first.';
        return;
      }
      const body = (document.getElementById('bookReviewBody')?.value ?? '').trim();
      try {
        const r = await fetch('/web-dashboard/api/reviews', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ targetType: 'book', targetId: activeDetailIsbn, rating: bookRatingSelected, body }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not save review.', 'negative'); return; }
        toast('Review saved!', 'positive');
        loadBookReviews(activeDetailIsbn);
      } catch { toast('Server error.', 'negative'); }
    }

    async function deleteBookReview() {
      if (!activeDetailIsbn) return;
      if (!confirm('Delete your review for this book?')) return;
      // Need the review id — re-fetch to get it
      try {
        const r = await fetch(`/web-dashboard/api/reviews/book/${encodeURIComponent(activeDetailIsbn)}`);
        const d = await r.json();
        if (!d.myReview) { toast('No review found.', 'warning'); return; }
        const dr = await fetch(`/web-dashboard/api/reviews/${d.myReview.id}`, { method: 'DELETE' });
        if (!dr.ok) { toast('Could not delete review.', 'negative'); return; }
        toast('Review deleted.', 'positive');
        loadBookReviews(activeDetailIsbn);
      } catch { toast('Server error.', 'negative'); }
    }

    // ── Equipment reviews ──────────────────────────────────────────────────────
    let equipRatingSelected = 0;
    let activeEquipId = null;

    function setEquipRating(val) {
      equipRatingSelected = val;
      document.querySelectorAll('#equipStarInput button').forEach(btn => {
        btn.classList.toggle('active', Number(btn.dataset.val) <= val);
      });
      document.getElementById('equipReviewHint').textContent = '';
    }

    async function loadEquipReviews(equipId) {
      activeEquipId = equipId;
      const loading   = document.getElementById('equipReviewLoading');
      const avgEl     = document.getElementById('equipReviewAvg');
      const listEl    = document.getElementById('equipReviewList');
      const deleteBtn = document.getElementById('equipDeleteBtn');

      if (!loading) return;
      loading.style.display = '';
      avgEl.style.display   = 'none';
      listEl.innerHTML      = '';
      equipRatingSelected   = 0;

      // Reset star input
      document.querySelectorAll('#equipStarInput button').forEach(b => b.classList.remove('active'));
      const bodyEl = document.getElementById('equipReviewBody');
      if (bodyEl) bodyEl.value = '';
      if (deleteBtn) deleteBtn.style.display = 'none';

      try {
        const r = await fetch(`/web-dashboard/api/reviews/equipment/${encodeURIComponent(equipId)}`);
        const d = await r.json();
        loading.style.display = 'none';

        if (d.avgRating !== null) {
          document.getElementById('equipAvgNum').textContent  = d.avgRating.toFixed(1);
          document.getElementById('equipAvgStars').innerHTML  = starsHTML(d.avgRating);
          document.getElementById('equipAvgSub').textContent  =
            `${d.total} review${d.total !== 1 ? 's' : ''}`;
          avgEl.style.display = '';
        }

        // Pre-fill form if user already has a review
        if (d.myReview) {
          setEquipRating(d.myReview.rating);
          if (bodyEl) bodyEl.value = d.myReview.body ?? '';
          if (deleteBtn) deleteBtn.style.display = '';
          document.getElementById('equipReviewHint').textContent =
            'You have already reviewed this item — submitting will update your review.';
        }

        // Render other users' reviews
        const others = d.reviews.filter(rv => !d.myReview || rv.id !== d.myReview.id);
        if (others.length === 0 && !d.myReview) {
          listEl.innerHTML = '<div class="review-no-reviews">No reviews yet. Be the first!</div>';
        } else {
          listEl.innerHTML = others.map(rv => `
            <div class="review-item">
              <div class="review-item-header">
                <span class="review-item-name">${esc(rv.userName)}</span>
                <span class="stars-display">${starsHTML(rv.rating)}</span>
                <span class="review-item-date">${new Date(rv.createdAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'})}</span>
              </div>
              ${rv.body ? `<p class="review-item-body">${esc(rv.body)}</p>` : ''}
            </div>`).join('');
        }
      } catch {
        if (loading) loading.textContent = 'Could not load reviews.';
      }
    }

    async function submitEquipReview() {
      if (!activeEquipId) return;
      if (!equipRatingSelected) {
        document.getElementById('equipReviewHint').textContent = 'Please select a star rating first.';
        return;
      }
      const body = (document.getElementById('equipReviewBody')?.value ?? '').trim();
      try {
        const r = await fetch('/web-dashboard/api/reviews', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ targetType: 'equipment', targetId: activeEquipId, rating: equipRatingSelected, body }),
        });
        const d = await r.json();
        if (!r.ok) { toast(d.error ?? 'Could not save review.', 'negative'); return; }
        toast('Review saved!', 'positive');
        loadEquipReviews(activeEquipId);
      } catch { toast('Server error.', 'negative'); }
    }

    async function deleteEquipReview() {
      if (!activeEquipId) return;
      if (!confirm('Delete your review for this item?')) return;
      try {
        const r = await fetch(`/web-dashboard/api/reviews/equipment/${encodeURIComponent(activeEquipId)}`);
        const d = await r.json();
        if (!d.myReview) { toast('No review found.', 'warning'); return; }
        const dr = await fetch(`/web-dashboard/api/reviews/${d.myReview.id}`, { method: 'DELETE' });
        if (!dr.ok) { toast('Could not delete review.', 'negative'); return; }
        toast('Review deleted.', 'positive');
        loadEquipReviews(activeEquipId);
      } catch { toast('Server error.', 'negative'); }
    }

    // ── My Reviews ─────────────────────────────────────────────────────────────
    async function loadMyReviews() {
      const btn = document.getElementById('refreshReviewsBtn');
      if (btn) btn.classList.add('spinning');

      try {
        const r = await fetch('/web-dashboard/api/my-reviews');
        const d = await r.json();
        const reviewList = d.reviews ?? [];

        document.getElementById('noMyReviews').style.display = reviewList.length ? 'none' : 'flex';

        document.getElementById('myReviewsList').innerHTML = reviewList.map(rv => {
          const date = new Date(rv.createdAt).toLocaleDateString('en-US', {
            month: 'long', day: 'numeric', year: 'numeric',
          });
          const updated = rv.updatedAt !== rv.createdAt
            ? ` · edited ${new Date(rv.updatedAt).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'})}`
            : '';
          const typeLabel = rv.targetType === 'book' ? '📚 Book' : '🔧 Equipment';
          const clickFn  = rv.targetType === 'book'
            ? `openBookModal('${esc(rv.targetId)}')`
            : `openEquipModal(${Number(rv.targetId)})`;

          return `
            <div class="loan-row" style="cursor:pointer;" onclick="${clickFn}">
              <div class="loan-info" style="flex:1;">
                <p class="loan-title">${esc(rv.itemName)}</p>
                <p class="loan-author" style="font-size:0.68rem;color:#475569;">${typeLabel}</p>
                <div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.3rem;">
                  <span class="stars-display">${starsHTML(rv.rating)}</span>
                  <span style="font-size:0.65rem;color:#64748b;">${date}${updated}</span>
                </div>
                ${rv.body
                  ? `<p style="font-size:0.76rem;color:#94a3b8;margin-top:0.4rem;line-height:1.5;">${esc(rv.body)}</p>`
                  : `<p style="font-size:0.72rem;color:#334155;margin-top:0.3rem;font-style:italic;">No written review</p>`}
              </div>
              <div style="font-size:0.65rem;color:#475569;flex-shrink:0;white-space:nowrap;">Tap to edit →</div>
            </div>`;
        }).join('');
      } catch {
        toast('Could not load reviews.', 'negative');
      } finally {
        if (btn) btn.classList.remove('spinning');
      }
    }

    // ── Helper ──────────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s ?? '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
    }

    // ── Boot ────────────────────────────────────────────────────────────────────
    // Read ?view= query param so header nav links from index.ejs navigate correctly
    const urlParams = new URLSearchParams(window.location.search);
    const startView = urlParams.get('view');
    if (startView && ['catalog', 'mybooks', 'suggest', 'equipment', 'reviews'].includes(startView)) {
      showView(startView);
    } else {
      showView('catalog');
    }
    loadCatalog();
  </script>
</body>
</html>
