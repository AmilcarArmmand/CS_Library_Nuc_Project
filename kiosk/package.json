{
  "name": "cs-library-kiosk-pi",
  "version": "1.0.0",
  "description": "CS Library Kiosk — Raspberry Pi client",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "clean": "rm -rf dist && rm -rf drizzle && rm -rf node_modules && rm -rf package-lock.json",
    "dev":   "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "install-kiosk": "cd pi && ./install-kiosk-services.sh",
    "uninstall-kiosk": "cd pi && ./uninstall-kiosk-services.sh",
    "start-kiosk": "sudo systemctl start cs-library-kiosk-app.service && sudo systemctl start cs-library-kiosk-browser.service && exit",
    "test": "echo \"Setup Jest aready!\" && exit 1"
  },
  "dependencies": {
    "dotenv":         "^16.4.5",
    "ejs":            "^3.1.10",
    "express":        "^4.19.2",
    "express-session": "^1.18.0"
  },
  "devDependencies": {
    "@types/ejs":             "^3.1.5",
    "@types/express":         "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node":            "^20.14.0",
    "tsx":                    "^4.15.0",
    "typescript":             "^5.4.5"
  }
}